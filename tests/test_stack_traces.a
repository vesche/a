fn assert_eq(a: i64, b: i64) -> void {
  if a != b {
    fail("expected " + to_str(a) + " == " + to_str(b))
  }
}

fn assert_true(b: bool) -> void {
  if !b {
    fail("expected true, got false")
  }
}

fn add(a: i64, b: i64) -> i64 {
  ret a + b
}

fn test_no_error_no_stack() -> void {
  assert_eq(add(2, 3), 5)
}

fn identity(x: i64) -> i64 {
  ret x
}

fn double(x: i64) -> i64 {
  ret identity(x) * 2
}

fn test_normal_call_chain() -> void {
  assert_eq(double(5), 10)
}

fn fib(n: i64) -> i64 {
  if n <= 1 {
    ret n
  }
  ret fib(n - 1) + fib(n - 2)
}

fn test_recursive_no_error() -> void {
  assert_eq(fib(10), 55)
}

fn accumulate(items: [i64]) -> i64 {
  let mut sum = 0
  for item in items {
    sum = sum + item
  }
  ret sum
}

fn test_loop_no_error() -> void {
  assert_eq(accumulate([1, 2, 3, 4, 5]), 15)
}
