; test_fs_tx.a -- tests for std/fs_tx.a transactional file operations

use std.fs_tx

fn assert(cond, msg) {
  if !cond { fail("ASSERT: " + msg) }
}

fn _tmp(name) -> str {
  ret "/tmp/a_test_fs_tx_" + name
}

fn _cleanup(path) {
  if fs.exists(path) { fs.rm(path) }
}

fn test_begin_commit() {
  let f = _tmp("commit.txt")
  _cleanup(f)
  io.write_file(f, "original")

  let tx = fs_tx.begin([f])
  assert(tx["committed"] == false, "should not be committed yet")
  assert(len(tx["snapped"]) == 1, "should snapshot 1 file")

  io.write_file(f, "modified")
  let tx2 = fs_tx.commit(tx)
  assert(tx2["committed"] == true, "should be committed")

  let content = io.read_file(f)
  assert(content == "modified", "file should remain modified after commit")
  _cleanup(f)
  println("  ok begin/commit")
}

fn test_begin_rollback() {
  let f = _tmp("rollback.txt")
  _cleanup(f)
  io.write_file(f, "original")

  let tx = fs_tx.begin([f])
  io.write_file(f, "modified")

  let content_mid = io.read_file(f)
  assert(content_mid == "modified", "file should be modified mid-transaction")

  let tx2 = fs_tx.rollback(tx)
  assert(tx2["rolled_back"] == true, "should be rolled back")

  let content_after = io.read_file(f)
  assert(content_after == "original", "file should be restored after rollback")
  _cleanup(f)
  println("  ok begin/rollback")
}

fn test_multiple_files() {
  let f1 = _tmp("multi1.txt")
  let f2 = _tmp("multi2.txt")
  _cleanup(f1)
  _cleanup(f2)
  io.write_file(f1, "aaa")
  io.write_file(f2, "bbb")

  let tx = fs_tx.begin([f1, f2])
  assert(len(tx["snapped"]) == 2, "should snapshot 2 files")

  io.write_file(f1, "xxx")
  io.write_file(f2, "yyy")

  fs_tx.rollback(tx)

  assert(io.read_file(f1) == "aaa", "f1 should be restored")
  assert(io.read_file(f2) == "bbb", "f2 should be restored")
  _cleanup(f1)
  _cleanup(f2)
  println("  ok multiple files rollback")
}

fn test_missing_file_in_paths() {
  let f = _tmp("exists.txt")
  let missing = _tmp("no_such_file.txt")
  _cleanup(f)
  _cleanup(missing)
  io.write_file(f, "here")

  let tx = fs_tx.begin([f, missing])
  assert(len(tx["snapped"]) == 1, "should only snapshot existing files")

  io.write_file(f, "changed")
  fs_tx.rollback(tx)
  assert(io.read_file(f) == "here", "existing file should be restored")
  _cleanup(f)
  println("  ok missing file handled")
}

fn test_modify_then_commit() {
  let p = _tmp("mod_commit.txt")
  _cleanup(p)
  io.write_file(p, "before")

  let tx = fs_tx.begin([p])
  io.write_file(p, "after")
  fs_tx.commit(tx)

  assert(io.read_file(p) == "after", "file should be modified after commit")
  _cleanup(p)
  println("  ok modify then commit keeps changes")
}

fn test_modify_then_rollback() {
  let p = _tmp("mod_rollback.txt")
  _cleanup(p)
  io.write_file(p, "safe")

  let tx = fs_tx.begin([p])
  io.write_file(p, "dangerous")
  assert(io.read_file(p) == "dangerous", "file should be modified mid-transaction")
  fs_tx.rollback(tx)

  assert(io.read_file(p) == "safe", "file should be restored after rollback")
  _cleanup(p)
  println("  ok modify then rollback restores")
}

fn test_nested_begin_rollback() {
  let p1 = _tmp("nested1.txt")
  let p2 = _tmp("nested2.txt")
  _cleanup(p1)
  _cleanup(p2)
  io.write_file(p1, "orig1")
  io.write_file(p2, "orig2")

  let tx = fs_tx.begin([p1, p2])
  io.write_file(p1, "new1")
  io.write_file(p2, "new2")
  fs_tx.rollback(tx)

  assert(io.read_file(p1) == "orig1", "p1 should be restored")
  assert(io.read_file(p2) == "orig2", "p2 should be restored")
  _cleanup(p1)
  _cleanup(p2)
  println("  ok nested begin/rollback restores all files")
}

fn test_commit_cleans_up() {
  let f = _tmp("cleanup.txt")
  _cleanup(f)
  io.write_file(f, "data")

  let tx = fs_tx.begin([f])
  let dir = tx["backup_dir"]
  assert(fs.exists(dir), "backup dir should exist after begin")

  fs_tx.commit(tx)
  assert(!fs.exists(dir), "backup dir should be removed after commit")
  _cleanup(f)
  println("  ok commit cleans up backup dir")
}

fn main() {
  test_begin_commit()
  test_begin_rollback()
  test_multiple_files()
  test_missing_file_in_paths()
  test_modify_then_commit()
  test_modify_then_rollback()
  test_nested_begin_rollback()
  test_commit_cleans_up()
  println("all fs_tx tests passed")
}
