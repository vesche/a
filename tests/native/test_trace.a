use std.testing
use std.trace

fn main() {
  ; --- Test 1: create tracer ---
  let t = trace.create("test-service")
  testing.assert_eq(t["name"], "test-service")
  testing.assert_eq(to_str(trace.count(t)), "0")
  println("PASS: create tracer")

  ; --- Test 2: begin/end span ---
  let t2 = trace.begin(t, "fetch")
  time.sleep(10)
  let t3 = trace.end(t2, "fetch", #{ "rows": 42 })
  testing.assert_eq(to_str(trace.count(t3)), "2")
  println("PASS: begin/end span")

  ; --- Test 3: instant event ---
  let t4 = trace.event(t3, "cache_hit", #{ "key": "users" })
  testing.assert_eq(to_str(trace.count(t4)), "3")
  println("PASS: instant event")

  ; --- Test 4: counter event ---
  let t5 = trace.counter(t4, "requests", #{ "total": 100 })
  testing.assert_eq(to_str(trace.count(t5)), "4")
  println("PASS: counter event")

  ; --- Test 5: spans extraction ---
  let sp = trace.spans(t5)
  testing.assert_eq(to_str(len(sp)), "1")
  testing.assert_eq(sp[0]["name"], "fetch")
  testing.assert_eq(to_str(sp[0]["data"]["rows"]), "42")
  let dur = sp[0]["duration_ms"]
  testing.assert_eq(to_str(dur >= 0), "true")
  println("PASS: spans extraction")

  ; --- Test 6: find_events ---
  let found = trace.find_events(t5, "cache_hit")
  testing.assert_eq(to_str(len(found)), "1")
  testing.assert_eq(found[0]["data"]["key"], "users")
  println("PASS: find_events")

  ; --- Test 7: duration_ms ---
  let d = trace.duration_ms(t5)
  testing.assert_eq(to_str(d >= 0), "true")
  println("PASS: duration_ms")

  ; --- Test 8: export_json ---
  let j = trace.export_json(t5)
  let parsed = json.parse(j)
  testing.assert_eq(parsed["name"], "test-service")
  testing.assert_eq(to_str(parsed["event_count"]), "4")
  println("PASS: export_json")

  ; --- Test 9: export_chrome ---
  let chrome = trace.export_chrome(t5)
  let events = json.parse(chrome)
  testing.assert_eq(type_of(events), "array")
  ; Should have: B (begin), E (end), i (instant), C (counter) = 4
  testing.assert_eq(to_str(len(events)), "4")
  testing.assert_eq(events[0]["ph"], "B")
  testing.assert_eq(events[0]["name"], "fetch")
  testing.assert_eq(events[1]["ph"], "E")
  testing.assert_eq(events[2]["ph"], "i")
  testing.assert_eq(events[3]["ph"], "C")
  println("PASS: export_chrome format")

  ; --- Test 10: export_otel ---
  let otel = trace.export_otel(t5)
  let odata = json.parse(otel)
  testing.assert_eq(to_str(len(odata["resourceSpans"])), "1")
  testing.assert_eq(odata["resourceSpans"][0]["operationName"], "fetch")
  println("PASS: export_otel format")

  ; --- Test 11: measure helper ---
  let m = trace.measure(t, "work", fn() { ret Ok(42) })
  testing.assert_eq(to_str(trace.count(m["trace"])), "2")
  testing.assert_eq(is_ok(m["result"]), true)
  testing.assert_eq(is_ok(m["result"]), true)
  println("PASS: measure helper (ok)")

  ; --- Test 12: measure with error ---
  let m2 = trace.measure(t, "fail_work", fn() { ret Err("boom") })
  testing.assert_eq(is_err(m2["result"]), true)
  let fail_spans = trace.spans(m2["trace"])
  testing.assert_eq(to_str(len(fail_spans)), "1")
  println("PASS: measure helper (error)")

  ; --- Test 13: nested spans ---
  let tn = trace.begin(t, "outer")
  let tn = trace.begin(tn, "inner")
  let tn = trace.end(tn, "inner", #{})
  let tn = trace.end(tn, "outer", #{})
  let ns = trace.spans(tn)
  testing.assert_eq(to_str(len(ns)), "2")
  testing.assert_eq(ns[0]["name"], "inner")
  testing.assert_eq(ns[1]["name"], "outer")
  println("PASS: nested spans")

  ; --- Test 14: clear ---
  let tc = trace.clear(t5)
  testing.assert_eq(to_str(trace.count(tc)), "0")
  println("PASS: clear")

  println("")
  println("All trace tests passed!")
}
