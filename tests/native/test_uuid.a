fn assert(cond, msg) {
  if !cond { fail(msg) }
}

fn main() {
  let id = uuid.v4()

  ; length must be 36 (8-4-4-4-12 with dashes)
  assert(len(id) == 36, str.concat("uuid length should be 36, got ", to_str(len(id))))

  ; dashes at positions 8, 13, 18, 23
  let chars = str.chars(id)
  assert(chars[8] == "-", "dash at pos 8")
  assert(chars[13] == "-", "dash at pos 13")
  assert(chars[18] == "-", "dash at pos 18")
  assert(chars[23] == "-", "dash at pos 23")

  ; version nibble (position 14) should be '4'
  assert(chars[14] == "4", str.concat("version nibble should be 4, got ", chars[14]))

  ; variant nibble (position 19) should be 8, 9, a, or b
  let v = chars[19]
  assert(v == "8" || v == "9" || v == "a" || v == "b",
    str.concat("variant nibble should be 8/9/a/b, got ", v))

  ; two calls produce different UUIDs
  let id2 = uuid.v4()
  assert(id != id2, "two uuid.v4() calls should differ")

  print("all uuid tests passed")
}
