; tests/native/test_semver.a

use std.semver

fn assert(cond, msg) {
  if !cond { fail("FAIL: " + msg) }
}

fn assert_eq(a, b) {
  if to_str(a) != to_str(b) {
    fail("FAIL: expected " + to_str(b) + ", got " + to_str(a))
  }
}

fn main() {
  ; parse
  let v = semver.parse("1.2.3")
  assert_eq(map.get(v, "major"), 1)
  assert_eq(map.get(v, "minor"), 2)
  assert_eq(map.get(v, "patch"), 3)

  let v2 = semver.parse("v0.10.4")
  assert_eq(map.get(v2, "major"), 0)
  assert_eq(map.get(v2, "minor"), 10)
  assert_eq(map.get(v2, "patch"), 4)

  ; format
  assert_eq(semver.format(v), "1.2.3")

  ; compare
  let a = semver.parse("1.2.3")
  let b = semver.parse("1.3.0")
  let c = semver.parse("1.2.3")
  assert_eq(semver.compare(a, b), -1)
  assert_eq(semver.compare(b, a), 1)
  assert_eq(semver.compare(a, c), 0)

  ; caret
  assert_eq(semver.satisfies("1.2.3", "^1.0"), true)
  assert_eq(semver.satisfies("1.9.9", "^1.0"), true)
  assert_eq(semver.satisfies("2.0.0", "^1.0"), false)
  assert_eq(semver.satisfies("0.9.9", "^1.0"), false)

  ; tilde
  assert_eq(semver.satisfies("1.2.3", "~1.2"), true)
  assert_eq(semver.satisfies("1.2.9", "~1.2"), true)
  assert_eq(semver.satisfies("1.3.0", "~1.2"), false)

  ; comparison operators
  assert_eq(semver.satisfies("2.0.0", ">=1.0.0"), true)
  assert_eq(semver.satisfies("1.0.0", ">=1.0.0"), true)
  assert_eq(semver.satisfies("0.9.0", ">=1.0.0"), false)
  assert_eq(semver.satisfies("1.0.1", ">1.0.0"), true)
  assert_eq(semver.satisfies("1.0.0", ">1.0.0"), false)
  assert_eq(semver.satisfies("0.9.0", "<1.0.0"), true)
  assert_eq(semver.satisfies("1.0.0", "<1.0.0"), false)
  assert_eq(semver.satisfies("1.0.0", "<=1.0.0"), true)
  assert_eq(semver.satisfies("1.0.1", "<=1.0.0"), false)

  ; exact
  assert_eq(semver.satisfies("1.2.3", "1.2.3"), true)
  assert_eq(semver.satisfies("1.2.4", "1.2.3"), false)

  ; best_match
  let versions = ["0.9.0", "1.0.0", "1.2.3", "1.5.0", "2.0.0"]
  assert_eq(semver.best_match(versions, "^1.0"), "1.5.0")
  assert_eq(semver.best_match(versions, "~1.2"), "1.2.3")
  assert_eq(semver.best_match(versions, ">=2.0.0"), "2.0.0")

  println("all semver tests passed")
}
