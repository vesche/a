use std.compiler.cgen
use std.compiler.wasmgen
use std.compiler.parser
use std.compiler.emitter
use std.compiler.checker
use std.compiler.profiler
use std.compiler.optimizer
use std.testgen
use std.path
use std.cli
use std.pkg
use std.plugin

fn _die(msg) {
  eprintln(cli.red(str.concat("error: ", msg)))
  exit(1)
}

fn _find_runtime_dir() -> str {
  let candidates = ["c_runtime", "../c_runtime"]
  for dir in candidates {
    if fs.exists(str.concat(dir, "/runtime.c")) { ret dir }
  }
  ; No local c_runtime/ -- extract from embedded files
  let cache = "/tmp/a_rt"
  if fs.exists(str.concat(cache, "/runtime.c")) { ret cache }
  let probe = embedded_file("c_runtime/runtime.c")
  if type_of(probe) == "void" || len(probe) == 0 {
    _die("cannot find c_runtime/ directory and no embedded runtime available")
  }
  fs.mkdir(cache)
  let rt_files = ["runtime.c", "runtime.h", "sqlite3.c", "sqlite3.h",
                  "miniz.c", "miniz.h", "stb_image.h", "stb_image_write.h", "stb_impl.c"]
  for f in rt_files {
    let content = embedded_file("c_runtime/" + f)
    if type_of(content) != "void" {
      io.write_file(cache + "/" + f, content)
    }
  }
  ; Write a stub embedded.c for sub-compilations
  let stub = "#include " + from_code(34) + "runtime.h" + from_code(34) + from_code(10)
  let stub2 = stub + "AValue a_embedded_file(AValue p)" + from_code(123) + "(void)p;return a_void();" + from_code(125) + from_code(10)
  io.write_file(cache + "/embedded.c", stub2)
  ret cache
}

fn _generate_c(source_path) -> str {
  let mut source = io.read_file(source_path)
  if type_of(source) == "void" || len(source) == 0 {
    _die(str.concat("cannot read file: ", source_path))
  }
  if str.starts_with(source, "#!") {
    let lines = str.lines(source)
    source = str.join(drop(lines, 1), "\n")
  }
  let prog_ast = parser.parse(source)
  if type_of(prog_ast) == "map" && map.has(prog_ast, "tag") {
    if prog_ast["tag"] == "ParseError" {
      _die(str.concat("parse error: ", str.concat(prog_ast["msg"], str.concat(" at token ", to_str(prog_ast["pos"])))))
    }
  }
  let bm = cgen._builtin_map()
  ret cgen.emit_program(prog_ast, bm)
}

fn _gcc_flags() -> str {
  let uname_result = exec("uname -s")
  let os = str.trim(uname_result["stdout"])
  if os == "Darwin" {
    ret "-lm -O2 -Wl,-stack_size,0x10000000 -framework Security -framework CoreFoundation"
  }
  ret "-lm -O2 -ldl"
}

fn _sqlite_flags() -> str {
  ret "-DSQLITE_THREADSAFE=0 -DSQLITE_OMIT_LOAD_EXTENSION"
}

fn _ensure_runtime_objs(runtime_dir) -> str {
  let sentinel = io.read_file(runtime_dir + "/runtime.c")
  if type_of(sentinel) == "void" || len(sentinel) == 0 { ret "" }
  let h = hash.sha256(sentinel)
  let obj_dir = "/tmp/a_obj/" + h
  if fs.exists(obj_dir + "/runtime.o") { ret obj_dir }
  eprintln("precompiling runtime (one-time)...")
  exec("mkdir -p " + obj_dir)
  let inc = "-I " + runtime_dir
  let sf = _sqlite_flags()
  let sources = [
    ["runtime.c", "gcc -c " + runtime_dir + "/runtime.c " + inc + " -O2 " + sf + " -o " + obj_dir + "/runtime.o"],
    ["gguf.c", "gcc -c " + runtime_dir + "/gguf.c " + inc + " -O2 -o " + obj_dir + "/gguf.o"],
    ["sqlite3.c", "gcc -c " + runtime_dir + "/sqlite3.c " + inc + " -O2 " + sf + " -o " + obj_dir + "/sqlite3.o"],
    ["miniz.c", "gcc -c " + runtime_dir + "/miniz.c " + inc + " -O2 -o " + obj_dir + "/miniz.o"],
    ["stb_impl.c", "gcc -c " + runtime_dir + "/stb_impl.c " + inc + " -O2 -o " + obj_dir + "/stb_impl.o"],
    ["embedded.c", "gcc -c " + runtime_dir + "/embedded.c " + inc + " -O2 -o " + obj_dir + "/embedded.o"]
  ]
  for pair in sources {
    let r = exec(pair[1])
    if r["code"] != 0 {
      eprintln(cli.red("failed to precompile " + pair[0]))
      if len(r["stderr"]) > 0 { eprintln(r["stderr"]) }
      exec("rm -rf " + obj_dir)
      ret ""
    }
  }
  ret obj_dir
}

fn _gcc_try(c_path, out_path, runtime_dir) -> int {
  let obj_dir = _ensure_runtime_objs(runtime_dir)
  let inc = "-I " + runtime_dir
  let flags = _gcc_flags()
  let sf = _sqlite_flags()
  if len(obj_dir) > 0 {
    let user_o = _tmp_path(".o")
    let compile = str.join(["gcc -c", c_path, inc, "-O2", sf, "-o", user_o], " ")
    let cr = exec(compile)
    if cr["code"] != 0 {
      fs.rm(user_o)
      ret cr["code"]
    }
    let link = str.join([
      "gcc", user_o,
      obj_dir + "/runtime.o", obj_dir + "/gguf.o", obj_dir + "/sqlite3.o",
      obj_dir + "/miniz.o", obj_dir + "/stb_impl.o",
      obj_dir + "/embedded.o",
      "-o", out_path, flags
    ], " ")
    let lr = exec(link)
    fs.rm(user_o)
    ret lr["code"]
  }
  let cmd = str.join([
    "gcc", c_path,
    runtime_dir + "/runtime.c", runtime_dir + "/gguf.c", runtime_dir + "/sqlite3.c",
    runtime_dir + "/miniz.c", runtime_dir + "/stb_impl.c",
    runtime_dir + "/embedded.c",
    "-o", out_path, inc, flags, sf
  ], " ")
  let result = exec(cmd)
  ret result["code"]
}

fn _gcc(c_path, out_path, runtime_dir) {
  let code = _gcc_try(c_path, out_path, runtime_dir)
  if code != 0 {
    eprintln(cli.red("gcc compilation failed"))
    exit(1)
  }
}

fn _tmp_path(suffix) -> str {
  let ts = to_str(time.now())
  ret str.concat("/tmp/a_cli_", str.concat(ts, suffix))
}

fn cmd_cc(source_path, out_file) {
  let c_code = _generate_c(source_path)
  if len(out_file) > 0 {
    io.write_file(out_file, c_code)
  } else {
    print(c_code)
  }
}

fn cmd_wat(source_path, out_file) {
  let source = io.read_file(source_path)
  let wat_code = wasmgen.compile(source)
  if len(out_file) > 0 {
    io.write_file(out_file, wat_code)
    eprintln(cli.green("generated") + " " + out_file)
  } else {
    print(wat_code)
  }
}

fn _codegen_subprocess(source_path, c_path) {
  let self = argv0()
  let cmd = str.join([self, "cc", source_path, "-o", c_path], " ")
  let mut attempts = 0
  let max_attempts = 5
  while attempts < max_attempts {
    let result = exec(cmd)
    if result["code"] == 0 { ret }
    attempts = attempts + 1
    if attempts == max_attempts {
      eprintln(cli.red(str.concat("codegen failed after ", str.concat(to_str(max_attempts), " attempts"))))
      if len(result["stderr"]) > 0 { eprintln(result["stderr"]) }
      exit(1)
    }
  }
}

fn cmd_build(source_path, out_path) {
  let runtime_dir = _find_runtime_dir()
  let c_path = _tmp_path(".c")
  _codegen_subprocess(source_path, c_path)
  _gcc(c_path, out_path, runtime_dir)
  fs.rm(c_path)
  eprintln(str.concat(cli.green("built"), str.concat(" ", out_path)))
}

; --- Cross-compilation targets ---

fn _known_targets() -> [str] {
  ret ["wasm32-wasi", "linux-x86_64", "linux-aarch64", "windows-x86_64", "macos-x86_64", "macos-aarch64"]
}

fn _target_compiler(tgt) -> str {
  if tgt == "wasm32-wasi" {
    let has_emcc = exec("which emcc 2>/dev/null")
    if has_emcc["code"] == 0 { ret "emcc" }
    let has_clang = exec("which clang 2>/dev/null")
    if has_clang["code"] == 0 { ret "clang" }
    ret ""
  }
  if tgt == "linux-x86_64" {
    let ccs = ["x86_64-linux-musl-gcc", "x86_64-linux-gnu-gcc", "x86_64-unknown-linux-gnu-gcc"]
    for cc in ccs {
      let r = exec("which " + cc + " 2>/dev/null")
      if r["code"] == 0 { ret cc }
    }
    let uname = str.trim(exec("uname -s")["stdout"])
    if uname == "Linux" {
      let arch = str.trim(exec("uname -m")["stdout"])
      if arch == "x86_64" { ret "gcc" }
    }
    ret ""
  }
  if tgt == "linux-aarch64" {
    let ccs = ["aarch64-linux-musl-gcc", "aarch64-linux-gnu-gcc"]
    for cc in ccs {
      let r = exec("which " + cc + " 2>/dev/null")
      if r["code"] == 0 { ret cc }
    }
    let uname = str.trim(exec("uname -s")["stdout"])
    if uname == "Linux" {
      let arch = str.trim(exec("uname -m")["stdout"])
      if arch == "aarch64" { ret "gcc" }
    }
    ret ""
  }
  if tgt == "windows-x86_64" {
    let ccs = ["x86_64-w64-mingw32-gcc", "i686-w64-mingw32-gcc"]
    for cc in ccs {
      let r = exec("which " + cc + " 2>/dev/null")
      if r["code"] == 0 { ret cc }
    }
    ret ""
  }
  if tgt == "macos-x86_64" || tgt == "macos-aarch64" {
    let uname = str.trim(exec("uname -s")["stdout"])
    if uname == "Darwin" { ret "gcc" }
    ret ""
  }
  ret ""
}

fn _target_flags(tgt) -> str {
  if tgt == "wasm32-wasi" {
    ret "-O2 -DWASM_BUILD -DNO_FORK -DNO_SIGNAL -DNO_IMAGE"
  }
  if tgt == "linux-x86_64" {
    ret "-lm -O2 -ldl -DLINUX_BUILD"
  }
  if tgt == "linux-aarch64" {
    ret "-lm -O2 -ldl -DLINUX_BUILD"
  }
  if tgt == "windows-x86_64" {
    ret "-lm -O2 -lws2_32 -DWINDOWS_BUILD"
  }
  if tgt == "macos-x86_64" {
    ret "-lm -O2 -target x86_64-apple-macos11 -framework Security -framework CoreFoundation"
  }
  if tgt == "macos-aarch64" {
    ret "-lm -O2 -target arm64-apple-macos11 -framework Security -framework CoreFoundation"
  }
  ret "-lm -O2"
}

fn _target_ext(tgt) -> str {
  if tgt == "wasm32-wasi" { ret ".wasm" }
  if tgt == "windows-x86_64" { ret ".exe" }
  ret ""
}

fn _target_emcc_flags() -> str {
  ret "-s WASI=1 -s STANDALONE_WASM=1 -s TOTAL_MEMORY=67108864 --no-entry"
}

fn cmd_build_target(source_path, out_path, tgt) {
  let runtime_dir = _find_runtime_dir()
  let c_path = _tmp_path(".c")
  _codegen_subprocess(source_path, c_path)

  let cc = _target_compiler(tgt)
  if len(cc) == 0 {
    fs.rm(c_path)
    _die("no compiler found for target: " + tgt + ". Install the appropriate cross-compilation toolchain.")
  }

  let flags = _target_flags(tgt)
  let sf = _sqlite_flags()
  let inc = "-I " + runtime_dir

  let mut cmd = ""
  if tgt == "wasm32-wasi" && cc == "emcc" {
    let emcc_extra = _target_emcc_flags()
    cmd = str.join([
      cc, c_path,
      runtime_dir + "/runtime.c", runtime_dir + "/gguf.c", runtime_dir + "/sqlite3.c",
      runtime_dir + "/miniz.c",
      runtime_dir + "/embedded.c",
      "-o", out_path, inc, flags, sf, emcc_extra
    ], " ")
  } else {
    if tgt == "wasm32-wasi" && cc == "clang" {
      cmd = str.join([
        cc, "--target=wasm32-wasi", "--sysroot=/opt/wasi-sdk/share/wasi-sysroot",
        c_path,
        runtime_dir + "/runtime.c", runtime_dir + "/gguf.c", runtime_dir + "/sqlite3.c",
        runtime_dir + "/miniz.c",
        runtime_dir + "/embedded.c",
        "-o", out_path, inc, flags, sf
      ], " ")
    } else {
      cmd = str.join([
        cc, c_path,
        runtime_dir + "/runtime.c", runtime_dir + "/gguf.c", runtime_dir + "/sqlite3.c",
        runtime_dir + "/miniz.c", runtime_dir + "/stb_impl.c",
        runtime_dir + "/embedded.c",
        "-o", out_path, inc, flags, sf
      ], " ")
    }
  }

  let r = exec(cmd)
  fs.rm(c_path)
  if r["code"] != 0 {
    if len(r["stderr"]) > 0 { eprintln(r["stderr"]) }
    _die("cross-compilation failed for target: " + tgt)
  }
  eprintln(cli.green("built") + " " + out_path + " (" + tgt + ")")
}

fn cmd_targets() {
  let targets = _known_targets()
  eprintln("supported cross-compilation targets:")
  for tgt in targets {
    let cc = _target_compiler(tgt)
    let mut status = cli.dim("(not available)")
    if len(cc) > 0 {
      status = cli.green("available") + " via " + cc
    }
    eprintln("  " + cli.bold(tgt) + "  " + status)
  }
}

fn _cache_dir() -> str {
  ret ".a_cache"
}

fn _ensure_cache_dir() {
  let dir = _cache_dir()
  if !fs.exists(dir) {
    fs.mkdir(dir)
  }
}

fn _cached_bin(source_path) -> str {
  let source = io.read_file(source_path)
  if type_of(source) == "void" || len(source) == 0 {
    ret ""
  }
  let h = hash.sha256(source)
  let cache_path = str.concat(_cache_dir(), str.concat("/", h))
  if fs.exists(cache_path) {
    ret cache_path
  }
  ret ""
}

fn _store_cache(source_path, bin_path) {
  let source = io.read_file(source_path)
  if type_of(source) == "void" || len(source) == 0 { ret "" }
  _ensure_cache_dir()
  let h = hash.sha256(source)
  let cache_path = str.concat(_cache_dir(), str.concat("/", h))
  fs.cp(bin_path, cache_path)
  exec(str.concat("chmod +x ", cache_path))
  ret ""
}

fn cmd_run(source_path, extra_args) {
  let cached = _cached_bin(source_path)
  if len(cached) > 0 {
    let mut run_cmd = cached
    if len(extra_args) > 0 {
      run_cmd = str.concat(cached, str.concat(" ", str.join(extra_args, " ")))
    }
    let result = exec(run_cmd)
    if len(result["stdout"]) > 0 { print(result["stdout"]) }
    if len(result["stderr"]) > 0 { eprintln(result["stderr"]) }
    if result["code"] != 0 { exit(result["code"]) }
    ret ""
  }

  let runtime_dir = _find_runtime_dir()
  let c_path = _tmp_path(".c")
  let bin_path = _tmp_path("")
  _codegen_subprocess(source_path, c_path)
  _gcc(c_path, bin_path, runtime_dir)
  fs.rm(c_path)

  _store_cache(source_path, bin_path)

  let mut run_cmd = bin_path
  if len(extra_args) > 0 {
    run_cmd = str.concat(bin_path, str.concat(" ", str.join(extra_args, " ")))
  }
  let result = exec(run_cmd)
  if len(result["stdout"]) > 0 { print(result["stdout"]) }
  if len(result["stderr"]) > 0 { eprintln(result["stderr"]) }
  fs.rm(bin_path)
  if result["code"] != 0 { exit(result["code"]) }
}

fn cmd_test(test_dir) {
  let runtime_dir = _find_runtime_dir()
  let self = argv0()
  let entries = fs.ls(test_dir)
  let mut test_files = []
  for entry in entries {
    let name = entry["name"]
    if str.starts_with(name, "test_") && str.ends_with(name, ".a") {
      test_files = push(test_files, path.join(test_dir, name))
    }
  }

  if len(test_files) == 0 {
    eprintln(str.concat("no test_*.a files found in ", test_dir))
    exit(1)
  }

  test_files = sort(test_files)
  let mut passed = 0
  let mut failed = 0

  for src in test_files {
    let name = path.basename(src)
    let c_path = _tmp_path(".c")
    let bin_path = _tmp_path("")

    let c_code = _generate_c(src)
    io.write_file(c_path, c_code)

    let gcc_code = _gcc_try(c_path, bin_path, runtime_dir)
    fs.rm(c_path)

    if gcc_code != 0 {
      println(str.concat("  ", str.concat(cli.red("FAIL"), str.concat(" ", str.concat(name, " (compile error)")))))
      failed = failed + 1
    } else {
      let run_result = exec(bin_path)
      fs.rm(bin_path)
      if run_result["code"] == 0 {
        println(str.concat("  ", str.concat(cli.green("PASS"), str.concat(" ", name))))
        passed = passed + 1
      } else {
        println(str.concat("  ", str.concat(cli.red("FAIL"), str.concat(" ", str.concat(name, str.concat(" (exit ", str.concat(to_str(run_result["code"]), ")")))))))
        if len(run_result["stdout"]) > 0 { println(run_result["stdout"]) }
        failed = failed + 1
      }
    }
  }

  println("")
  println(str.concat(to_str(passed), str.concat(" passed, ", str.concat(to_str(failed), " failed"))))
  if failed > 0 { exit(1) }
}

fn cmd_cache_clean() {
  let dir = _cache_dir()
  if fs.exists(dir) {
    exec(str.concat("rm -rf ", dir))
    eprintln(cli.green("cache cleared"))
  } else {
    eprintln("no cache to clean")
  }
}

fn _profile_insert_fn_hits(c_code, fn_names, fn_hit_map) -> str {
  let nl = from_code(10)
  let lbr = from_code(123)
  let lines = str.split(c_code, nl)
  let mut new_lines = []
  for ln in lines {
    new_lines = push(new_lines, ln)
    let trimmed = str.trim(ln)
    for fn2 in fn_names {
      let mangled = str.replace(str.replace(str.replace(fn2, ".", "_"), "-", "_"), "!", "_bang")
      let sig_start = "AValue fn_" + mangled + "("
      if str.starts_with(trimmed, sig_start) {
        if str.ends_with(trimmed, ") " + lbr) {
          let hit_id = fn_hit_map[fn2]
          new_lines = push(new_lines, "    a_profile_hit(" + to_str(hit_id) + ");")
        }
      }
    }
  }
  ret str.join(new_lines, nl)
}

fn _profile_insert_branch_hits(c_code, n_ifs, n_whiles, n_fors, hit_base) -> str {
  let nl = from_code(10)
  let lbr = from_code(123)
  let src_lines = str.split(c_code, nl)
  let mut new_lines = []
  let mut idx_if = 0
  let mut idx_wh = 0
  let mut idx_fo = 0
  for ln in src_lines {
    new_lines = push(new_lines, ln)
    let trimmed = str.trim(ln)
    if str.starts_with(trimmed, "if (a_truthy(") {
      if str.ends_with(trimmed, ") " + lbr) {
        if idx_if < n_ifs {
          let cid = hit_base + idx_if
          new_lines = push(new_lines, "        a_profile_hit(" + to_str(cid) + ");")
          idx_if = idx_if + 1
        }
      }
    }
    if str.starts_with(trimmed, "while (a_truthy(") {
      if str.ends_with(trimmed, ") " + lbr) {
        let cid = hit_base + n_ifs + idx_wh
        new_lines = push(new_lines, "        a_profile_hit(" + to_str(cid) + ");")
        idx_wh = idx_wh + 1
      }
    }
    if str.starts_with(trimmed, "for (int __fi") {
      let cid = hit_base + n_ifs + n_whiles + idx_fo
      new_lines = push(new_lines, "            a_profile_hit(" + to_str(cid) + ");")
      idx_fo = idx_fo + 1
    }
  }
  ret str.join(new_lines, nl)
}

fn _profile_count_branches(stmts, counts) -> map {
  for st in stmts {
    let tag = st["tag"]
    if tag == "If" {
      counts = map.set(counts, "ifs", counts["ifs"] + 1)
      let then_stmts = st["then"]["stmts"]
      counts = _profile_count_branches(then_stmts, counts)
      let else_br = st["else"]
      if type_of(else_br) != "void" {
        if else_br["tag"] == "ElseBlock" {
          counts = map.set(counts, "elses", counts["elses"] + 1)
          counts = _profile_count_branches(else_br["block"]["stmts"], counts)
        }
        if else_br["tag"] == "ElseIf" {
          counts = _profile_count_branches([else_br["stmt"]], counts)
        }
      }
    }
    if tag == "While" {
      counts = map.set(counts, "whiles", counts["whiles"] + 1)
      counts = _profile_count_branches(st["body"]["stmts"], counts)
    }
    if tag == "For" || tag == "ForDestructure" {
      counts = map.set(counts, "fors", counts["fors"] + 1)
      counts = _profile_count_branches(st["body"]["stmts"], counts)
    }
  }
  ret counts
}

fn cmd_profile(source_path, profile_out) {
  let runtime_dir = _find_runtime_dir()
  let prof_out = profile_out
  if len(prof_out) == 0 {
    prof_out = "profile.json"
  }

  let source = io.read_file(source_path)
  if type_of(source) == "void" || len(source) == 0 {
    _die("profiler: could not read source file")
  }
  let prog = _parse_source(source_path)
  let items = prog["items"]

  let mut fn_names = []
  for item in items {
    if item["tag"] == "FnDecl" {
      fn_names = push(fn_names, item["name"])
    }
  }

  let mut branch_counts = #{ "ifs": 0, "elses": 0, "whiles": 0, "fors": 0 }
  for item2 in items {
    if item2["tag"] == "FnDecl" {
      let body = item2["body"]
      if type_of(body) == "map" {
        if map.has(body, "stmts") {
          branch_counts = _profile_count_branches(body["stmts"], branch_counts)
        }
      }
    }
  }

  let base_c = _generate_c(source_path)
  let nl = from_code(10)
  let q = from_code(34)
  let mut counter_id = 0
  let mut reg_lines = ""
  let mut fn_hit_map = #{}
  for fname in fn_names {
    reg_lines = reg_lines + "    a_profile_register(" + q + "fn:" + fname + q + ");" + nl
    fn_hit_map = map.set(fn_hit_map, fname, counter_id)
    counter_id = counter_id + 1
  }

  let mut c_code = _profile_insert_fn_hits(base_c, fn_names, fn_hit_map)

  let n_ifs = branch_counts["ifs"]
  let n_whiles = branch_counts["whiles"]
  let n_fors = branch_counts["fors"]

  let mut bi = 0
  while bi < n_ifs {
    reg_lines = reg_lines + "    a_profile_register(" + q + "if:" + to_str(bi) + q + ");" + nl
    counter_id = counter_id + 1
    bi = bi + 1
  }
  bi = 0
  while bi < n_whiles {
    reg_lines = reg_lines + "    a_profile_register(" + q + "while:" + to_str(bi) + q + ");" + nl
    counter_id = counter_id + 1
    bi = bi + 1
  }
  bi = 0
  while bi < n_fors {
    reg_lines = reg_lines + "    a_profile_register(" + q + "for:" + to_str(bi) + q + ");" + nl
    counter_id = counter_id + 1
    bi = bi + 1
  }

  let hit_base = len(fn_names)
  c_code = _profile_insert_branch_hits(c_code, n_ifs, n_whiles, n_fors, hit_base)

  let old_main = "g_argc = argc; g_argv = argv;"
  let new_main = "g_argc = argc; g_argv = argv;" + nl + "    a_profile_init();" + nl + reg_lines
  c_code = str.replace(c_code, old_main, new_main)

  let old_end = "fn_main();" + nl + "    return 0;"
  let new_end = "fn_main();" + nl + "    a_profile_dump_json(a_string(" + q + prof_out + q + "));" + nl + "    return 0;"
  c_code = str.replace(c_code, old_end, new_end)

  let c_path = _tmp_path("_prof.c")
  io.write_file(c_path, c_code)
  let bin_path = _tmp_path("_prof_bin")
  _ensure_runtime_objs(runtime_dir)
  let gcc_code = _gcc_try(c_path, bin_path, runtime_dir)
  fs.rm(c_path)
  if gcc_code != 0 {
    _die("profiler: gcc compilation failed")
  }

  eprintln("running instrumented binary...")
  let run_result = exec(bin_path)
  fs.rm(bin_path)

  if fs.exists(prof_out) {
    eprintln(cli.green("profile written to " + prof_out))
    let report = optimizer.analyze_profile(prof_out)
    if !map.has(report, "error") {
      eprintln("  total instrumentation points: " + to_str(report["total_points"]))
      eprintln("  total hits: " + to_str(report["total_hits"]))
      let hf = report["hot_functions"]
      if len(hf) > 0 {
        eprintln("  hot functions:")
        for hfn in hf {
          eprintln("    " + hfn["name"] + ": " + to_str(hfn["count"]) + " calls (" + to_str(hfn["hot_ratio"]) + "% of max)")
        }
      }
    }
  } else {
    eprintln(cli.red("profile file not generated"))
  }
}

fn cmd_gentests(source_path, out_path) {
  let tests_str = testgen.gen_tests_for_file(source_path)
  if len(out_path) > 0 {
    io.write_file(out_path, tests_str)
    eprintln(cli.green("tests written to " + out_path))
  } else {
    print(tests_str)
  }
}

fn cmd_optimize_report(source_path, profile_path) {
  let source = io.read_file(source_path)
  let report = optimizer.analyze_profile(profile_path)
  if map.has(report, "error") {
    _die("optimizer: " + report["error"])
  }

  let suggs = optimizer.suggest(source, report)
  eprintln("=== Optimization Report ===")
  eprintln("")
  eprintln("Total instrumentation points: " + to_str(report["total_points"]))
  eprintln("Total hits: " + to_str(report["total_hits"]))
  eprintln("")

  let hf = report["hot_functions"]
  eprintln("Hot Functions (" + to_str(len(hf)) + "):")
  for f in hf {
    eprintln("  " + f["name"] + ": " + to_str(f["count"]) + " calls (" + to_str(f["hot_ratio"]) + "% of max)")
  }
  eprintln("")

  eprintln("Suggestions (" + to_str(len(suggs)) + "):")
  for sg in suggs {
    eprintln("  [" + sg["priority"] + "] " + sg["type"] + " -- " + sg["reason"])
  }
}

fn cmd_eval(expr, extra_args) {
  let wrapped = str.concat("fn main() \{\n  println(", str.concat(expr, ")\n\}"))
  let tmp = _tmp_path("_eval.a")
  io.write_file(tmp, wrapped)
  cmd_run(tmp, extra_args)
  fs.rm(tmp)
}

fn cmd_lsp() {
  let runtime_dir = _find_runtime_dir()
  let lsp_source = "src/lsp.a"
  if !fs.exists(lsp_source) {
    _die("cannot find src/lsp.a -- run from the project root")
  }
  cmd_build(lsp_source, "a-lsp")
  eprintln("configure your editor to run ./a-lsp as the language server for *.a files")
}

fn _parse_source(source_path) -> map {
  let source = io.read_file(source_path)
  if type_of(source) == "void" || len(source) == 0 {
    _die("cannot read file: " + source_path)
  }
  let ast = parser.parse(source)
  if type_of(ast) == "map" && map.has(ast, "tag") {
    if ast["tag"] == "ParseError" {
      _die("parse error: " + ast["msg"] + " at token " + to_str(ast["pos"]))
    }
  }
  ret ast
}

fn _fmt_file(file_path: str) {
  let ast = _parse_source(file_path)
  let formatted = emitter.emit(ast)
  io.write_file(file_path, formatted)
}

fn _is_dir(p: str) -> bool {
  if !fs.exists(p) { ret false }
  if str.ends_with(p, ".a") { ret false }
  let result = exec("test -d " + p + " && echo yes || echo no")
  ret str.trim(result["stdout"]) == "yes"
}

fn _fmt_dir(target: str) {
  let entries = fs.ls(target)
  let mut i = 0
  while i < len(entries) {
    let name = map.get(entries[i], "name")
    let full = path.join(target, name)
    if map.get(entries[i], "is_dir") {
      _fmt_dir(full)
    } else {
      if str.ends_with(name, ".a") {
        _fmt_file(full)
      }
    }
    i = i + 1
  }
}

fn cmd_fmt(target: str) {
  if _is_dir(target) {
    _fmt_dir(target)
    println(cli.green("formatted") + " " + target)
    ret
  }
  if str.ends_with(target, ".a") && fs.exists(target) {
    _fmt_file(target)
    println(cli.green("formatted") + " " + target)
  } else {
    _die("expected a .a file or directory: " + target)
  }
}

fn cmd_ast(source_path: str) {
  let ast = _parse_source(source_path)
  println(json.pretty(ast))
}

fn cmd_check(source_path: str) {
  let ast = _parse_source(source_path)
  let diagnostics = checker.check(ast)
  if len(diagnostics) == 0 {
    println(cli.green("no issues found"))
    ret
  }
  let mut errors = 0
  let mut warnings = 0
  let mut i = 0
  while i < len(diagnostics) {
    let d = diagnostics[i]
    let sev = map.get(d, "severity")
    let line = map.get(d, "line")
    let msg = map.get(d, "msg")
    if sev == "error" {
      eprintln(cli.red("error") + " (line " + to_str(line) + "): " + msg)
      errors = errors + 1
    } else {
      eprintln(cli.yellow("warning") + " (line " + to_str(line) + "): " + msg)
      warnings = warnings + 1
    }
    i = i + 1
  }
  println("")
  println(to_str(errors) + " error(s), " + to_str(warnings) + " warning(s)")
  if errors > 0 { exit(1) }
}

fn _repl_build_source(fns, bindings, expr: str) -> str {
  let lb = from_code(123)
  let rb = from_code(125)
  let mut src = ""
  let mut i = 0
  while i < len(fns) {
    src = src + fns[i] + "\n"
    i = i + 1
  }
  src = src + "fn main() " + lb + "\n"
  i = 0
  while i < len(bindings) {
    src = src + "  " + bindings[i] + "\n"
    i = i + 1
  }
  if len(expr) > 0 {
    src = src + "  " + expr + "\n"
  }
  src = src + rb + "\n"
  ret src
}

fn cmd_repl() {
  let runtime_dir = _find_runtime_dir()
  let mut bindings = []
  let mut fns = []
  let mut line_buf = ""
  let mut brace_depth = 0
  println("a repl -- type :quit to exit, :clear to reset")
  while true {
    if brace_depth > 0 {
      print(".. ")
    } else {
      print("a> ")
    }
    io.flush()
    let line = io.read_line()
    if type_of(line) == "void" { break }
    let trimmed = str.trim(line)

    if brace_depth == 0 {
      if trimmed == ":quit" || trimmed == ":q" { break }
      if trimmed == ":clear" {
        bindings = []
        fns = []
        println("state cleared")
        continue
      }
      if trimmed == ":bindings" {
        let mut bi = 0
        while bi < len(bindings) {
          println("  " + bindings[bi])
          bi = bi + 1
        }
        continue
      }
      if len(trimmed) == 0 { continue }
    }

    line_buf = line_buf + line + "\n"
    let chars = str.chars(trimmed)
    let mut ci = 0
    while ci < len(chars) {
      let ch = chars[ci]
      if ch == from_code(123) { brace_depth = brace_depth + 1 }
      if ch == from_code(125) { brace_depth = brace_depth - 1 }
      ci = ci + 1
    }

    if brace_depth > 0 { continue }

    let input = str.trim(line_buf)
    line_buf = ""

    if str.starts_with(input, "fn ") {
      fns = push(fns, input)
      continue
    }

    if str.starts_with(input, "let ") {
      let src = _repl_build_source(fns, push(bindings, input), "")
      let tmp = _tmp_path("_repl.a")
      io.write_file(tmp, src)
      let c_path = _tmp_path("_repl.c")
      let bin_path = _tmp_path("_repl")
      _codegen_subprocess(tmp, c_path)
      let gcc_code = _gcc_try(c_path, bin_path, runtime_dir)
      fs.rm(tmp)
      fs.rm(c_path)
      if gcc_code != 0 {
        eprintln(cli.red("error: ") + "invalid binding")
      } else {
        fs.rm(bin_path)
        bindings = push(bindings, input)
      }
      continue
    }

    let expr_line = "println(to_str(" + input + "))"
    let src = _repl_build_source(fns, bindings, expr_line)
    let tmp = _tmp_path("_repl.a")
    io.write_file(tmp, src)
    let c_path = _tmp_path("_repl.c")
    let bin_path = _tmp_path("_repl")
    _codegen_subprocess(tmp, c_path)
    let gcc_code = _gcc_try(c_path, bin_path, runtime_dir)
    fs.rm(tmp)
    fs.rm(c_path)
    if gcc_code != 0 {
      eprintln(cli.red("error: ") + "cannot evaluate expression")
    } else {
      let result = exec(bin_path)
      fs.rm(bin_path)
      if len(result["stdout"]) > 0 { print(result["stdout"]) }
      if result["code"] != 0 {
        eprintln(cli.red("runtime error") + " (exit " + to_str(result["code"]) + ")")
      }
    }
  }
}

fn cmd_pkg_init() {
  let dir = fs.cwd()
  pkg.init(dir)
  println("created pkg.toml in " + dir)
}

fn cmd_pkg_add(name: str, source: str) {
  let dir = fs.cwd()
  pkg.add_dep(dir, name, source)
}

fn cmd_pkg_install() {
  let dir = fs.cwd()
  let result = pkg.install(dir)
  println("done (" + to_str(map.get(result, "installed")) + " packages installed)")
}

fn _collect_watch_files(source_path) -> [str] {
  let mut files = [source_path]
  let source = io.read_file(source_path)
  if type_of(source) == "void" { ret files }
  let lines = str.lines(source)
  for line in lines {
    let trimmed = str.trim(line)
    if str.starts_with(trimmed, "use ") {
      let mod_path = str.trim(str.slice(trimmed, 4, len(trimmed)))
      let parts = str.split(mod_path, ".")
      let file = str.join(parts, "/") + ".a"
      if fs.exists(file) {
        files = push(files, file)
      }
    }
  }
  ret files
}

fn _get_mtimes(files) -> [int] {
  let mut mtimes = []
  for f in files {
    let s = fs.stat(f)
    if type_of(s) == "map" {
      mtimes = push(mtimes, s["mtime"])
    } else {
      mtimes = push(mtimes, 0)
    }
  }
  ret mtimes
}

fn _mtimes_changed(old_mt, new_mt) -> bool {
  if len(old_mt) != len(new_mt) { ret true }
  let mut i = 0
  while i < len(old_mt) {
    if old_mt[i] != new_mt[i] { ret true }
    i = i + 1
  }
  ret false
}

fn cmd_watch(source_path) {
  if !fs.exists(source_path) {
    _die("watch: file not found: " + source_path)
  }
  let self = argv0()
  let mut files = _collect_watch_files(source_path)
  let mut mtimes = _get_mtimes(files)

  eprintln(cli.dim("[watch] watching " + to_str(len(files)) + " file(s), press Ctrl+C to stop"))

  let r = exec(self + " run " + source_path)
  if len(r["stdout"]) > 0 { print(r["stdout"]) }
  if len(r["stderr"]) > 0 { eprintln(r["stderr"]) }
  io.flush()

  ; Poll for changes and re-run
  while true {
    time.sleep(500)
    let new_files = _collect_watch_files(source_path)
    let new_mtimes = _get_mtimes(new_files)

    if _mtimes_changed(mtimes, new_mtimes) || len(new_files) != len(files) {
      eprintln(cli.dim("[watch] change detected, restarting..."))
      files = new_files
      mtimes = _get_mtimes(files)
      let result = exec(self + " run " + source_path)
      if len(result["stdout"]) > 0 { print(result["stdout"]) }
      if len(result["stderr"]) > 0 { eprintln(result["stderr"]) }
      io.flush()
    }
  }
}

fn cmd_spawn(source, agent_name) {
  if !fs.exists(source) {
    _die("spawn: file not found: " + source)
  }
  let self = argv0()
  let bin_name = ".a_cache/agent_" + agent_name
  let build_result = exec(self + " build " + source + " -o " + bin_name)
  if build_result["code"] != 0 {
    eprintln(build_result["stderr"])
    _die("spawn: build failed")
  }

  ; Ensure registry directory exists
  if !fs.exists("/tmp/a_agents") {
    fs.mkdir("/tmp/a_agents")
  }

  ; Launch in background with agent name in environment
  let run_cmd = "A_AGENT_NAME=" + agent_name + " " + bin_name + " &"
  let r = exec(run_cmd)

  eprintln(cli.green("[spawn]") + " launched agent " + cli.bold(agent_name) + " from " + source)
}

fn _agent_log(name, msg) {
  eprintln(cli.dim("[agent]") + " " + cli.bold(name) + " " + msg)
}

fn cmd_agent(source, agent_name, health_port, max_restarts, no_restart) {
  if !fs.exists(source) {
    _die("agent: file not found: " + source)
  }
  let self = argv0()

  ; Ensure cache and registry dirs exist
  if !fs.exists(".a_cache") { fs.mkdir(".a_cache") }
  if !fs.exists("/tmp/a_agents") { fs.mkdir("/tmp/a_agents") }

  ; Build the agent binary
  let bin = ".a_cache/agent_" + agent_name
  let build_r = exec(self + " build " + source + " -o " + bin)
  if build_r["code"] != 0 {
    if len(build_r["stderr"]) > 0 { eprintln(build_r["stderr"]) }
    _die("agent: build failed")
  }

  ; Write PID file for the supervisor
  let pid_file = "/tmp/a_agents/" + agent_name + ".pid"
  io.write_file(pid_file, to_str(reflect.pid()))

  _agent_log(agent_name, "supervisor started (pid " + to_str(reflect.pid()) + ")")

  let mut restarts = 0
  let mut running = true

  while running {
    let start_time = time.now()
    _agent_log(agent_name, "starting agent process")

    let mut env_prefix = "A_AGENT_NAME=" + agent_name + " A_COMPILER=" + self
    if health_port > 0 {
      env_prefix = env_prefix + " A_AGENT_PORT=" + to_str(health_port)
    }

    let result = exec(env_prefix + " " + bin)

    ; Forward captured output
    if len(result["stdout"]) > 0 { print(result["stdout"]) }
    if len(result["stderr"]) > 0 { eprintln(result["stderr"]) }

    let code = result["code"]
    let uptime = time.now() - start_time

    if code == 42 {
      ; Exit code 42 = self-update requested: rebuild and restart immediately
      _agent_log(agent_name, "update requested, rebuilding...")
      let rebuild = exec(self + " build " + source + " -o " + bin)
      if rebuild["code"] != 0 {
        _agent_log(agent_name, "rebuild failed, restarting with old binary")
      } else {
        _agent_log(agent_name, "rebuild succeeded")
      }
      restarts = 0
    } else if code == 0 || no_restart {
      _agent_log(agent_name, "exited (code " + to_str(code) + "), stopping")
      running = false
    } else {
      _agent_log(agent_name, "crashed (exit " + to_str(code) + ", uptime " + to_str(uptime / 1000) + "s)")

      ; Reset restart count if the agent ran healthily for >60s
      if uptime > 60000 {
        restarts = 0
      }

      restarts = restarts + 1
      if max_restarts > 0 && restarts >= max_restarts {
        _agent_log(agent_name, "max restarts (" + to_str(max_restarts) + ") reached, giving up")
        running = false
      } else {
        ; Exponential backoff: 1s, 2s, 4s, ..., capped at 30s
        let mut backoff = 1000
        let mut e = 0
        while e < restarts - 1 {
          backoff = backoff * 2
          e = e + 1
        }
        if backoff > 30000 { backoff = 30000 }
        _agent_log(agent_name, "restarting in " + to_str(backoff / 1000) + "s (attempt " + to_str(restarts) + ")")
        time.sleep(backoff)
      }
    }
  }

  ; Cleanup
  if fs.exists(pid_file) { fs.rm(pid_file) }
  _agent_log(agent_name, "supervisor stopped")
}

fn cmd_plugin(argv) {
  if len(argv) < 1 { _die("usage: a plugin <install|list|remove|init|run>") }
  let sub = argv[0]

  if sub == "install" {
    if len(argv) < 2 { _die("usage: a plugin install <dir|git:user/repo>") }
    let source = argv[1]
    let mut result = Err("unknown")
    if str.starts_with(source, "git:") || str.starts_with(source, "github:") {
      let repo = str.replace(str.replace(source, "git:", ""), "github:", "")
      result = plugin.install_git(repo)
    } else {
      result = plugin.install(source)
    }
    if is_ok(result) {
      let info = unwrap(result)
      eprintln(cli.green("[plugin]") + " installed " + cli.bold(info["name"]) + " v" + info["version"])
    } else {
      _die(unwrap_or(result, "install failed"))
    }
    ret
  }

  if sub == "list" {
    let plugins = plugin.list()
    if len(plugins) == 0 {
      eprintln("no plugins installed")
      ret
    }
    let mut i = 0
    while i < len(plugins) {
      let p = plugins[i]
      eprintln("  " + cli.bold(p["name"]) + " v" + p["version"] + "  " + cli.dim(p["dir"]))
      i = i + 1
    }
    ret
  }

  if sub == "remove" {
    if len(argv) < 2 { _die("usage: a plugin remove <name>") }
    let result = plugin.remove(argv[1])
    if is_ok(result) {
      eprintln(cli.green("[plugin]") + " removed " + cli.bold(argv[1]))
    } else {
      _die(unwrap_or(result, "remove failed"))
    }
    ret
  }

  if sub == "init" {
    if len(argv) < 3 { _die("usage: a plugin init <dir> <name>") }
    let result = plugin.init(argv[1], argv[2])
    if is_ok(result) {
      eprintln(cli.green("[plugin]") + " created plugin scaffold at " + argv[1])
    } else {
      _die("plugin init failed")
    }
    ret
  }

  if sub == "run" {
    if len(argv) < 2 { _die("usage: a plugin run <name>") }
    let result = plugin.run(argv[1])
    if is_ok(result) {
      let r = unwrap(result)
      if len(r["stdout"]) > 0 { print(r["stdout"]) }
      if r["code"] != 0 { exit(r["code"]) }
    } else {
      _die(unwrap_or(result, "plugin run failed"))
    }
    ret
  }

  _die("usage: a plugin <install|list|remove|init|run>")
}

fn _usage() {
  eprintln("a -- the a language native toolchain")
  eprintln("")
  eprintln("usage:")
  eprintln("  a run <file.a> [args...]    compile and run (cached)")
  eprintln("  a build <file.a> [-o out]   compile to native binary")
  eprintln("  a build <file.a> --target T cross-compile (wasm32-wasi, linux-x86_64, ...)")
  eprintln("  a targets                  list available cross-compilation targets")
  eprintln("  a eval <expr>              evaluate an expression")
  eprintln("  a repl                     interactive read-eval-print loop")
  eprintln("  a cc <file.a>              emit C to stdout")
  eprintln("  a wat <file.a>             emit WebAssembly Text Format to stdout")
  eprintln("  a fmt <file.a|dir/>        format source code")
  eprintln("  a ast <file.a>             dump parsed AST as JSON")
  eprintln("  a check <file.a>           type-check source file")
  eprintln("  a test <dir/>              run test_*.a files in directory")
  eprintln("  a lsp                      start language server (JSON-RPC over stdio)")
  eprintln("  a watch <file.a>           recompile and run on file change")
  eprintln("  a agent <file.a> [opts]     deploy supervised long-running agent")
  eprintln("     --name N                  agent name (default: filename)")
  eprintln("     --max-restarts N          max restart attempts (default: 10, 0=unlimited)")
  eprintln("     --no-restart              run once, exit on child exit")
  eprintln("  a spawn <file.a> --name N  launch named agent process (background)")
  eprintln("  a plugin install <dir>     install a plugin from directory")
  eprintln("  a plugin list              list installed plugins")
  eprintln("  a plugin remove <name>     uninstall a plugin")
  eprintln("  a plugin init <dir> <name> scaffold a new plugin")
  eprintln("  a plugin run <name>        run an installed plugin")
  eprintln("  a profile <file.a> [-o p]   profile-guided: instrument, run, dump JSON")
  eprintln("  a gentests <file.a> [-o f]  auto-generate tests from source analysis")
  eprintln("  a optimize <file.a> <prof>  optimization report from profile data")
  eprintln("  a cache clean              clear the compilation cache")
  eprintln("  a pkg init                 create pkg.toml in current directory")
  eprintln("  a pkg add <name> <source>  add a dependency")
  eprintln("  a pkg install              install all dependencies")
  eprintln("")
  eprintln("  a run and a build expect c_runtime/ in the current directory.")
  eprintln("  shebang: #!/usr/bin/env a run")
}

fn main() {
  let argv = args()
  if len(argv) == 0 {
    _usage()
    exit(1)
  }

  let subcmd = argv[0]

  if subcmd == "cc" {
    if len(argv) < 2 { _die("cc requires a source file") }
    let mut cc_out = ""
    if len(argv) >= 4 && argv[2] == "-o" {
      cc_out = argv[3]
    }
    cmd_cc(argv[1], cc_out)
    ret
  }

  if subcmd == "wat" {
    if len(argv) < 2 { _die("wat requires a source file") }
    let mut wat_out = ""
    if len(argv) >= 4 && argv[2] == "-o" {
      wat_out = argv[3]
    }
    cmd_wat(argv[1], wat_out)
    ret
  }

  if subcmd == "build" {
    if len(argv) < 2 { _die("build requires a source file") }
    let source = argv[1]
    let mut out = path.stem(source)
    let mut tgt = ""
    let mut i = 2
    while i < len(argv) {
      if argv[i] == "-o" && i + 1 < len(argv) {
        out = argv[i + 1]
        i = i + 2
      } else {
        if argv[i] == "--target" && i + 1 < len(argv) {
          tgt = argv[i + 1]
          i = i + 2
        } else {
          i = i + 1
        }
      }
    }
    if len(tgt) > 0 {
      let ext = _target_ext(tgt)
      if len(ext) > 0 && !str.ends_with(out, ext) {
        out = out + ext
      }
      cmd_build_target(source, out, tgt)
    } else {
      cmd_build(source, out)
    }
    ret
  }

  if subcmd == "targets" {
    cmd_targets()
    ret
  }

  if subcmd == "run" {
    if len(argv) < 2 { _die("run requires a source file") }
    let source = argv[1]
    let mut extra = []
    if len(argv) > 2 {
      let mut i = 2
      while i < len(argv) {
        extra = push(extra, argv[i])
        i = i + 1
      }
    }
    cmd_run(source, extra)
    ret
  }

  if subcmd == "test" {
    if len(argv) < 2 { _die("test requires a directory") }
    cmd_test(argv[1])
    ret
  }

  if subcmd == "eval" {
    if len(argv) < 2 { _die("eval requires an expression") }
    let mut extra = []
    if len(argv) > 2 {
      let mut i = 2
      while i < len(argv) {
        extra = push(extra, argv[i])
        i = i + 1
      }
    }
    cmd_eval(argv[1], extra)
    ret
  }

  if subcmd == "fmt" {
    if len(argv) < 2 { _die("fmt requires a file or directory") }
    cmd_fmt(argv[1])
    ret
  }

  if subcmd == "ast" {
    if len(argv) < 2 { _die("ast requires a source file") }
    cmd_ast(argv[1])
    ret
  }

  if subcmd == "check" {
    if len(argv) < 2 { _die("check requires a source file") }
    cmd_check(argv[1])
    ret
  }

  if subcmd == "repl" {
    cmd_repl()
    ret
  }

  if subcmd == "plugin" {
    let mut plugin_argv = []
    let mut i = 1
    while i < len(argv) {
      plugin_argv = push(plugin_argv, argv[i])
      i = i + 1
    }
    cmd_plugin(plugin_argv)
    ret
  }

  if subcmd == "pkg" {
    if len(argv) < 2 { _die("usage: a pkg <init|add|install>") }
    if argv[1] == "init" {
      cmd_pkg_init()
      ret
    }
    if argv[1] == "add" {
      if len(argv) < 4 { _die("usage: a pkg add <name> <source>") }
      cmd_pkg_add(argv[2], argv[3])
      ret
    }
    if argv[1] == "install" {
      cmd_pkg_install()
      ret
    }
    _die("usage: a pkg <init|add|install>")
    ret
  }

  if subcmd == "cache" {
    if len(argv) >= 2 && argv[1] == "clean" {
      cmd_cache_clean()
      ret
    }
    _die("usage: a cache clean")
    ret
  }

  if subcmd == "watch" {
    if len(argv) < 2 { _die("watch requires a source file") }
    cmd_watch(argv[1])
    ret
  }

  if subcmd == "agent" {
    if len(argv) < 2 { _die("agent requires a source file") }
    let source = argv[1]
    let mut agent_name = path.stem(source)
    let mut health_port = 0
    let mut max_restarts = 10
    let mut no_restart = false
    let mut i = 2
    while i < len(argv) {
      if argv[i] == "--name" && i + 1 < len(argv) {
        agent_name = argv[i + 1]
        i = i + 2
      } else if argv[i] == "--health-port" && i + 1 < len(argv) {
        health_port = int(argv[i + 1])
        i = i + 2
      } else if argv[i] == "--max-restarts" && i + 1 < len(argv) {
        max_restarts = int(argv[i + 1])
        i = i + 2
      } else if argv[i] == "--no-restart" {
        no_restart = true
        i = i + 1
      } else {
        i = i + 1
      }
    }
    cmd_agent(source, agent_name, health_port, max_restarts, no_restart)
    ret
  }

  if subcmd == "spawn" {
    if len(argv) < 2 { _die("spawn requires a source file") }
    let source = argv[1]
    let mut agent_name = path.stem(source)
    let mut i = 2
    while i < len(argv) {
      if argv[i] == "--name" && i + 1 < len(argv) {
        agent_name = argv[i + 1]
        i = i + 2
      } else {
        i = i + 1
      }
    }
    cmd_spawn(source, agent_name)
    ret
  }

  if subcmd == "lsp" {
    cmd_lsp()
    ret
  }

  if subcmd == "profile" {
    if len(argv) < 2 {
      _die("profile requires a source file")
    }
    let source = argv[1]
    let mut prof_out = ""
    let mut i = 2
    while i < len(argv) {
      if argv[i] == "-o" && i + 1 < len(argv) {
        prof_out = argv[i + 1]
        i = i + 2
      } else {
        i = i + 1
      }
    }
    cmd_profile(source, prof_out)
    ret
  }

  if subcmd == "gentests" {
    if len(argv) < 2 {
      _die("gentests requires a source file")
    }
    let source = argv[1]
    let mut test_out = ""
    let mut i = 2
    while i < len(argv) {
      if argv[i] == "-o" && i + 1 < len(argv) {
        test_out = argv[i + 1]
        i = i + 2
      } else {
        i = i + 1
      }
    }
    cmd_gentests(source, test_out)
    ret
  }

  if subcmd == "optimize" {
    if len(argv) < 3 {
      _die("optimize requires a source file and profile path")
    }
    cmd_optimize_report(argv[1], argv[2])
    ret
  }

  _die(str.concat("unknown command: ", subcmd))
}
