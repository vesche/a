fn _all_builtin_names() {
  let sigs = _builtin_signatures()
  let ns_sigs = _builtin_ns_signatures()
  ret concat_arr(map.keys(sigs), map.keys(ns_sigs))
}

fn _lookup_signature(name, builtin_sigs, ns_sigs) {
  if map.has(builtin_sigs, name) { ret builtin_sigs[name] }
  if map.has(ns_sigs, name) { ret ns_sigs[name] }
  ret ""
}

; --- Keyword list ---

fn _keywords() {
  ret [
    "fn", "let", "mut", "if", "else", "for", "in", "while",
    "match", "ret", "use", "try", "catch", "extern", "true", "false",
    "break", "continue", "ty", "mod", "pub", "effects", "pre", "post", "where"
  ]
}

; --- Stdlib module names ---

fn _stdlib_modules() {
  ret [
    "std.cli", "std.path", "std.math", "std.strings", "std.hash",
    "std.datetime", "std.re", "std.encoding", "std.csv", "std.testing",
    "std.template", "std.meta", "std.compiler.lexer", "std.compiler.parser",
    "std.compiler.ast", "std.compiler.cgen", "std.compiler.emitter",
    "std.compiler.compiler", "std.compiler.serialize",
    "std.yaml", "std.toml", "std.html", "std.url",
    "std.llm"
  ]
}

; --- LSP request handlers ---

fn _handle_initialize(id) {
  let capabilities = #{
    "textDocumentSync": 1,
    "completionProvider": #{"triggerCharacters": [".", ":"]},
    "hoverProvider": true,
    "definitionProvider": true
  }
  let result = #{
    "capabilities": capabilities,
    "serverInfo": #{"name": "a-lsp", "version": "0.50.0"}
  }
  _respond(id, result)
}

fn _collect_errors(node, errors) {
  if type_of(node) != "map" { ret errors }
  let mut errs = errors
  if map.has(node, "tag") && node["tag"] == "ParseError" {
    errs = push(errs, node)
    ret errs
  }
  let keys = map.keys(node)
  let mut i = 0
  while i < len(keys) {
    let k = keys[i]
    let v = node[k]
    if type_of(v) == "map" {
      errs = _collect_errors(v, errs)
    }
    if type_of(v) == "array" {
      let mut j = 0
      while j < len(v) {
        errs = _collect_errors(v[j], errs)
        j = j + 1
      }
    }
    i = i + 1
  }
  ret errs
}

fn _make_diag(msg, lc) {
  let pos = #{"line": lc["line"], "character": lc["character"]}
  let end_pos = #{"line": lc["line"], "character": lc["character"] + 1}
  ret #{
    "range": #{"start": pos, "end": end_pos},
    "severity": 1,
    "source": "a-lsp",
    "message": msg
  }
}

fn _publish_diagnostics(uri, content, docs) {
  let ast = _parse_doc(content)
  let errors = _collect_errors(ast, [])
  let mut diags = []
  let mut i = 0
  while i < len(errors) {
    let err = errors[i]
    let lc = _token_pos_to_lc(content, err["pos"])
    diags = push(diags, _make_diag(err["msg"], lc))
    i = i + 1
  }
  _notify("textDocument/publishDiagnostics", #{"uri": uri, "diagnostics": diags})
  ret ast
}

fn _handle_completion(id, docs, params) {
  let mut items = []

  let builtin_sigs = _builtin_signatures()
  let ns_sigs = _builtin_ns_signatures()
  let all_names = concat_arr(map.keys(builtin_sigs), map.keys(ns_sigs))

  let mut i = 0
  while i < len(all_names) {
    let name = all_names[i]
    let sig = _lookup_signature(name, builtin_sigs, ns_sigs)
    let item = #{
      "label": name,
      "kind": 3,
      "detail": sig
    }
    items = push(items, item)
    i = i + 1
  }

  let kws = _keywords()
  i = 0
  while i < len(kws) {
    items = push(items, #{"label": kws[i], "kind": 14})
    i = i + 1
  }

  ; user functions from current document
  let uri = params["textDocument"]["uri"]
  if map.has(docs, uri) {
    let doc = docs[uri]
    let ast = doc["ast"]
    if type_of(ast) == "map" && map.has(ast, "tag") && ast["tag"] == "Program" {
      let fns = _collect_fn_decls(ast)
      let mut fi = 0
      while fi < len(fns) {
        let sig = _fn_signature(fns[fi])
        items = push(items, #{
          "label": fns[fi]["name"],
          "kind": 3,
          "detail": sig
        })
        fi = fi + 1
      }
    }
  }

  ; module names (triggered on "use ")
  let mods = _stdlib_modules()
  i = 0
  while i < len(mods) {
    items = push(items, #{"label": mods[i], "kind": 9})
    i = i + 1
  }

  _respond(id, items)
}

fn _handle_hover(id, docs, params) {
  let uri = params["textDocument"]["uri"]
  let pos = params["position"]
  let line = pos["line"]
  let character = pos["character"]

  let empty = #{}
  if !map.has(docs, uri) {
    _respond(id, empty)
    ret ""
  }

  let doc = docs[uri]
  let content = doc["content"]
  let word = _word_at(content, line, character)

  if len(word) == 0 {
    _respond(id, empty)
    ret ""
  }

  let builtin_sigs = _builtin_signatures()
  let ns_sigs = _builtin_ns_signatures()
  let sig = _lookup_signature(word, builtin_sigs, ns_sigs)

  if len(sig) > 0 {
    let hover_text = str.concat("```a\n", str.concat(sig, "\n```"))
    _respond(id, #{"contents": #{"kind": "markdown", "value": hover_text}})
    ret ""
  }

  ; check user-defined functions
  let ast = doc["ast"]
  if type_of(ast) == "map" && map.has(ast, "tag") && ast["tag"] == "Program" {
    let fns = _collect_fn_decls(ast)
    let mut fi = 0
    while fi < len(fns) {
      if fns[fi]["name"] == word {
        let fsig = _fn_signature(fns[fi])
        let hover_text = str.concat("```a\n", str.concat(fsig, "\n```"))
        _respond(id, #{"contents": #{"kind": "markdown", "value": hover_text}})
        ret ""
      }
      fi = fi + 1
    }
  }

  _respond(id, empty)
}

fn _uri_to_path(uri) {
  if str.starts_with(uri, "file://") {
    ret str.slice(uri, 7, len(uri))
  }
  ret uri
}

fn _make_location(target_uri, target_line) {
  let pos = #{"line": target_line, "character": 0}
  ret #{"uri": target_uri, "range": #{"start": pos, "end": pos}}
}

fn _find_in_imports(ast, word) {
  let items = ast["items"]
  let mut ii = 0
  while ii < len(items) {
    let item = items[ii]
    if type_of(item) == "map" && map.has(item, "tag") && item["tag"] == "UseDecl" {
      let path_arr = item["path"]
      let mod_file = str.concat(str.join(path_arr, "/"), ".a")
      if fs.exists(mod_file) {
        let mod_src = io.read_file(mod_file)
        if type_of(mod_src) == "str" && len(mod_src) > 0 {
          let prefix = path_arr[len(path_arr) - 1]
          let prefixed = str.concat(prefix, ".")
          if str.starts_with(word, prefixed) {
            let fn_name = str.slice(word, len(prefixed), len(word))
            let fn_line = _find_fn_line(mod_src, fn_name)
            let mod_uri = str.concat("file://", fs.abs(mod_file))
            ret _make_location(mod_uri, fn_line)
          }
        }
      }
    }
    ii = ii + 1
  }
  ret ""
}

fn _handle_definition(id, docs, params) {
  let uri = params["textDocument"]["uri"]
  let pos = params["position"]
  let line = pos["line"]
  let character = pos["character"]
  let empty = #{}

  if !map.has(docs, uri) {
    _respond(id, empty)
    ret ""
  }

  let doc = docs[uri]
  let content = doc["content"]
  let word = _word_at(content, line, character)

  if len(word) == 0 {
    _respond(id, empty)
    ret ""
  }

  let ast = doc["ast"]
  if type_of(ast) == "map" && map.has(ast, "tag") && ast["tag"] == "Program" {
    let fns = _collect_fn_decls(ast)
    let mut fi = 0
    while fi < len(fns) {
      if fns[fi]["name"] == word {
        let fn_line = _find_fn_line(content, word)
        _respond(id, _make_location(uri, fn_line))
        ret ""
      }
      fi = fi + 1
    }

    let imported = _find_in_imports(ast, word)
    if type_of(imported) == "map" {
      _respond(id, imported)
      ret ""
    }
  }

  _respond(id, empty)
}

; --- Main loop ---

fn _dispatch(msg, docs) {
  let method = msg["method"]
  let mut id = 0
  if map.has(msg, "id") {
    id = msg["id"]
  }
  let mut params = #{"_": 0}
  if map.has(msg, "params") {
    params = msg["params"]
  }

  _log(str.concat("recv: ", method))

  if method == "initialize" {
    _handle_initialize(id)
    ret docs
  }
  if method == "initialized" {
    _log("initialized")
    ret docs
  }
  if method == "shutdown" {
    let empty = #{}
    _respond(id, empty)
    ret "shutdown"
  }
  if method == "exit" {
    ret "exit"
  }
  if method == "textDocument/didOpen" {
    let td = params["textDocument"]
    let uri = td["uri"]
    let content = td["text"]
    let ast = _publish_diagnostics(uri, content, docs)
    ret map.set(docs, uri, #{"content": content, "ast": ast, "version": 0})
  }
  if method == "textDocument/didChange" {
    let td = params["textDocument"]
    let uri = td["uri"]
    let changes = params["contentChanges"]
    if len(changes) > 0 {
      let content = changes[0]["text"]
      let ast = _publish_diagnostics(uri, content, docs)
      ret map.set(docs, uri, #{"content": content, "ast": ast, "version": td["version"]})
    }
    ret docs
  }
  if method == "textDocument/didClose" {
    let td = params["textDocument"]
    let uri = td["uri"]
    let new_docs = map.delete(docs, uri)
    _notify("textDocument/publishDiagnostics", #{"uri": uri, "diagnostics": []})
    ret new_docs
  }
  if method == "textDocument/completion" {
    _handle_completion(id, docs, params)
    ret docs
  }
  if method == "textDocument/hover" {
    _handle_hover(id, docs, params)
    ret docs
  }
  if method == "textDocument/definition" {
    _handle_definition(id, docs, params)
    ret docs
  }
  ret docs
}

fn main() {
  _log("starting")
  let mut docs = #{}

  let mut running = true
  while running {
    let msg = _read_message()
    if type_of(msg) == "str" {
      running = false
    } else if type_of(msg) != "map" || !map.has(msg, "method") {
      if map.has(msg, "id") {
        _respond_error(msg["id"], -32600, "Invalid request")
      }
    } else {
      let result = _dispatch(msg, docs)
      if type_of(result) == "str" {
        running = false
      } else {
        docs = result
      }
    }
  }

  _log("shutdown")
}
