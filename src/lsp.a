use std.compiler.parser
use std.compiler.lexer

; --- JSON-RPC wire protocol ---

fn _log(msg) {
  eprintln(str.concat("[a-lsp] ", msg))
}

fn _strip_cr(s) {
  if len(s) > 0 && str.ends_with(s, "\r") {
    ret str.slice(s, 0, len(s) - 1)
  }
  ret s
}

fn _read_message() {
  let mut content_length = -1
  let mut raw = io.read_line()
  let mut line = _strip_cr(raw)
  if len(line) == 0 {
    let next = _strip_cr(io.read_line())
    if len(next) == 0 {
      ret "eof"
    }
    line = next
  }
  while len(line) > 0 {
    if str.starts_with(line, "Content-Length: ") {
      content_length = int(str.slice(line, 16, len(line)))
    }
    line = _strip_cr(io.read_line())
  }
  if content_length < 0 {
    ret "eof"
  }
  let body = io.read_bytes(content_length)
  ret json.parse(body)
}

fn _send(msg) {
  let mut out = map.set(msg, "jsonrpc", "2.0")
  let body = json.stringify(out)
  let header = str.concat("Content-Length: ", str.concat(to_str(len(body)), "\r\n\r\n"))
  print(str.concat(header, body))
  io.flush()
}

fn _respond(id, result) {
  _send(#{"id": id, "result": result})
}

fn _respond_error(id, code, message) {
  _send(#{"id": id, "error": #{"code": code, "message": message}})
}

fn _notify(method, params) {
  _send(#{"method": method, "params": params})
}

; --- Position mapping ---
; Convert a token index (from the parser) to a line/character pair.
; The lexer produces [kind, text, kind, text, ...] so token at index i
; corresponds to tokens i*2 and i*2+1. We rebuild offsets by walking
; the source and matching token text sequentially.

fn _offset_to_lc(source, offset) {
  let chars = str.chars(source)
  let mut line = 0
  let mut ch = 0
  let mut i = 0
  while i < offset && i < len(chars) {
    if chars[i] == "\n" {
      line = line + 1
      ch = 0
    } else {
      ch = ch + 1
    }
    i = i + 1
  }
  ret #{"line": line, "character": ch}
}

fn _build_token_offsets(source) {
  let toks = lexer.lex(source)
  let chars = str.chars(source)
  let n = len(chars)
  let num_toks = len(toks) / 2
  let mut offsets = []
  let mut pos = 0
  let mut ti = 0
  while ti < num_toks {
    let kind = toks[ti * 2]
    let text = toks[ti * 2 + 1]
    if kind == "Eof" {
      offsets = push(offsets, pos)
      ti = ti + 1
    } else {
      if kind == "Newline" {
        offsets = push(offsets, pos)
        if pos < n && chars[pos] == "\n" {
          pos = pos + 1
        }
        ti = ti + 1
      } else {
        ; skip whitespace/comments
        while pos < n && (chars[pos] == " " || chars[pos] == "\t" || chars[pos] == "\r") {
          pos = pos + 1
        }
        if pos < n && chars[pos] == ";" {
          while pos < n && chars[pos] != "\n" {
            pos = pos + 1
          }
        }
        ; skip whitespace again after comments
        while pos < n && (chars[pos] == " " || chars[pos] == "\t" || chars[pos] == "\r") {
          pos = pos + 1
        }
        offsets = push(offsets, pos)
        let tlen = len(text)
        if tlen > 0 {
          pos = pos + tlen
        } else {
          pos = pos + 1
        }
        ti = ti + 1
      }
    }
  }
  ret offsets
}

fn _token_pos_to_lc(source, token_pos) {
  let offsets = _build_token_offsets(source)
  let mut offset = 0
  if token_pos < len(offsets) {
    offset = offsets[token_pos]
  } else {
    offset = len(source)
  }
  ret _offset_to_lc(source, offset)
}

; --- Document store ---
; Global state: maps URI -> #{"content": str, "ast": ..., "version": int}

fn _parse_doc(content) {
  ret parser.parse(content)
}

; --- AST walking ---

fn _collect_fn_decls(ast) {
  let mut fns = []
  if type_of(ast) != "map" { ret fns }
  if !map.has(ast, "tag") { ret fns }
  let tag = ast["tag"]
  if tag == "Program" {
    let items = ast["items"]
    let mut i = 0
    while i < len(items) {
      fns = concat_arr(fns, _collect_fn_decls(items[i]))
      i = i + 1
    }
  }
  if tag == "FnDecl" {
    fns = push(fns, ast)
  }
  ret fns
}

fn _fn_signature(decl) {
  let name = decl["name"]
  let params = decl["params"]
  let mut parts = []
  let mut i = 0
  while i < len(params) {
    let p = params[i]
    let pname = p["name"]
    let ptyp = p["type"]
    if type_of(ptyp) == "map" && map.has(ptyp, "tag") {
      if ptyp["tag"] == "TyNamed" {
        parts = push(parts, str.concat(pname, str.concat(": ", ptyp["name"])))
      } else {
        parts = push(parts, pname)
      }
    } else {
      parts = push(parts, pname)
    }
    i = i + 1
  }
  let param_str = str.join(parts, ", ")
  let mut sig = str.concat("fn ", str.concat(name, str.concat("(", str.concat(param_str, ")"))))
  let ret_type = decl["ret_type"]
  if type_of(ret_type) == "map" && map.has(ret_type, "tag") {
    if ret_type["tag"] == "TyNamed" {
      sig = str.concat(sig, str.concat(" -> ", ret_type["name"]))
    }
  }
  ret sig
}

; Find the line number (0-indexed) where a function is declared in source
fn _find_fn_line(source, fn_name) {
  let lines = str.split(source, "\n")
  let target = str.concat("fn ", str.concat(fn_name, "("))
  let mut i = 0
  while i < len(lines) {
    if str.contains(lines[i], target) { ret i }
    i = i + 1
  }
  ret 0
}

; --- Word extraction ---
; Given source content and a line/character position, extract the word under cursor.

fn _word_at(content, line, character) {
  let lines = str.split(content, "\n")
  if line >= len(lines) { ret "" }
  let ln = lines[line]
  let chars = str.chars(ln)
  if character >= len(chars) { ret "" }
  ; expand left
  let mut left = character
  while left > 0 {
    let c = chars[left - 1]
    if is_alnum(c) || c == "_" || c == "." {
      left = left - 1
    } else {
      break
    }
  }
  ; expand right
  let mut right = character
  while right < len(chars) {
    let c = chars[right]
    if is_alnum(c) || c == "_" || c == "." {
      right = right + 1
    } else {
      break
    }
  }
  if left == right { ret "" }
  ret str.join(slice(chars, left, right), "")
}

; --- Builtin registry ---

fn _builtin_signatures() {
  let mut m = #{}
  m = map.set(m, "println", "fn println(value) -> void")
  m = map.set(m, "print", "fn print(value) -> void")
  m = map.set(m, "eprintln", "fn eprintln(value) -> void")
  m = map.set(m, "len", "fn len(value) -> i64")
