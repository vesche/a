  m = map.set(m, "to_str", "fn to_str(value) -> str")
  m = map.set(m, "type_of", "fn type_of(value) -> str")
  m = map.set(m, "int", "fn int(value) -> i64")
  m = map.set(m, "float", "fn float(value) -> f64")
  m = map.set(m, "sort", "fn sort(arr) -> array")
  m = map.set(m, "contains", "fn contains(arr, value) -> bool")
  m = map.set(m, "reverse_arr", "fn reverse_arr(arr) -> array")
  m = map.set(m, "concat_arr", "fn concat_arr(a, b) -> array")
  m = map.set(m, "args", "fn args() -> [str]")
  m = map.set(m, "argv0", "fn argv0() -> str")
  m = map.set(m, "slice", "fn slice(arr, start, end) -> array")
  m = map.set(m, "char_code", "fn char_code(ch) -> i64")
  m = map.set(m, "from_code", "fn from_code(code) -> str")
  m = map.set(m, "is_alpha", "fn is_alpha(ch) -> bool")
  m = map.set(m, "is_digit", "fn is_digit(ch) -> bool")
  m = map.set(m, "is_alnum", "fn is_alnum(ch) -> bool")
  m = map.set(m, "fail", "fn fail(message) -> void")
  m = map.set(m, "exit", "fn exit(code) -> void")
  m = map.set(m, "Ok", "fn Ok(value) -> Result")
  m = map.set(m, "Err", "fn Err(value) -> Result")
