; std/log.a -- Structured JSON logging to stderr
use std.datetime

fn _level_num(level: str) -> int {
  if level == "debug" { ret 0 }
  if level == "info" { ret 1 }
  if level == "warn" { ret 2 }
  if level == "error" { ret 3 }
  ret 1
}

fn _current_level() -> int {
  let lvl = env.get("_A_LOG_LEVEL")
  if lvl == "" { ret 1 }
  ret _level_num(lvl)
}

fn set_level(level: str) -> void {
  env.set("_A_LOG_LEVEL", level)
}

fn log(level: str, msg: str, ctx) -> void {
  if _level_num(level) < _current_level() { ret }
  let mut entry = #{ "level": level, "msg": msg, "ts": datetime.iso(time.now()) }
  if type_of(ctx) == "map" {
    let keys = map.keys(ctx)
    let mut i = 0
    while i < len(keys) {
      entry = map.set(entry, keys[i], ctx[keys[i]])
      i = i + 1
    }
  }
  eprintln(json.stringify(entry))
}

fn debug(msg: str) -> void {
  log("debug", msg, 0)
}

fn info(msg: str) -> void {
  log("info", msg, 0)
}

fn warn(msg: str) -> void {
  log("warn", msg, 0)
}

fn error(msg: str) -> void {
  log("error", msg, 0)
}

fn with(key: str, val) -> map {
  ret map.set(#{}, key, val)
}

fn debugf(msg: str, ctx) -> void {
  log("debug", msg, ctx)
}

fn infof(msg: str, ctx) -> void {
  log("info", msg, ctx)
}

fn warnf(msg: str, ctx) -> void {
  log("warn", msg, ctx)
}

fn errorf(msg: str, ctx) -> void {
  log("error", msg, ctx)
}

fn timed(label: str, f) -> void {
  let start = time.now()
  f()
  let elapsed = time.now() - start
  log("info", label, #{"elapsed_ms": elapsed})
}

fn with2(k1: str, v1, k2: str, v2) -> map {
  ret map.set(map.set(#{}, k1, v1), k2, v2)
}

fn child(base_ctx) -> map {
  ret base_ctx
}

fn child_log(level: str, msg: str, base_ctx, extra) -> void {
  let mut ctx = base_ctx
  if type_of(extra) == "map" {
    let keys = map.keys(extra)
    let mut i = 0
    while i < len(keys) {
      ctx = map.set(ctx, keys[i], extra[keys[i]])
      i = i + 1
    }
  }
  log(level, msg, ctx)
}
