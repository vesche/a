; std/diff.a -- Text diff (Myers algorithm), patch, unified format

fn _split(s: str) -> array {
  if s == "" { ret [] }
  ret str.lines(str.replace(s, "\r", ""))
}

fn _myers(a_lines, b_lines) -> array {
  let n = len(a_lines)
  let m = len(b_lines)
  if n == 0 {
    let mut ops = []
    let mut j = 0
    while j < m {
      ops = push(ops, #{ "op": "add", "line": b_lines[j] })
      j = j + 1
    }
    ret ops
  }
  if m == 0 {
    let mut ops = []
    let mut i = 0
    while i < n {
      ops = push(ops, #{ "op": "remove", "line": a_lines[i] })
      i = i + 1
    }
    ret ops
  }

  let max_d = n + m
  ; V array indexed by k + max_d (to handle negative diagonals)
  let size = 2 * max_d + 1
  let mut v = []
  let mut vi = 0
  while vi < size {
    v = push(v, 0)
    vi = vi + 1
  }
  ; Store V snapshots for backtracking
  let mut trace = []

  let mut d = 0
  let mut found = false
  while d <= max_d {
    let mut k = 0 - d
    while k <= d {
      let idx = k + max_d
      let mut x = 0
      if k == 0 - d {
        x = v[idx + 1]
      } else {
        if k == d {
          x = v[idx - 1] + 1
        } else {
          if v[idx - 1] + 1 > v[idx + 1] {
            x = v[idx - 1] + 1
          } else {
            x = v[idx + 1]
          }
        }
      }
      let mut y = x - k

      ; Extend diagonal (match/equal lines)
      while x < n {
        if y >= m { break }
        if a_lines[x] != b_lines[y] { break }
        x = x + 1
        y = y + 1
      }

      v = _arr_set(v, idx, x)

      if x >= n {
        if y >= m {
          found = true
          break
        }
      }
      k = k + 2
    }

    ; Save V state after this d iteration
    let mut v_copy = []
    let mut ci = 0
    while ci < size {
      v_copy = push(v_copy, v[ci])
      ci = ci + 1
    }
    trace = push(trace, v_copy)

    if found { break }
    d = d + 1
  }

  ; Backtrack to recover edit script
  ret _backtrack(trace, a_lines, b_lines, d, n, m, max_d)
}

fn _arr_set(arr, idx: int, val) -> array {
  let mut result = []
  let mut i = 0
  while i < len(arr) {
    if i == idx {
      result = push(result, val)
    } else {
      result = push(result, arr[i])
    }
    i = i + 1
  }
  ret result
}

fn _backtrack(trace, a_lines, b_lines, d: int, n: int, m: int, max_d: int) -> array {
  let mut ops = []
  let mut x = n
  let mut y = m
  let mut dd = d
  while dd > 0 {
    let v_prev = trace[dd - 1]
    let k = x - y
    let idx = k + max_d
    let mut prev_k = k
    if k == 0 - dd {
      prev_k = k + 1
    } else {
      if k == dd {
        prev_k = k - 1
      } else {
        if v_prev[idx - 1] < v_prev[idx + 1] {
          prev_k = k + 1
        } else {
          prev_k = k - 1
        }
      }
    }

    let prev_x = v_prev[prev_k + max_d]
    let prev_y = prev_x - prev_k

    while x > prev_x {
      if y > prev_y {
        x = x - 1
        y = y - 1
        ops = push(ops, #{ "op": "keep", "line": a_lines[x] })
      } else {
        break
      }
    }

    if x == prev_x {
      y = y - 1
      ops = push(ops, #{ "op": "add", "line": b_lines[y] })
    } else {
      x = x - 1
      ops = push(ops, #{ "op": "remove", "line": a_lines[x] })
    }

    x = prev_x
    y = prev_y
    dd = dd - 1
  }

  while x > 0 {
    if y > 0 {
      x = x - 1
      y = y - 1
      ops = push(ops, #{ "op": "keep", "line": a_lines[x] })
    } else {
      break
    }
  }

  let mut reversed = []
  let mut ri = len(ops) - 1
  while ri >= 0 {
    reversed = push(reversed, ops[ri])
    ri = ri - 1
  }
  ret reversed
}

fn lines(a: str, b: str) -> array {
  let a_lines = _split(a)
  let b_lines = _split(b)
  ret _myers(a_lines, b_lines)
}

fn _format_unified(ops) -> str {
  let n = len(ops)
  if n == 0 { ret "" }

  let mut out = ""
  let mut a_pos = 1
  let mut b_pos = 1

  ; Collect hunks -- groups of changes with 3 lines of context
  let context = 3
  let mut i = 0
  while i < n {
    ; Skip to next change
    if ops[i]["op"] == "keep" {
      a_pos = a_pos + 1
      b_pos = b_pos + 1
      i = i + 1
      continue
    }

    ; Found a change -- build a hunk
    let mut hunk_start = i
    ; Include up to 3 context lines before
    let mut ctx_before = 0
    while ctx_before < context {
      if hunk_start > 0 {
        if ops[hunk_start - 1]["op"] == "keep" {
          hunk_start = hunk_start - 1
          ctx_before = ctx_before + 1
        } else {
          break
        }
      } else {
        break
      }
    }

    ; Find end of hunk (extend past changes + context)
    let mut hunk_end = i
    while hunk_end < n {
      if ops[hunk_end]["op"] != "keep" {
        hunk_end = hunk_end + 1
        ; Add context after change
        let mut ctx_after = 0
        while ctx_after < context {
          if hunk_end < n {
            if ops[hunk_end]["op"] == "keep" {
              hunk_end = hunk_end + 1
              ctx_after = ctx_after + 1
            } else {
              break
            }
          } else {
            break
          }
        }
        ; Check if next change is within context window
        if hunk_end < n {
          if ops[hunk_end]["op"] != "keep" {
            continue
          }
        }
        break
      } else {
        break
      }
    }

    ; Calculate line numbers
    let a_start = a_pos - ctx_before
    let b_start = b_pos - ctx_before
    let mut a_count = 0
    let mut b_count = 0
    let mut hi = hunk_start
    while hi < hunk_end {
      let hop = ops[hi]["op"]
      if hop == "keep" {
        a_count = a_count + 1
        b_count = b_count + 1
      }
      if hop == "remove" { a_count = a_count + 1 }
      if hop == "add" { b_count = b_count + 1 }
      hi = hi + 1
    }

    ; Output hunk header
    out = str.concat(out, str.concat("@@ -", str.concat(to_str(a_start), str.concat(",", str.concat(to_str(a_count), str.concat(" +", str.concat(to_str(b_start), str.concat(",", str.concat(to_str(b_count), str.concat(" @@", "\n"))))))))))

    ; Output hunk lines
    let mut hj = hunk_start
    while hj < hunk_end {
      let hop = ops[hj]["op"]
      let hline = ops[hj]["line"]
      if hop == "keep" { out = str.concat(out, str.concat(" ", str.concat(hline, "\n"))) }
      if hop == "remove" { out = str.concat(out, str.concat("-", str.concat(hline, "\n"))) }
      if hop == "add" { out = str.concat(out, str.concat("+", str.concat(hline, "\n"))) }
      hj = hj + 1
    }

    ; Advance positions to end of hunk
    a_pos = a_start + a_count
    b_pos = b_start + b_count
    i = hunk_end
  }

  ret out
}

fn text(a: str, b: str) -> str {
  let ops = lines(a, b)
  let mut out = "--- a\n+++ b\n"
  out = str.concat(out, _format_unified(ops))
  ret out
}

fn patch(original: str, diff_str: str) -> str {
  let orig_lines = _split(original)
  let diff_lines = _split(diff_str)
  let mut result = []
  let mut orig_idx = 0
  let n = len(diff_lines)
  let mut i = 0

  while i < n {
    let line = diff_lines[i]
    if str.starts_with(line, "@@") {
      ; Parse hunk header: @@ -start,count +start,count @@
      let parts = str.split(line, " ")
      ; parts[1] is like "-1,3", extract start
      let minus_part = parts[1]
      let comma_parts = str.split(str.slice(minus_part, 1, len(str.chars(minus_part))), ",")
      let hunk_start = int(comma_parts[0])

      ; Copy lines before this hunk
      while orig_idx < hunk_start - 1 {
        result = push(result, orig_lines[orig_idx])
        orig_idx = orig_idx + 1
      }
      i = i + 1
      continue
    }

    if str.starts_with(line, "---") {
      i = i + 1
      continue
    }
    if str.starts_with(line, "+++") {
      i = i + 1
      continue
    }

    let first = str.slice(line, 0, 1)
    let rest = str.slice(line, 1, len(str.chars(line)))
    if first == " " {
      result = push(result, rest)
      orig_idx = orig_idx + 1
    }
    if first == "-" {
      orig_idx = orig_idx + 1
    }
    if first == "+" {
      result = push(result, rest)
    }
    i = i + 1
  }

  ; Copy remaining original lines
  while orig_idx < len(orig_lines) {
    result = push(result, orig_lines[orig_idx])
    orig_idx = orig_idx + 1
  }

  ret str.join(result, "\n")
}
