; Self-hosted "a" language lexer -- full parity with src/lexer.rs
; Tokenizes source into flat array: [kind0, text0, kind1, text1, ...]
; Supports string interpolation (InterpStart, InterpMid, InterpEnd),
; DotDotDot (...), Underscore (_), and all escape sequences.

fn is_ws(c: str) -> bool {
  ret c == " " || c == "\t" || c == "\r"
}

fn is_id_start(c: str) -> bool {
  ret is_alpha(c) || c == "_"
}

fn is_id_char(c: str) -> bool {
  ret is_alnum(c) || c == "_"
}

fn keyword_or_ident(word: str) -> str {
  if word == "fn" { ret "KwFn" }
  if word == "ty" { ret "KwTy" }
  if word == "mod" { ret "KwMod" }
  if word == "let" { ret "KwLet" }
  if word == "mut" { ret "KwMut" }
  if word == "if" { ret "KwIf" }
  if word == "else" { ret "KwElse" }
  if word == "match" { ret "KwMatch" }
  if word == "for" { ret "KwFor" }
  if word == "in" { ret "KwIn" }
  if word == "while" { ret "KwWhile" }
  if word == "break" { ret "KwBreak" }
  if word == "continue" { ret "KwContinue" }
  if word == "ret" { ret "KwRet" }
  if word == "use" { ret "KwUse" }
  if word == "try" { ret "KwTry" }
  if word == "pub" { ret "KwPub" }
  if word == "effects" { ret "KwEffects" }
  if word == "pre" { ret "KwPre" }
  if word == "post" { ret "KwPost" }
  if word == "where" { ret "KwWhere" }
  if word == "true" { ret "KwTrue" }
  if word == "false" { ret "KwFalse" }
  if word == "i8" { ret "TyI8" }
  if word == "i16" { ret "TyI16" }
  if word == "i32" { ret "TyI32" }
  if word == "i64" { ret "TyI64" }
  if word == "u8" { ret "TyU8" }
  if word == "u16" { ret "TyU16" }
  if word == "u32" { ret "TyU32" }
  if word == "u64" { ret "TyU64" }
  if word == "f32" { ret "TyF32" }
  if word == "f64" { ret "TyF64" }
  if word == "bool" { ret "TyBool" }
  if word == "str" { ret "TyStr" }
  if word == "bytes" { ret "TyBytes" }
  if word == "void" { ret "TyVoid" }
  if word == "_" { ret "Underscore" }
  ret "Ident"
}

fn process_escape(c: str) -> str {
  if c == "n" { ret "\n" }
  if c == "t" { ret "\t" }
  if c == "r" { ret "\r" }
  if c == "\\" { ret "\\" }
  if c == "\"" { ret "\"" }
  if c == "\{" { ret "\{" }
  if c == "\}" { ret "\}" }
  ret c
}

fn lex(src: str) -> [str] {
  let chars = str.chars(src)
  let n = len(chars)
  let mut pos = 0
  let mut toks: [str] = []
  let mut interp_depth = 0

  while pos < n {
    let c = chars[pos]

    if c == "\n" {
      toks = push(toks, "Newline")
      toks = push(toks, "")
      pos = pos + 1
      continue
    }

    if is_ws(c) {
      pos = pos + 1
      continue
    }

    ; semicolon comments
    if c == ";" {
      while pos < n {
        if chars[pos] == "\n" { break }
        pos = pos + 1
      }
      continue
    }

    ; raw strings: r"..." or r#"..."#
    if c == "r" {
      if pos < n {
        if chars[pos] == "\"" {
          pos = pos + 1
          let mut content = ""
          while pos < n {
            if chars[pos] == "\"" {
              pos = pos + 1
              break
            }
            content = content + chars[pos]
            pos = pos + 1
          }
          toks = push(toks, "Str")
          toks = push(toks, content)
          continue
        }
        if chars[pos] == "#" {
          let hash_start = pos
          let mut hashes = 0
          while pos < n {
            if chars[pos] == "#" {
              hashes = hashes + 1
              pos = pos + 1
            } else { break }
          }
          if pos < n {
            if chars[pos] == "\"" {
              pos = pos + 1
              let mut content = ""
              let mut found = false
              while pos < n {
                if chars[pos] == "\"" {
                  let mut hi = 0
                  let mut ok = true
                  while hi < hashes {
                    if pos + 1 + hi >= n {
                      ok = false
                      break
                    }
                    if chars[pos + 1 + hi] != "#" {
                      ok = false
                      break
                    }
                    hi = hi + 1
                  }
                  if ok {
                    pos = pos + 1 + hashes
                    found = true
                    break
                  }
                }
                content = content + chars[pos]
                pos = pos + 1
              }
              toks = push(toks, "Str")
              toks = push(toks, content)
              continue
            }
          }
          pos = hash_start
        }
      }
    }

    ; heredoc: triple backtick
    if c == "`" {
      if pos + 1 < n {
        if chars[pos] == "`" {
          if chars[pos + 1] == "`" {
            pos = pos + 2
            if pos < n {
              if chars[pos] == "\n" { pos = pos + 1 }
            }
            let mut content = ""
            while pos < n {
              if chars[pos] == "`" {
                if pos + 2 < n {
                  if chars[pos + 1] == "`" {
                    if chars[pos + 2] == "`" {
                      pos = pos + 3
                      if len(content) > 0 {
                        if str.slice(content, len(content) - 1, len(content)) == "\n" {
                          content = str.slice(content, 0, len(content) - 1)
                        }
                      }
                      break
                    }
                  }
                }
              }
              content = content + chars[pos]
              pos = pos + 1
            }
            toks = push(toks, "Str")
            toks = push(toks, content)
            continue
          }
        }
      }
    }

    ; identifiers and keywords
    if is_id_start(c) {
      let start = pos
      while pos < n {
        if is_id_char(chars[pos]) { pos = pos + 1 } else { break }
      }
      let word = str.slice(src, start, pos)
      let kind = keyword_or_ident(word)
      toks = push(toks, kind)
      toks = push(toks, word)
      continue
    }

    ; numbers
    if is_digit(c) {
      let start = pos
      let mut is_float = false
      while pos < n {
        if is_digit(chars[pos]) {
          pos = pos + 1
        } else {
          if chars[pos] == "." {
            if is_float { break }
            if pos + 1 < n {
              if is_digit(chars[pos + 1]) {
                is_float = true
                pos = pos + 1
              } else { break }
            } else { break }
          } else { break }
        }
      }
      let text = str.slice(src, start, pos)
      if is_float {
        toks = push(toks, "Float")
      } else {
        toks = push(toks, "Int")
      }
      toks = push(toks, text)
      continue
    }

    ; strings with interpolation support
    if c == "\"" {
      pos = pos + 1
      let mut content = ""
      let mut done = false
      while pos < n {
        let sc = chars[pos]
        if sc == "\"" {
          pos = pos + 1
          done = true
          break
        }
        if sc == "\{" {
          ; start interpolation
          toks = push(toks, "InterpStart")
          toks = push(toks, content)
          content = ""
          interp_depth = interp_depth + 1
          pos = pos + 1
          done = true
          break
        }
        if sc == "\\" {
          pos = pos + 1
          if pos < n {
            content = content + process_escape(chars[pos])
            pos = pos + 1
          }
          continue
        }
        content = content + sc
        pos = pos + 1
      }
      if done {
        if interp_depth == 0 {
          ; check if we ended normally (with ") vs started interp
          ; if last push was InterpStart, we already handled it
          let tlen = len(toks)
          if tlen > 0 {
            if toks[tlen - 2] == "InterpStart" {
              continue
            }
          }
          toks = push(toks, "Str")
          toks = push(toks, content)
        }
      } else {
        toks = push(toks, "Str")
        toks = push(toks, content)
      }
      continue
    }

    ; closing } during interpolation -> continue scanning string
    if c == "\}" {
      if interp_depth > 0 {
        pos = pos + 1
        let mut content = ""
        let mut ended = false
        while pos < n {
          let sc = chars[pos]
          if sc == "\"" {
            pos = pos + 1
            interp_depth = interp_depth - 1
            toks = push(toks, "InterpEnd")
            toks = push(toks, content)
            ended = true
            break
          }
          if sc == "\{" {
            toks = push(toks, "InterpMid")
            toks = push(toks, content)
            content = ""
            pos = pos + 1
            ended = true
            break
          }
          if sc == "\\" {
            pos = pos + 1
            if pos < n {
              content = content + process_escape(chars[pos])
              pos = pos + 1
            }
            continue
          }
          content = content + sc
          pos = pos + 1
        }
        if ended { continue }
        interp_depth = interp_depth - 1
        toks = push(toks, "InterpEnd")
        toks = push(toks, content)
        continue
      }
      toks = push(toks, "RBrace")
      toks = push(toks, "\}")
      pos = pos + 1
      continue
    }

    ; single-char punctuation
    if c == "(" { toks = push(toks, "LParen")
      toks = push(toks, "(")
      pos = pos + 1
      continue }
    if c == ")" { toks = push(toks, "RParen")
      toks = push(toks, ")")
      pos = pos + 1
      continue }
    if c == "\{" { toks = push(toks, "LBrace")
      toks = push(toks, "\{")
      pos = pos + 1
      continue }
    if c == "[" { toks = push(toks, "LBracket")
      toks = push(toks, "[")
      pos = pos + 1
      continue }
    if c == "]" { toks = push(toks, "RBracket")
      toks = push(toks, "]")
      pos = pos + 1
      continue }
    if c == "," { toks = push(toks, "Comma")
      toks = push(toks, ",")
      pos = pos + 1
      continue }
    if c == ":" { toks = push(toks, "Colon")
      toks = push(toks, ":")
      pos = pos + 1
      continue }
    if c == "?" { toks = push(toks, "Question")
      toks = push(toks, "?")
      pos = pos + 1
      continue }
    if c == "#" { toks = push(toks, "Hash")
      toks = push(toks, "#")
      pos = pos + 1
      continue }
    if c == "+" { toks = push(toks, "Plus")
      toks = push(toks, "+")
      pos = pos + 1
      continue }
    if c == "*" { toks = push(toks, "Star")
      toks = push(toks, "*")
      pos = pos + 1
      continue }
    if c == "%" { toks = push(toks, "Percent")
      toks = push(toks, "%")
      pos = pos + 1
      continue }
    if c == "/" { toks = push(toks, "Slash")
      toks = push(toks, "/")
      pos = pos + 1
      continue }

    ; dot and DotDotDot
    if c == "." {
      if pos + 2 < n {
        if chars[pos + 1] == "." {
          if chars[pos + 2] == "." {
            toks = push(toks, "DotDotDot")
            toks = push(toks, "...")
            pos = pos + 3
            continue
          }
        }
      }
      toks = push(toks, "Dot")
      toks = push(toks, ".")
      pos = pos + 1
      continue
    }

    ; two-char operators
    if c == "-" {
      if pos + 1 < n {
        if chars[pos + 1] == ">" {
          toks = push(toks, "Arrow")
          toks = push(toks, "->")
          pos = pos + 2
          continue
        }
      }
      toks = push(toks, "Minus")
      toks = push(toks, "-")
      pos = pos + 1
      continue
    }

    if c == "=" {
      if pos + 1 < n {
        if chars[pos + 1] == "=" {
          toks = push(toks, "EqEq")
          toks = push(toks, "==")
          pos = pos + 2
          continue
        }
        if chars[pos + 1] == ">" {
          toks = push(toks, "FatArrow")
          toks = push(toks, "=>")
          pos = pos + 2
          continue
        }
      }
      toks = push(toks, "Eq")
      toks = push(toks, "=")
      pos = pos + 1
      continue
    }

    if c == "!" {
      if pos + 1 < n {
        if chars[pos + 1] == "=" {
          toks = push(toks, "NotEq")
          toks = push(toks, "!=")
          pos = pos + 2
          continue
        }
      }
      toks = push(toks, "Bang")
      toks = push(toks, "!")
      pos = pos + 1
      continue
    }

    if c == "<" {
      if pos + 1 < n {
        if chars[pos + 1] == "=" {
          toks = push(toks, "LtEq")
          toks = push(toks, "<=")
          pos = pos + 2
          continue
        }
      }
      toks = push(toks, "Lt")
      toks = push(toks, "<")
      pos = pos + 1
      continue
    }

    if c == ">" {
      if pos + 1 < n {
        if chars[pos + 1] == "=" {
          toks = push(toks, "GtEq")
          toks = push(toks, ">=")
          pos = pos + 2
          continue
        }
      }
      toks = push(toks, "Gt")
      toks = push(toks, ">")
      pos = pos + 1
      continue
    }

    if c == "&" {
      if pos + 1 < n {
        if chars[pos + 1] == "&" {
          toks = push(toks, "AmpAmp")
          toks = push(toks, "&&")
          pos = pos + 2
          continue
        }
      }
      toks = push(toks, "Amp")
      toks = push(toks, "&")
      pos = pos + 1
      continue
    }

    if c == "|" {
      if pos + 1 < n {
        if chars[pos + 1] == "|" {
          toks = push(toks, "PipePipe")
          toks = push(toks, "||")
          pos = pos + 2
          continue
        }
        if chars[pos + 1] == ">" {
          toks = push(toks, "PipeArrow")
          toks = push(toks, "|>")
          pos = pos + 2
          continue
        }
      }
      toks = push(toks, "Pipe")
      toks = push(toks, "|")
      pos = pos + 1
      continue
    }

    toks = push(toks, "Unknown")
    toks = push(toks, c)
    pos = pos + 1
  }

  toks = push(toks, "Eof")
  toks = push(toks, "")
  ret toks
}

; Token access helpers
fn tk(toks: [str], i: i64) -> str {
  ret toks[i * 2]
}

fn tv(toks: [str], i: i64) -> str {
  ret toks[i * 2 + 1]
}

fn tcount(toks: [str]) -> i64 {
  ret len(toks) / 2
}

fn skip_nl(toks: [str], p: i64) -> i64 {
  let mut i = p
  while tk(toks, i) == "Newline" {
    i = i + 1
  }
  ret i
}
