; std/compiler/cgen.a -- C code generation backend
; Reads an "a" source file, parses to AST, emits C source to stdout.
; Supports `use` module inlining, closures/lambdas, HOFs, pipes.
; Usage: a run std/compiler/cgen.a -- input.a > output.c

use std.compiler.parser
use std.compiler.ast

; Builtin name -> C function name mapping
fn _builtin_map() -> map {
  let m = #{
    "println": "a_println", "print": "a_print", "eprintln": "a_eprintln",
    "len": "a_len", "push": "a_array_push", "to_str": "a_to_str",
    "fail": "a_fail", "type_of": "a_type_of", "int": "a_to_int", "float": "a_to_float",
    "sort": "a_sort", "contains": "a_contains", "reverse_arr": "a_reverse_arr",
    "concat_arr": "a_concat_arr", "args": "a_args", "slice": "a_array_slice",
    "char_code": "a_char_code", "from_code": "a_from_code",
    "is_alpha": "a_is_alpha", "is_digit": "a_is_digit", "is_alnum": "a_is_alnum",
    "Ok": "a_ok", "Err": "a_err", "unwrap": "a_unwrap",
    "is_ok": "a_is_ok", "is_err": "a_is_err", "unwrap_or": "a_unwrap_or"
  }
  let m2 = #{
    "str.concat": "a_str_concat", "str.split": "a_str_split",
    "str.contains": "a_str_contains", "str.replace": "a_str_replace",
    "str.trim": "a_str_trim", "str.upper": "a_str_upper", "str.lower": "a_str_lower",
    "str.join": "a_str_join", "str.chars": "a_str_chars", "str.slice": "a_str_slice",
    "str.starts_with": "a_str_starts_with", "str.ends_with": "a_str_ends_with",
    "str.find": "a_str_find", "str.count": "a_str_count", "str.lines": "a_str_lines",
    "map.get": "a_map_get", "map.set": "a_map_set", "map.has": "a_map_has",
    "map.keys": "a_map_keys", "map.values": "a_map_values", "map.merge": "a_map_merge",
    "map.delete": "a_map_delete", "map.entries": "a_map_entries", "map.from_entries": "a_map_from_entries"
  }
  let m3 = #{
    "io.read_file": "a_io_read_file", "io.write_file": "a_io_write_file",
    "io.read_stdin": "a_io_read_stdin", "io.read_line": "a_io_read_line",
    "fs.ls": "a_fs_ls", "fs.mkdir": "a_fs_mkdir", "fs.cwd": "a_fs_cwd",
    "fs.exists": "a_fs_exists", "fs.is_dir": "a_fs_is_dir",
    "fs.rm": "a_fs_rm", "fs.mv": "a_fs_mv", "fs.cp": "a_fs_cp",
    "fs.abs": "a_fs_abs", "fs.is_file": "a_fs_is_file",
    "exec": "a_exec", "env.get": "a_env_get",
    "env.set": "a_env_set", "env.all": "a_env_all",
    "json.parse": "a_json_parse",
    "json.stringify": "a_json_stringify", "json.pretty": "a_json_pretty"
  }
  let m4 = #{
    "math.sqrt": "a_math_sqrt", "math.abs": "a_math_abs",
    "math.floor": "a_math_floor", "math.ceil": "a_math_ceil", "math.round": "a_math_round",
    "math.pow": "a_math_pow", "math.min": "a_math_min", "math.max": "a_math_max",
    "time.now": "a_time_now", "time.sleep": "a_time_sleep",
    "hash.sha256": "a_hash_sha256", "hash.md5": "a_hash_md5",
    "http.get": "a_http_get", "http.post": "a_http_post",
    "map": "a_hof_map", "filter": "a_hof_filter", "reduce": "a_hof_reduce",
    "each": "a_hof_each", "sort_by": "a_hof_sort_by", "find": "a_hof_find",
    "any": "a_hof_any", "all": "a_hof_all", "flat_map": "a_hof_flat_map",
    "min_by": "a_hof_min_by", "max_by": "a_hof_max_by",
    "enumerate": "a_enumerate", "zip": "a_zip",
    "take": "a_take", "drop": "a_drop", "unique": "a_unique", "chunk": "a_chunk",
    "ptr.null": "a_ptr_null", "ptr.is_null": "a_is_null"
  }
  ret map.merge(map.merge(map.merge(m, m2), m3), m4)
}

fn _void_builtins() -> [str] {
  ret ["println", "print", "eprintln", "fail", "each", "env.set", "time.sleep"]
}

fn _c_keywords() -> [str] {
  ret ["short", "long", "int", "float", "double", "void", "char", "auto",
       "do", "default", "register", "signed", "unsigned", "const", "static",
       "extern", "case", "switch", "goto", "struct", "union", "enum",
       "typedef", "sizeof", "volatile", "inline", "restrict"]
}

fn _mangle(name: str) -> str {
  let out = str.replace(str.replace(name, ".", "_"), "-", "_")
  if contains(_c_keywords(), out) { ret str.concat("_", out) }
  ret out
}

fn _bslash() -> str { ret from_code(92) }
fn _dquote() -> str { ret from_code(34) }
fn _newline_char() -> str { ret from_code(10) }
fn _tab_char() -> str { ret from_code(9) }
fn _cr_char() -> str { ret from_code(13) }

fn _escape_c_str(s: str) -> str {
  let bs = _bslash()
  let out = str.replace(s, bs, str.concat(bs, bs))
  out = str.replace(out, _dquote(), str.concat(bs, _dquote()))
  out = str.replace(out, _newline_char(), str.concat(bs, "n"))
  out = str.replace(out, _cr_char(), str.concat(bs, "r"))
  out = str.replace(out, _tab_char(), str.concat(bs, "t"))
  ret out
}

fn _indent(depth: int) -> str {
  let mut out = ""
  let mut i = 0
  while i < depth {
    out = str.concat(out, "    ")
    i = i + 1
  }
  ret out
}

; ctx = #{"prefix": "parser", "fns": ["parse", ...]}
; prefix="" for main file, "modname" for imported modules

fn _prefixed_name(name, ctx) -> str {
  let prefix = ctx["prefix"]
  if type_of(prefix) == "str" {
    if len(prefix) > 0 {
      ret str.concat(prefix, str.concat("_", name))
    }
  }
  ret name
}

fn _is_intra_module_call(fname, ctx) -> bool {
  let prefix = ctx["prefix"]
  if type_of(prefix) != "str" { ret false }
  if len(prefix) == 0 { ret false }
  if str.contains(fname, ".") { ret false }
  let fns = ctx["fns"]
  if type_of(fns) == "array" {
    ret contains(fns, fname)
  }
  ret false
}

; --- Result triple: [code, lambda_id, [lifted_fns]] ---
; All emit functions return this so lambda state threads correctly.

fn _R(code, li) { ret [code, li, []] }
fn _RL(code, li, lifted) { ret [code, li, lifted] }

fn _is_ident(node) -> bool {
  if type_of(node) != "map" { ret false }
  if node["tag"] != "Ident" { ret false }
  let n = node["name"]
  if n == "true" { ret false }
  if n == "false" { ret false }
  ret true
}

fn _emit_cleanup(vars, depth) -> str {
  let ind = _indent(depth)
  let mut out = ""
  for v in vars {
    out = str.concat(out, str.concat("\n", str.concat(ind, str.concat("a_release(", str.concat(v, ");")))))
  }
  ret out
}

; --- Escape analysis ---
; A variable escapes if its value can outlive its scope:
;   - returned from the function
;   - captured by a lambda
;   - stored in a collection passed to a non-builtin function

fn _ea_collect_idents(expr) -> [str] {
  if type_of(expr) != "map" { ret [] }
  let tag = expr["tag"]
  if tag == "Ident" {
    let n = expr["name"]
    if n == "true" { ret [] }
    if n == "false" { ret [] }
    ret [n]
  }
  if tag == "BinOp" { ret concat_arr(_ea_collect_idents(expr["left"]), _ea_collect_idents(expr["right"])) }
  if tag == "UnaryOp" { ret _ea_collect_idents(expr["expr"]) }
  if tag == "Call" {
    let mut ids = _ea_collect_idents(expr["func"])
    for a in expr["args"] { ids = concat_arr(ids, _ea_collect_idents(a)) }
    ret ids
  }
  if tag == "Index" { ret concat_arr(_ea_collect_idents(expr["expr"]), _ea_collect_idents(expr["index"])) }
  if tag == "FieldAccess" { ret _ea_collect_idents(expr["expr"]) }
  if tag == "Array" {
    let mut ids = []
    for e in expr["elems"] { ids = concat_arr(ids, _ea_collect_idents(e)) }
    ret ids
  }
  if tag == "Map" {
    let mut ids = []
    for e in expr["entries"] { ids = concat_arr(ids, _ea_collect_idents(e["value"])) }
    ret ids
  }
  if tag == "Spread" { ret _ea_collect_idents(expr["expr"]) }
  if tag == "Pipe" { ret concat_arr(_ea_collect_idents(expr["left"]), _ea_collect_idents(expr["right"])) }
  if tag == "InterpolatedString" {
    let mut ids = []
    for p in expr["parts"] {
      if p["tag"] == "Expr" { ids = concat_arr(ids, _ea_collect_idents(p["expr"])) }
    }
    ret ids
  }
  ret []
}

fn _escape_analysis(stmts, captures) -> [str] {
  let mut escaping = []

  for s in stmts {
    let tag = s["tag"]
    if tag == "Return" {
      if type_of(s["expr"]) != "void" {
        let ids = _ea_collect_idents(s["expr"])
        for id in ids {
          if !contains(escaping, id) { escaping = push(escaping, id) }
        }
      }
    }
  }

  ; Variables captured by lambdas escape
  for cap in captures {
    if !contains(escaping, cap) { escaping = push(escaping, cap) }
  }

  ret escaping
}

; --- Free variable analysis for closures ---

fn _collect_idents_in_expr(node) -> [str] {
  let tag = node["tag"]
  if type_of(tag) != "str" { ret [] }

  if tag == "Ident" { ret [node["name"]] }
  if tag == "Int" { ret [] }
  if tag == "Float" { ret [] }
  if tag == "Bool" { ret [] }
  if tag == "Void" { ret [] }
  if tag == "String" { ret [] }

  if tag == "BinOp" {
    ret concat_arr(_collect_idents_in_expr(node["left"]), _collect_idents_in_expr(node["right"]))
  }
  if tag == "UnaryOp" { ret _collect_idents_in_expr(node["expr"]) }

  if tag == "Call" {
    let mut ids = []
    let func = node["func"]
    if func["tag"] == "Ident" {
      ; function name idents are NOT variable captures
    } else {
      ids = concat_arr(ids, _collect_idents_in_expr(func))
    }
    for arg in node["args"] { ids = concat_arr(ids, _collect_idents_in_expr(arg)) }
    ret ids
  }

  if tag == "FieldAccess" { ret _collect_idents_in_expr(node["expr"]) }
  if tag == "Index" {
    ret concat_arr(_collect_idents_in_expr(node["expr"]), _collect_idents_in_expr(node["index"]))
  }

  if tag == "Array" {
    let mut ids = []
    for e in node["elems"] { ids = concat_arr(ids, _collect_idents_in_expr(e)) }
    ret ids
  }

  if tag == "MapLiteral" {
    let mut ids = []
    for e in node["entries"] { ids = concat_arr(ids, _collect_idents_in_expr(e["value"])) }
    ret ids
  }

  if tag == "Interpolation" {
    let mut ids = []
    for p in node["parts"] {
      if p["tag"] != "InterpLit" { ids = concat_arr(ids, _collect_idents_in_expr(p["expr"])) }
    }
    ret ids
  }

  if tag == "IfExpr" {
    ret concat_arr(_collect_idents_in_expr(node["cond"]),
      concat_arr(_collect_idents_in_expr(node["then"]), _collect_idents_in_expr(node["else"])))
  }

  if tag == "Pipe" {
    ret concat_arr(_collect_idents_in_expr(node["left"]), _collect_idents_in_expr(node["right"]))
  }

  if tag == "MatchExpr" {
    let mut ids = _collect_idents_in_expr(node["expr"])
    for arm in node["arms"] {
      if type_of(arm["guard"]) != "void" && arm["guard"]["tag"] != "Void" {
        ids = concat_arr(ids, _collect_idents_in_expr(arm["guard"]))
      }
      let body = arm["body"]
      if type_of(body["stmts"]) == "array" {
        ids = concat_arr(ids, _collect_idents_in_block(body))
      } else {
        ids = concat_arr(ids, _collect_idents_in_expr(body))
      }
    }
    ret ids
  }

  if tag == "Lambda" {
    ; lambdas capture, so we need to look inside but exclude lambda params
    let mut bound = []
    for p in node["params"] { bound = push(bound, p["name"]) }
    let body_ids = _collect_idents_in_block(node["body"])
    let mut free = []
    for id in body_ids {
      if !contains(bound, id) { if !contains(free, id) { free = push(free, id) } }
    }
    ret free
  }

  ret []
}

fn _collect_idents_in_block(block) -> [str] {
  if type_of(block["tag"]) == "str" {
    if block["tag"] == "BlockExpr" {
      ret _collect_idents_in_block(block["block"])
    }
  }
  let mut ids = []
  let stmts = block["stmts"]
  if type_of(stmts) != "array" { ret _collect_idents_in_expr(block) }
  for s in stmts { ids = concat_arr(ids, _collect_idents_in_stmt(s)) }
  ret ids
}

fn _collect_idents_in_stmt(s) -> [str] {
  let tag = s["tag"]
  if tag == "Let" { ret _collect_idents_in_expr(s["value"]) }
  if tag == "Assign" {
    ret concat_arr(_collect_idents_in_expr(s["target"]), _collect_idents_in_expr(s["value"]))
  }
  if tag == "Return" {
    if type_of(s["expr"]) != "void" { ret _collect_idents_in_expr(s["expr"]) }
    ret []
  }
  if tag == "ExprStmt" { ret _collect_idents_in_expr(s["expr"]) }
  if tag == "If" {
    let mut ids = _collect_idents_in_expr(s["cond"])
    ids = concat_arr(ids, _collect_idents_in_block(s["then"]))
    let eb = s["else"]
    if type_of(eb) != "void" {
      if eb["tag"] == "ElseBlock" { ids = concat_arr(ids, _collect_idents_in_block(eb["block"])) }
      if eb["tag"] == "ElseIf" { ids = concat_arr(ids, _collect_idents_in_stmt(eb["stmt"])) }
    }
    ret ids
  }
  if tag == "While" {
    ret concat_arr(_collect_idents_in_expr(s["cond"]), _collect_idents_in_block(s["body"]))
  }
  if tag == "For" {
    ret concat_arr(_collect_idents_in_expr(s["iter"]), _collect_idents_in_block(s["body"]))
  }
  ret []
}

fn _compute_captures(lambda_node, enclosing_vars, bm) -> [str] {
  let mut bound = []
  for p in lambda_node["params"] { bound = push(bound, p["name"]) }
  let body = lambda_node["body"]
  let body_lets = _collect_lets_in_block(body)
  bound = concat_arr(bound, body_lets)

  let body_ids = _collect_idents_in_block(body)
  let mut captures = []
  for id in body_ids {
    if !contains(bound, id) && !map.has(bm, id) && contains(enclosing_vars, id) {
      if !contains(captures, id) { captures = push(captures, id) }
    }
  }
  ret captures
}

fn _collect_lets_in_block(block) -> [str] {
  if type_of(block["tag"]) == "str" {
    if block["tag"] == "BlockExpr" { ret _collect_lets_in_block(block["block"]) }
  }
  let mut names = []
  let stmts = block["stmts"]
  if type_of(stmts) != "array" { ret [] }
  for s in stmts {
    if s["tag"] == "Let" { names = push(names, s["name"]) }
  }
  ret names
}

; --- Expression emission ---
; Returns [code, li, [lifted_fns]]

fn emit_expr(node, bm, ctx, li) {
  let tag = node["tag"]

  if tag == "Int" { ret _R(str.concat("a_int(", str.concat(to_str(node["value"]), ")")), li) }
  if tag == "Float" { ret _R(str.concat("a_float(", str.concat(to_str(node["value"]), ")")), li) }
  if tag == "Bool" {
    if node["value"] { ret _R("a_bool(1)", li) }
    ret _R("a_bool(0)", li)
  }
  if tag == "Void" { ret _R("a_void()", li) }

  if tag == "String" {
    ret _R(str.concat("a_string(\"", str.concat(_escape_c_str(node["value"]), "\")")), li)
  }

  if tag == "Ident" {
    let name = node["name"]
    if name == "true" { ret _R("a_bool(1)", li) }
    if name == "false" { ret _R("a_bool(0)", li) }
    ret _R(_mangle(name), li)
  }

  if tag == "BinOp" {
    let op = node["op"]
    let lr = emit_expr(node["left"], bm, ctx, li)
    let rr = emit_expr(node["right"], bm, ctx, lr[1])
    let l = lr[0]
    let r = rr[0]
    li = rr[1]
    let lifted = concat_arr(lr[2], rr[2])
    let mut code = ""
    if op == "+" { code = str.concat("a_add(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == "-" && code == "" { code = str.concat("a_sub(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == "*" && code == "" { code = str.concat("a_mul(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == "/" && code == "" { code = str.concat("a_div(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == "%" && code == "" { code = str.concat("a_mod(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == "==" && code == "" { code = str.concat("a_eq(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == "!=" && code == "" { code = str.concat("a_neq(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == "<" && code == "" { code = str.concat("a_lt(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == ">" && code == "" { code = str.concat("a_gt(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == "<=" && code == "" { code = str.concat("a_lteq(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == ">=" && code == "" { code = str.concat("a_gteq(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == "&&" && code == "" { code = str.concat("a_and(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if op == "||" && code == "" { code = str.concat("a_or(", str.concat(l, str.concat(", ", str.concat(r, ")")))) }
    if code == "" { code = str.concat("/* unknown op: ", str.concat(op, " */a_void()")) }
    ret _RL(code, li, lifted)
  }

  if tag == "UnaryOp" {
    let ir = emit_expr(node["expr"], bm, ctx, li)
    if node["op"] == "!" { ret _RL(str.concat("a_not(", str.concat(ir[0], ")")), ir[1], ir[2]) }
    if node["op"] == "-" { ret _RL(str.concat("a_neg(", str.concat(ir[0], ")")), ir[1], ir[2]) }
    ret ir
  }

  if tag == "Call" {
    let func = node["func"]
    let a = node["args"]
    let fname = _resolve_call_name(func)

    if fname == "fail" {
      if len(a) > 0 {
        let ar = emit_expr(a[0], bm, ctx, li)
        ret _RL(str.concat("(a_fail(", str.concat(ar[0], "), a_void())")), ar[1], ar[2])
      }
      ret _R("(a_fail(a_string(\"assertion failed\")), a_void())", li)
    }
    if fname == "exit" {
      if len(a) > 0 {
        let ar = emit_expr(a[0], bm, ctx, li)
        ret _RL(str.concat("(exit((int)", str.concat(ar[0], ".ival), a_void())")), ar[1], ar[2])
      }
      ret _R("(exit(0), a_void())", li)
    }

    ; Emit args
    let mut arg_codes = []
    let mut lifted = []
    for arg in a {
      let ar = emit_expr(arg, bm, ctx, li)
      arg_codes = push(arg_codes, ar[0])
      li = ar[1]
      lifted = concat_arr(lifted, ar[2])
    }

    if map.has(bm, fname) {
      let cfn = bm[fname]
      ret _RL(str.concat(cfn, str.concat("(", str.concat(str.join(arg_codes, ", "), ")"))), li, lifted)
    }

    ; Check if this is a closure call (variable, not a known function)
    let all_fns = ctx["fns"]
    let is_known_fn = false
    if type_of(all_fns) == "array" { is_known_fn = contains(all_fns, fname) }
    if str.contains(fname, ".") { is_known_fn = true }

    if func["tag"] == "Ident" && !is_known_fn && !_is_intra_module_call(fname, ctx) {
      ; Closure call: a_closure_call(var, argc, arg1, arg2, ...)
      let mut call_args = [to_str(len(arg_codes))]
      call_args = concat_arr(call_args, arg_codes)
      ret _RL(str.concat("a_closure_call(", str.concat(_mangle(fname), str.concat(", ", str.concat(str.join(call_args, ", "), ")")))), li, lifted)
    }

    let mut mangled = ""
    let aliases = ctx["import_aliases"]
    if type_of(aliases) == "map" && map.has(aliases, fname) {
      mangled = str.concat("fn_", _mangle(aliases[fname]))
    } else if _is_intra_module_call(fname, ctx) {
      mangled = str.concat("fn_", _mangle(_prefixed_name(fname, ctx)))
    } else {
      mangled = str.concat("fn_", _mangle(fname))
    }
    ret _RL(str.concat(mangled, str.concat("(", str.concat(str.join(arg_codes, ", "), ")"))), li, lifted)
  }

  if tag == "FieldAccess" {
    let er = emit_expr(node["expr"], bm, ctx, li)
    let field = node["field"]
    ret _RL(str.concat("a_map_get(", str.concat(er[0], str.concat(", a_string(\"", str.concat(field, "\"))")))), er[1], er[2])
  }

  if tag == "Index" {
    let er = emit_expr(node["expr"], bm, ctx, li)
    let ir = emit_expr(node["index"], bm, ctx, er[1])
    ret _RL(str.concat("a_array_get(", str.concat(er[0], str.concat(", ", str.concat(ir[0], ")")))), ir[1], concat_arr(er[2], ir[2]))
  }

  if tag == "Array" {
    let elems = node["elems"]
    if len(elems) == 0 { ret _R("a_array_new(0)", li) }

    ; Check for spread elements
    let mut has_spread = false
    for e in elems { if e["tag"] == "Spread" { has_spread = true } }

    let mut lifted = []
    if has_spread {
      ; Build incrementally: start empty, push or concat
      let mut code = "a_array_new(0)"
      for e in elems {
        if e["tag"] == "Spread" {
          let er = emit_expr(e["expr"], bm, ctx, li)
          li = er[1]
          lifted = concat_arr(lifted, er[2])
          code = str.concat("a_concat_arr(", str.concat(code, str.concat(", ", str.concat(er[0], ")"))))
        } else {
          let er = emit_expr(e, bm, ctx, li)
          li = er[1]
          lifted = concat_arr(lifted, er[2])
          code = str.concat("a_array_push(", str.concat(code, str.concat(", ", str.concat(er[0], ")"))))
        }
      }
      ret _RL(code, li, lifted)
    }

    let mut parts = []
    for e in elems {
      let er = emit_expr(e, bm, ctx, li)
      parts = push(parts, er[0])
      li = er[1]
      lifted = concat_arr(lifted, er[2])
    }
    ret _RL(str.concat("a_array_new(", str.concat(to_str(len(elems)), str.concat(", ", str.concat(str.join(parts, ", "), ")")))), li, lifted)
  }

  if tag == "MapLiteral" {
    let entries = node["entries"]
    if len(entries) == 0 { ret _R("a_map_new(0)", li) }
    let mut parts = []
    let mut lifted = []
    for e in entries {
      let key_node = e["key"]
      let key_str = ""
      if key_node["tag"] == "String" { key_str = key_node["value"] }
      let vr = emit_expr(e["value"], bm, ctx, li)
      li = vr[1]
      lifted = concat_arr(lifted, vr[2])
      parts = push(parts, str.concat("\"", str.concat(_escape_c_str(key_str), str.concat("\", ", vr[0]))))
    }
    ret _RL(str.concat("a_map_new(", str.concat(to_str(len(entries)), str.concat(", ", str.concat(str.join(parts, ", "), ")")))), li, lifted)
  }

  if tag == "Interpolation" {
    let parts = node["parts"]
    let mut cparts = []
    let mut lifted = []
    for p in parts {
      if p["tag"] == "InterpLit" {
        cparts = push(cparts, str.concat("a_string(\"", str.concat(_escape_c_str(p["value"]), "\")")))
      } else {
        let er = emit_expr(p["expr"], bm, ctx, li)
        li = er[1]
        lifted = concat_arr(lifted, er[2])
        cparts = push(cparts, str.concat("a_to_str(", str.concat(er[0], ")")))
      }
    }
    ret _RL(str.concat("a_concat_n(", str.concat(to_str(len(cparts)), str.concat(", ", str.concat(str.join(cparts, ", "), ")")))), li, lifted)
  }

  if tag == "IfExpr" {
    let cr = emit_expr(node["cond"], bm, ctx, li)
    let tr = emit_expr(node["then"], bm, ctx, cr[1])
    let er = emit_expr(node["else"], bm, ctx, tr[1])
    let lifted = concat_arr(cr[2], concat_arr(tr[2], er[2]))
    ret _RL(str.concat("(a_truthy(", str.concat(cr[0], str.concat(") ? ", str.concat(tr[0], str.concat(" : ", str.concat(er[0], ")")))))), er[1], lifted)
  }

  if tag == "MatchExpr" {
    ret _emit_match_expr(node, bm, ctx, li)
  }

  if tag == "BlockExpr" {
    let stmts = node["block"]["stmts"]
    if len(stmts) > 0 {
      let last = stmts[len(stmts) - 1]
      if last["tag"] == "ExprStmt" {
        ret emit_expr(last["expr"], bm, ctx, li)
      }
      if last["tag"] == "Return" {
        if type_of(last["expr"]) != "void" {
          ret emit_expr(last["expr"], bm, ctx, li)
        }
      }
    }
    ret _R("a_void()", li)
  }

  ; --- Pipe: desugar to function call ---
  if tag == "Pipe" {
    let right = node["right"]
    if right["tag"] == "Call" {
      let new_args = concat_arr([node["left"]], right["args"])
      let new_call = #{"tag": "Call", "func": right["func"], "args": new_args}
      ret emit_expr(new_call, bm, ctx, li)
    }
    ; Pipe to a non-call: treat as closure call with one arg
    let lr = emit_expr(node["left"], bm, ctx, li)
    let rr = emit_expr(node["right"], bm, ctx, lr[1])
    let lifted = concat_arr(lr[2], rr[2])
    ret _RL(str.concat("a_closure_call(", str.concat(rr[0], str.concat(", 1, ", str.concat(lr[0], ")")))), rr[1], lifted)
  }

  ; --- Lambda: lift to top-level function, emit closure creation ---
  if tag == "Lambda" {
    let lambda_name = str.concat("__lambda_", to_str(li))
    let params = node["params"]
    let body = node["body"]

    ; Determine captures
    let enclosing_vars = ctx["enclosing_vars"]
    let mut captures = []
    if type_of(enclosing_vars) == "array" {
      captures = _compute_captures(node, enclosing_vars, bm)
    }

    ; Build lifted function body
    let mut fn_code = str.concat("AValue ", str.concat(lambda_name, "(AValue __env, int __argc, AValue* __argv) \{"))

    ; Load captures from env
    let mut ci = 0
    for cap in captures {
      fn_code = str.concat(fn_code, str.concat("\n    AValue ", str.concat(_mangle(cap), str.concat(" = a_array_get(__env, a_int(", str.concat(to_str(ci), "));")))))
      ci = ci + 1
    }

    ; Load params from argv
    let mut pi = 0
    for p in params {
      fn_code = str.concat(fn_code, str.concat("\n    AValue ", str.concat(_mangle(p["name"]), str.concat(" = __argv[", str.concat(to_str(pi), "];")))))
      pi = pi + 1
    }

    let next_li = li + 1
    let mut body_lifted = []

    ; Build lambda ctx with its own enclosing vars for nested lambdas
    let mut lambda_vars = []
    for cap in captures { lambda_vars = push(lambda_vars, cap) }
    for p in params { lambda_vars = push(lambda_vars, p["name"]) }

    ; Unwrap body: BlockExpr wraps a block, or body is an expression
    let body_tag = body["tag"]
    if body_tag == "BlockExpr" {
      let stmts = body["block"]["stmts"]

      ; Pre-declare body locals
      let body_vars = _collect_vars_in_stmts(stmts)
      let mut bound = []
      for cap in captures { bound = push(bound, _mangle(cap)) }
      for p in params { bound = push(bound, _mangle(p["name"])) }
      let mut decl_vars = []
      for v in body_vars {
        if !contains(bound, v) { if !contains(decl_vars, v) { decl_vars = push(decl_vars, v) } }
      }
      ; Add body-scoped lets to lambda_vars for nested lambda capture analysis
      let body_lets = _collect_lets_in_block(body["block"])
      for bl in body_lets { lambda_vars = push(lambda_vars, bl) }
      let lambda_ctx = map.set(ctx, "enclosing_vars", lambda_vars)

      if len(decl_vars) > 0 {
        let mut init_parts = []
        for v in decl_vars { init_parts = push(init_parts, str.concat(v, " = \{0\}")) }
        fn_code = str.concat(fn_code, str.concat("\n    AValue ", str.concat(str.join(init_parts, ", "), ";")))
      }

      let mut lambda_cleanup = []
      for cap in captures { lambda_cleanup = push(lambda_cleanup, _mangle(cap)) }
      lambda_cleanup = concat_arr(lambda_cleanup, decl_vars)
      lambda_ctx = map.set(lambda_ctx, "cleanup_vars", lambda_cleanup)
      lambda_ctx = map.set(lambda_ctx, "goto_cleanup", false)

      ; Emit body, making the last ExprStmt an implicit return
      let mut has_return = false
      let mut si = 0
      while si < len(stmts) {
        let s = stmts[si]
        let is_last = si == len(stmts) - 1
        if is_last && s["tag"] == "ExprStmt" {
          let er = emit_expr(s["expr"], bm, lambda_ctx, next_li)
          let cleanup = _emit_cleanup(lambda_cleanup, 1)
          fn_code = str.concat(fn_code, str.concat("\n    \{ AValue __ret = ", str.concat(er[0], str.concat(";", str.concat(cleanup, "\n    return __ret; \}")))))
          next_li = er[1]
          body_lifted = concat_arr(body_lifted, er[2])
          has_return = true
        } else {
          let sr = emit_stmt(s, 1, bm, lambda_ctx, next_li)
          fn_code = str.concat(fn_code, str.concat("\n", sr[0]))
          next_li = sr[1]
          body_lifted = concat_arr(body_lifted, sr[2])
          if is_last && s["tag"] == "Return" { has_return = true }
        }
        si = si + 1
      }
      if !has_return {
        let cleanup = _emit_cleanup(lambda_cleanup, 1)
        fn_code = str.concat(fn_code, str.concat(cleanup, "\n    return a_void();"))
      }
    } else {
      ; Expression-body lambda: fn(x) => expr
      let lambda_ctx = map.set(ctx, "enclosing_vars", lambda_vars)
      let mut lambda_cleanup = []
      for cap in captures { lambda_cleanup = push(lambda_cleanup, _mangle(cap)) }
      lambda_ctx = map.set(lambda_ctx, "cleanup_vars", lambda_cleanup)
      lambda_ctx = map.set(lambda_ctx, "goto_cleanup", false)
      let er = emit_expr(body, bm, lambda_ctx, next_li)
      let cleanup = _emit_cleanup(lambda_cleanup, 1)
      fn_code = str.concat(fn_code, str.concat("\n    \{ AValue __ret = ", str.concat(er[0], str.concat(";", str.concat(cleanup, "\n    return __ret; \}")))))
      next_li = er[1]
      body_lifted = concat_arr(body_lifted, er[2])
    }
    fn_code = str.concat(fn_code, "\n\}\n")

    ; Emit closure creation at the expression site
    let mut env_code = "a_void()"
    if len(captures) > 0 {
      let mut cap_parts = []
      for cap in captures { cap_parts = push(cap_parts, str.concat("a_retain(", str.concat(_mangle(cap), ")"))) }
      env_code = str.concat("a_array_new(", str.concat(to_str(len(captures)), str.concat(", ", str.concat(str.join(cap_parts, ", "), ")"))))
    }
    let closure_code = str.concat("a_closure(", str.concat(lambda_name, str.concat(", ", str.concat(env_code, ")"))))

    let all_lifted = concat_arr(body_lifted, [fn_code])
    ret _RL(closure_code, next_li, all_lifted)
  }

  ; --- Try: expr? or try expr ---
  if tag == "Try" {
    let er = emit_expr(node["expr"], bm, ctx, li)
    ret _RL(str.concat("a_try_unwrap(", str.concat(er[0], ")")), er[1], er[2])
  }

  ; --- TryBlock: try { block } ---
  if tag == "TryBlock" {
    ; TryBlock is an expression that returns a Result.
    ; We use setjmp/longjmp via the runtime try stack.
    ; This produces a statement-expression using GCC ({...}) extension,
    ; but for portability we use a temp variable approach.
    ; The caller wraps this in an assignment: result = <try_block_code>;
    ; We emit a helper: a block that sets __try_result, then use __try_result as the value.
    ; However, since this is an expression context, we need a GCC statement-expression.
    let block = node["block"]
    let stmts = block["stmts"]
    let nl = _newline_char()
    let mut code = str.concat("(\{", nl)
    code = str.concat(code, str.concat("        AValue __try_result;", nl))
    ; Pre-declare variables used inside the try block
    let try_vars = _collect_vars_in_stmts(stmts)
    if len(try_vars) > 0 {
      code = str.concat(code, str.concat("        AValue ", str.concat(str.join(try_vars, ", "), str.concat(";", nl))))
    }
    code = str.concat(code, str.concat("        a_try_depth++;", nl))
    code = str.concat(code, str.concat("        if (setjmp(a_try_stack[a_try_depth - 1]) == 0) \{", nl))

    let mut lifted = []
    let nstmts = len(stmts)
    let has_tail = nstmts > 0 && stmts[nstmts - 1]["tag"] == "ExprStmt"
    if has_tail {
      code = str.concat(code, str.concat("        AValue __try_tail = a_void();", nl))
    }
    let mut si = 0
    while si < nstmts {
      let s = stmts[si]
      let is_last = si == nstmts - 1
      if is_last && has_tail {
        let er = emit_expr(s["expr"], bm, ctx, li)
        code = str.concat(code, str.concat("            __try_tail = ", str.concat(er[0], str.concat(";", nl))))
        li = er[1]
        lifted = concat_arr(lifted, er[2])
      } else {
        let sr = emit_stmt(s, 3, bm, ctx, li)
        code = str.concat(code, str.concat(sr[0], nl))
        li = sr[1]
        lifted = concat_arr(lifted, sr[2])
      }
      si = si + 1
    }

    code = str.concat(code, str.concat("            a_try_depth--;", nl))
    if has_tail {
      code = str.concat(code, str.concat("            __try_result = a_ok(__try_tail);", nl))
    } else {
      code = str.concat(code, str.concat("            __try_result = a_ok(a_void());", nl))
    }
    code = str.concat(code, str.concat("        \} else \{", nl))
    code = str.concat(code, str.concat("            a_try_depth--;", nl))
    code = str.concat(code, str.concat("            __try_result = a_err(a_try_err);", nl))
    code = str.concat(code, str.concat("        \}", nl))
    code = str.concat(code, str.concat("        __try_result;", nl))
    code = str.concat(code, "    \})")

    ret _RL(code, li, lifted)
  }

  ret _R(str.concat("/* unhandled expr: ", str.concat(tag, " */a_void()")), li)
}

fn _resolve_call_name(func) -> str {
  if func["tag"] == "Ident" { ret func["name"] }
  if func["tag"] == "FieldAccess" {
    let obj = func["expr"]
    if obj["tag"] == "Ident" {
      ret str.concat(obj["name"], str.concat(".", func["field"]))
    }
  }
  ret "__unknown__"
}

; --- Pattern matching emission ---
; _emit_pat_cond: returns [cond_code, li, lifted] where cond_code is a C boolean expr
; _emit_pat_bind: returns [bind_code, li, lifted] where bind_code is C statements

fn _emit_pat_cond(pat, target, bm, ctx, li) {
  let tag = pat["tag"]
  if tag == "PatWildcard" { ret _R("1", li) }
  if tag == "PatIdent" { ret _R("1", li) }

  if tag == "PatLiteral" {
    let val = pat["value"]
    let vr = emit_expr(val, bm, ctx, li)
    ret _RL(str.concat("a_truthy(a_eq(", str.concat(target, str.concat(", ", str.concat(vr[0], "))")))), vr[1], vr[2])
  }

  if tag == "PatConstructor" {
    let name = pat["name"]
    if name == "Ok" { ret _R(str.concat("a_is_ok_raw(", str.concat(target, ")")), li) }
    if name == "Err" { ret _R(str.concat("a_is_err_raw(", str.concat(target, ")")), li) }
    ret _R("0 /* unknown constructor */", li)
  }

  if tag == "PatArray" {
    let elems = pat["elems"]
    let mut has_rest = false
    let mut fixed_count = 0
    for e in elems {
      if e["tag"] == "PatRest" { has_rest = true }
      if e["tag"] == "PatElem" { fixed_count = fixed_count + 1 }
    }
    let mut cond = ""
    if has_rest {
      cond = str.concat("a_is_array_min_len(", str.concat(target, str.concat(", ", str.concat(to_str(fixed_count), ")"))))
    } else {
      cond = str.concat("a_is_array_of_len(", str.concat(target, str.concat(", ", str.concat(to_str(fixed_count), ")"))))
    }
    ; Add nested element conditions
    let mut idx = 0
    let mut lifted = []
    for e in elems {
      if e["tag"] == "PatElem" {
        let sub = e["pattern"]
        if sub["tag"] != "PatIdent" && sub["tag"] != "PatWildcard" {
          let elem_var = str.concat(target, str.concat(".aval->items[", str.concat(to_str(idx), "]")))
          let sc = _emit_pat_cond(sub, elem_var, bm, ctx, li)
          li = sc[1]
          lifted = concat_arr(lifted, sc[2])
          cond = str.concat(cond, str.concat(" && ", sc[0]))
        }
        idx = idx + 1
      }
    }
    ret _RL(cond, li, lifted)
  }

  if tag == "PatMap" {
    let entries = pat["entries"]
    let mut cond = str.concat(target, ".tag == TAG_MAP")
    let mut lifted = []
    for e in entries {
      let key = e["key"]
      cond = str.concat(cond, str.concat(" && a_is_map_with(", str.concat(target, str.concat(", \"", str.concat(_escape_c_str(key), "\")")))))
      ; Add nested value conditions
      let sub = e["pattern"]
      if sub["tag"] != "PatIdent" && sub["tag"] != "PatWildcard" {
        let val_expr = str.concat("a_map_get(", str.concat(target, str.concat(", a_string(\"", str.concat(_escape_c_str(key), "\"))"))))
        let sc = _emit_pat_cond(sub, val_expr, bm, ctx, li)
        li = sc[1]
        lifted = concat_arr(lifted, sc[2])
        cond = str.concat(cond, str.concat(" && ", sc[0]))
      }
    }
    ret _RL(cond, li, lifted)
  }

  ret _R("0 /* unknown pattern */", li)
}

fn _emit_pat_bind(pat, target, depth, bm, ctx, li) {
  let tag = pat["tag"]
  let ind = _indent(depth)

  if tag == "PatWildcard" { ret _R("", li) }

  if tag == "PatIdent" {
    ret _R(str.concat(ind, str.concat(_mangle(pat["name"]), str.concat(" = ", str.concat(target, ";")))), li)
  }

  if tag == "PatLiteral" { ret _R("", li) }

  if tag == "PatConstructor" {
    let name = pat["name"]
    let args = pat["args"]
    let mut code = ""
    if (name == "Ok" || name == "Err") && len(args) > 0 {
      let inner = args[0]
      let inner_expr = str.concat("a_unwrap_unsafe(", str.concat(target, ")"))
      let br = _emit_pat_bind(inner, inner_expr, depth, bm, ctx, li)
      code = br[0]
      li = br[1]
    }
    ret _R(code, li)
  }

  if tag == "PatArray" {
    let elems = pat["elems"]
    let mut code = ""
    let mut idx = 0
    let mut lifted = []
    for e in elems {
      if e["tag"] == "PatElem" {
        let elem_var = str.concat(target, str.concat(".aval->items[", str.concat(to_str(idx), "]")))
        let br = _emit_pat_bind(e["pattern"], elem_var, depth, bm, ctx, li)
        if len(br[0]) > 0 {
          if len(code) > 0 { code = str.concat(code, "\n") }
          code = str.concat(code, br[0])
        }
        li = br[1]
        lifted = concat_arr(lifted, br[2])
        idx = idx + 1
      }
      if e["tag"] == "PatRest" {
        let rest_expr = str.concat("a_drop(", str.concat(target, str.concat(", a_int(", str.concat(to_str(idx), "))"))))
        if len(code) > 0 { code = str.concat(code, "\n") }
        code = str.concat(code, str.concat(ind, str.concat(_mangle(e["name"]), str.concat(" = ", str.concat(rest_expr, ";")))))
      }
    }
    ret _RL(code, li, lifted)
  }

  if tag == "PatMap" {
    let entries = pat["entries"]
    let mut code = ""
    let mut lifted = []
    for e in entries {
      let key = e["key"]
      let val_expr = str.concat("a_map_get(", str.concat(target, str.concat(", a_string(\"", str.concat(_escape_c_str(key), "\"))"))))
      let br = _emit_pat_bind(e["pattern"], val_expr, depth, bm, ctx, li)
      if len(br[0]) > 0 {
        if len(code) > 0 { code = str.concat(code, "\n") }
        code = str.concat(code, br[0])
      }
      li = br[1]
      lifted = concat_arr(lifted, br[2])
    }
    ret _RL(code, li, lifted)
  }

  ret _R("", li)
}

fn _emit_arm_body(body, depth, bm, ctx, li) {
  let mut code = ""
  let mut lifted = []
  if type_of(body["stmts"]) == "array" {
    for s in body["stmts"] {
      let sr = emit_stmt(s, depth, bm, ctx, li)
      if len(code) > 0 { code = str.concat(code, "\n") }
      code = str.concat(code, sr[0])
      li = sr[1]
      lifted = concat_arr(lifted, sr[2])
    }
  } else {
    ; Single expression body -- emit as expression statement
    let er = emit_expr(body, bm, ctx, li)
    li = er[1]
    lifted = concat_arr(lifted, er[2])
    code = str.concat(_indent(depth), str.concat(er[0], ";"))
  }
  ret _RL(code, li, lifted)
}

fn _emit_match(node, depth, bm, ctx, li) {
  let ind = _indent(depth)
  let d1 = _indent(depth + 1)
  let d2 = _indent(depth + 2)
  let er = emit_expr(node["expr"], bm, ctx, li)
  li = er[1]
  let mut lifted = er[2]
  let arms = node["arms"]

  let mut out = str.concat(ind, "\{")
  out = str.concat(out, str.concat("\n", str.concat(d1, str.concat("AValue __match = ", str.concat(er[0], ";")))))
  out = str.concat(out, str.concat("\n", str.concat(d1, "int __matched = 0;")))

  for arm in arms {
    let pat = arm["pattern"]
    let guard = arm["guard"]
    let body = arm["body"]

    let cr = _emit_pat_cond(pat, "__match", bm, ctx, li)
    li = cr[1]
    lifted = concat_arr(lifted, cr[2])

    let mut has_guard = type_of(guard) != "void"
    if has_guard { if guard["tag"] == "Void" { has_guard = false } }

    out = str.concat(out, str.concat("\n", str.concat(d1, str.concat("if (!__matched && ", str.concat(cr[0], ") \{")))))

    ; Emit bindings
    let br = _emit_pat_bind(pat, "__match", depth + 2, bm, ctx, li)
    li = br[1]
    lifted = concat_arr(lifted, br[2])
    if len(br[0]) > 0 {
      out = str.concat(out, str.concat("\n", br[0]))
    }

    if has_guard {
      let gr = emit_expr(guard, bm, ctx, li)
      li = gr[1]
      lifted = concat_arr(lifted, gr[2])
      out = str.concat(out, str.concat("\n", str.concat(d2, str.concat("if (a_truthy(", str.concat(gr[0], ")) \{")))))

      let br2 = _emit_arm_body(body, depth + 3, bm, ctx, li)
      li = br2[1]
      lifted = concat_arr(lifted, br2[2])
      if len(br2[0]) > 0 { out = str.concat(out, str.concat("\n", br2[0])) }
      out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 3), "__matched = 1;")))

      out = str.concat(out, str.concat("\n", str.concat(d2, "\}")))
    } else {
      let br2 = _emit_arm_body(body, depth + 2, bm, ctx, li)
      li = br2[1]
      lifted = concat_arr(lifted, br2[2])
      if len(br2[0]) > 0 { out = str.concat(out, str.concat("\n", br2[0])) }
      out = str.concat(out, str.concat("\n", str.concat(d2, "__matched = 1;")))
    }

    out = str.concat(out, str.concat("\n", str.concat(d1, "\}")))
  }

  out = str.concat(out, str.concat("\n", str.concat(ind, "\}")))
  ret _RL(out, li, lifted)
}

fn _emit_match_expr(node, bm, ctx, li) {
  let nl = _newline_char()
  let er = emit_expr(node["expr"], bm, ctx, li)
  li = er[1]
  let mut lifted = er[2]
  let arms = node["arms"]

  let mut code = str.concat("(\{", nl)
  code = str.concat(code, str.concat("        AValue __match = ", str.concat(er[0], str.concat(";", nl))))
  code = str.concat(code, str.concat("        AValue __match_result = a_void();", nl))
  code = str.concat(code, str.concat("        int __matched = 0;", nl))

  ; Pre-declare arm variables
  let mut arm_vars = []
  for arm in arms {
    let pv = _collect_pattern_vars(arm["pattern"])
    for v in pv { if !contains(arm_vars, v) { arm_vars = push(arm_vars, v) } }
  }
  if len(arm_vars) > 0 {
    code = str.concat(code, str.concat("        AValue ", str.concat(str.join(arm_vars, ", "), str.concat(";", nl))))
  }

  for arm in arms {
    let pat = arm["pattern"]
    let guard = arm["guard"]
    let body = arm["body"]

    let cr = _emit_pat_cond(pat, "__match", bm, ctx, li)
    li = cr[1]
    lifted = concat_arr(lifted, cr[2])

    let mut has_guard = type_of(guard) != "void"
    if has_guard { if guard["tag"] == "Void" { has_guard = false } }

    code = str.concat(code, str.concat("        if (!__matched && ", str.concat(cr[0], str.concat(") \{", nl))))

    let br = _emit_pat_bind(pat, "__match", 3, bm, ctx, li)
    li = br[1]
    lifted = concat_arr(lifted, br[2])
    if len(br[0]) > 0 {
      code = str.concat(code, str.concat(br[0], nl))
    }

    if has_guard {
      let gr = emit_expr(guard, bm, ctx, li)
      li = gr[1]
      lifted = concat_arr(lifted, gr[2])
      code = str.concat(code, str.concat("            if (a_truthy(", str.concat(gr[0], str.concat(")) \{", nl))))

      let body_r = _emit_match_expr_body(body, bm, ctx, li)
      li = body_r[1]
      lifted = concat_arr(lifted, body_r[2])
      code = str.concat(code, str.concat("                __match_result = ", str.concat(body_r[0], str.concat(";", nl))))
      code = str.concat(code, str.concat("                __matched = 1;", nl))
      code = str.concat(code, str.concat("            \}", nl))
    } else {
      let body_r = _emit_match_expr_body(body, bm, ctx, li)
      li = body_r[1]
      lifted = concat_arr(lifted, body_r[2])
      code = str.concat(code, str.concat("            __match_result = ", str.concat(body_r[0], str.concat(";", nl))))
      code = str.concat(code, str.concat("            __matched = 1;", nl))
    }

    code = str.concat(code, str.concat("        \}", nl))
  }

  code = str.concat(code, str.concat("        __match_result;", nl))
  code = str.concat(code, "    \})")

  ret _RL(code, li, lifted)
}

fn _emit_match_expr_body(body, bm, ctx, li) {
  let mut lifted = []
  if type_of(body["stmts"]) == "array" {
    ; Block body -- emit all statements, then the last expression
    let stmts = body["stmts"]
    if len(stmts) == 0 { ret _R("a_void()", li) }
    let last = stmts[len(stmts) - 1]
    let nl = _newline_char()
    let mut preamble = ""
    let mut i = 0
    while i < len(stmts) - 1 {
      let sr = emit_stmt(stmts[i], 4, bm, ctx, li)
      preamble = str.concat(preamble, str.concat(sr[0], nl))
      li = sr[1]
      lifted = concat_arr(lifted, sr[2])
      i = i + 1
    }
    ; Last stmt is the value
    if last["tag"] == "ExprStmt" {
      let er = emit_expr(last["expr"], bm, ctx, li)
      if len(preamble) > 0 {
        ret _RL(str.concat("(\{", str.concat(nl, str.concat(preamble, str.concat("                ", str.concat(er[0], str.concat(";", str.concat(nl, "            \})"))))))), er[1], concat_arr(lifted, er[2]))
      }
      ret _RL(er[0], er[1], concat_arr(lifted, er[2]))
    }
    if last["tag"] == "Return" {
      if type_of(last["expr"]) != "void" {
        let er = emit_expr(last["expr"], bm, ctx, li)
        if len(preamble) > 0 {
          ret _RL(str.concat("(\{", str.concat(nl, str.concat(preamble, str.concat("                ", str.concat(er[0], str.concat(";", str.concat(nl, "            \})"))))))), er[1], concat_arr(lifted, er[2]))
        }
        ret _RL(er[0], er[1], concat_arr(lifted, er[2]))
      }
    }
    ret _R("a_void()", li)
  }
  ; Single expression body
  ret emit_expr(body, bm, ctx, li)
}

; --- Statement emission ---
; Returns [code, li, [lifted_fns]]

fn emit_stmt(node, depth: int, bm, ctx, li) {
  let tag = node["tag"]
  let ind = _indent(depth)

  if tag == "Let" {
    let vr = emit_expr(node["value"], bm, ctx, li)
    let vname = _mangle(node["name"])
    let assign_expr = vr[0]
    let mut code = ""
    if _is_ident(node["value"]) {
      code = str.concat(ind, str.concat("\{ AValue __old = ", str.concat(vname, str.concat("; ", str.concat(vname, str.concat(" = a_retain(", str.concat(assign_expr, "); a_release(__old); \}")))))))
    } else {
      code = str.concat(ind, str.concat("\{ AValue __old = ", str.concat(vname, str.concat("; ", str.concat(vname, str.concat(" = ", str.concat(assign_expr, "; a_release(__old); \}")))))))
    }
    ret _RL(code, vr[1], vr[2])
  }

  if tag == "LetDestructure" {
    let vr = emit_expr(node["value"], bm, ctx, li)
    let mut code = str.concat(ind, str.concat("__dest = ", str.concat(vr[0], ";")))
    let bindings = node["bindings"]
    let mut i = 0
    for b in bindings {
      if b != "" && b != "_" {
        code = str.concat(code, str.concat("\n", str.concat(ind, str.concat(_mangle(b), str.concat(" = a_array_get(__dest, a_int(", str.concat(to_str(i), "));"))))))
      }
      i = i + 1
    }
    let rest_name = node["rest"]
    if rest_name != "" {
      code = str.concat(code, str.concat("\n", str.concat(ind, str.concat(_mangle(rest_name), str.concat(" = a_drop(__dest, a_int(", str.concat(to_str(len(bindings)), "));"))))))
    }
    ret _RL(code, vr[1], vr[2])
  }

  if tag == "Assign" {
    let target = node["target"]
    if target["tag"] == "Ident" {
      let vr = emit_expr(node["value"], bm, ctx, li)
      let tname = _mangle(target["name"])
      let assign_expr = vr[0]
      let mut code = ""
      if _is_ident(node["value"]) {
        code = str.concat(ind, str.concat("\{ AValue __old = ", str.concat(tname, str.concat("; ", str.concat(tname, str.concat(" = a_retain(", str.concat(assign_expr, "); a_release(__old); \}")))))))
      } else {
        code = str.concat(ind, str.concat("\{ AValue __old = ", str.concat(tname, str.concat("; ", str.concat(tname, str.concat(" = ", str.concat(assign_expr, "; a_release(__old); \}")))))))
      }
      ret _RL(code, vr[1], vr[2])
    }
    if target["tag"] == "Index" {
      let vr = emit_expr(node["value"], bm, ctx, li)
      let tr = emit_expr(target["expr"], bm, ctx, vr[1])
      let ir = emit_expr(target["index"], bm, ctx, tr[1])
      ret _RL(str.concat(ind, str.concat(tr[0], str.concat(" = a_index_set(", str.concat(tr[0], str.concat(", ", str.concat(ir[0], str.concat(", ", str.concat(vr[0], ");")))))))), ir[1], concat_arr(vr[2], concat_arr(tr[2], ir[2])))
    }
    let vr = emit_expr(node["value"], bm, ctx, li)
    let tr = emit_expr(target, bm, ctx, vr[1])
    ret _RL(str.concat(ind, str.concat(tr[0], str.concat(" = ", str.concat(vr[0], ";")))), tr[1], concat_arr(vr[2], tr[2]))
  }

  if tag == "Return" {
    let use_goto = type_of(ctx["goto_cleanup"]) == "bool" && ctx["goto_cleanup"]
    let cleanup_vars = ctx["cleanup_vars"]
    let has_cleanup = type_of(cleanup_vars) == "array" && len(cleanup_vars) > 0
    if type_of(node["expr"]) == "void" {
      if use_goto {
        ret _R(str.concat(ind, "goto __fn_cleanup;"), li)
      }
      if has_cleanup {
        let cleanup = _emit_cleanup(cleanup_vars, depth)
        ret _R(str.concat(ind, str.concat("\{", str.concat(cleanup, str.concat("\n", str.concat(ind, "return a_void(); \}"))))), li)
      }
      ret _R(str.concat(ind, "return a_void();"), li)
    }
    let vr = emit_expr(node["expr"], bm, ctx, li)
    if use_goto {
      let val_expr = vr[0]
      if _is_ident(node["expr"]) {
        val_expr = str.concat("a_retain(", str.concat(vr[0], ")"))
      }
      ret _RL(str.concat(ind, str.concat("__ret = ", str.concat(val_expr, "; goto __fn_cleanup;"))), vr[1], vr[2])
    }
    if has_cleanup {
      let val_expr = vr[0]
      let ret_expr = val_expr
      if _is_ident(node["expr"]) {
        ret_expr = str.concat("a_retain(", str.concat(val_expr, ")"))
      }
      let cleanup = _emit_cleanup(cleanup_vars, depth)
      let code = str.concat(ind, str.concat("\{ AValue __ret = ", str.concat(ret_expr, str.concat(";", str.concat(cleanup, str.concat("\n", str.concat(ind, "return __ret; \}")))))))
      ret _RL(code, vr[1], vr[2])
    }
    ret _RL(str.concat(ind, str.concat("return ", str.concat(vr[0], ";"))), vr[1], vr[2])
  }

  if tag == "ExprStmt" {
    let er = emit_expr(node["expr"], bm, ctx, li)
    ret _RL(str.concat(ind, str.concat(er[0], ";")), er[1], er[2])
  }

  if tag == "If" {
    let cr = emit_expr(node["cond"], bm, ctx, li)
    li = cr[1]
    let mut lifted = cr[2]
    let mut out = str.concat(ind, str.concat("if (a_truthy(", str.concat(cr[0], ")) \{")))
    let then_stmts = node["then"]["stmts"]
    for s in then_stmts {
      let sr = emit_stmt(s, depth + 1, bm, ctx, li)
      out = str.concat(out, str.concat("\n", sr[0]))
      li = sr[1]
      lifted = concat_arr(lifted, sr[2])
    }
    out = str.concat(out, str.concat("\n", str.concat(ind, "\}")))
    let else_branch = node["else"]
    if type_of(else_branch) != "void" {
      if else_branch["tag"] == "ElseBlock" {
        out = str.concat(out, " else \{")
        let else_stmts = else_branch["block"]["stmts"]
        for s in else_stmts {
          let sr = emit_stmt(s, depth + 1, bm, ctx, li)
          out = str.concat(out, str.concat("\n", sr[0]))
          li = sr[1]
          lifted = concat_arr(lifted, sr[2])
        }
        out = str.concat(out, str.concat("\n", str.concat(ind, "\}")))
      }
      if else_branch["tag"] == "ElseIf" {
        let sr = emit_stmt(else_branch["stmt"], depth, bm, ctx, li)
        out = str.concat(out, str.concat(" else ", sr[0]))
        li = sr[1]
        lifted = concat_arr(lifted, sr[2])
      }
    }
    ret _RL(out, li, lifted)
  }

  if tag == "While" {
    let cr = emit_expr(node["cond"], bm, ctx, li)
    li = cr[1]
    let mut lifted = cr[2]
    let mut out = str.concat(ind, str.concat("while (a_truthy(", str.concat(cr[0], ")) \{")))
    let body_stmts = node["body"]["stmts"]
    for s in body_stmts {
      let sr = emit_stmt(s, depth + 1, bm, ctx, li)
      out = str.concat(out, str.concat("\n", sr[0]))
      li = sr[1]
      lifted = concat_arr(lifted, sr[2])
    }
    out = str.concat(out, str.concat("\n", str.concat(ind, "\}")))
    ret _RL(out, li, lifted)
  }

  if tag == "For" {
    let var_name = _mangle(node["var"])
    let ir = emit_expr(node["iter"], bm, ctx, li)
    li = ir[1]
    let mut lifted = ir[2]
    let mut out = str.concat(ind, "\{")
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 1), str.concat("AValue __iter_arr = a_iterable(", str.concat(ir[0], ");")))))
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 1), "for (int __fi = 0; __fi < a_ilen(__iter_arr); __fi++) \{")))
    let mut body_vars = _collect_vars_in_stmts(node["body"]["stmts"])
    let mut for_decls = [var_name]
    for v in body_vars {
      if !contains(for_decls, v) { for_decls = push(for_decls, v) }
    }
    let mut init_parts = []
    for v in for_decls { init_parts = push(init_parts, str.concat(v, " = \{0\}")) }
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 2), str.concat("AValue ", str.concat(str.join(init_parts, ", "), ";")))))
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 2), str.concat(var_name, " = a_array_get(__iter_arr, a_int(__fi));"))))
    let body_stmts = node["body"]["stmts"]
    for s in body_stmts {
      let sr = emit_stmt(s, depth + 2, bm, ctx, li)
      out = str.concat(out, str.concat("\n", sr[0]))
      li = sr[1]
      lifted = concat_arr(lifted, sr[2])
    }
    let for_cleanup = _emit_cleanup(for_decls, depth + 2)
    out = str.concat(out, for_cleanup)
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 1), "\}")))
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 1), "a_release(__iter_arr);")))
    out = str.concat(out, str.concat("\n", str.concat(ind, "\}")))
    ret _RL(out, li, lifted)
  }

  if tag == "ForDestructure" {
    let bindings = node["bindings"]
    let ir = emit_expr(node["iter"], bm, ctx, li)
    li = ir[1]
    let mut lifted = ir[2]
    let mut out = str.concat(ind, "\{")
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 1), str.concat("AValue __iter_arr = a_iterable(", str.concat(ir[0], ");")))))
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 1), "for (int __fi = 0; __fi < a_ilen(__iter_arr); __fi++) \{")))
    ; Collect all variables to declare
    let mut decls = ["__elem"]
    for b in bindings { decls = push(decls, _mangle(b)) }
    let mut body_vars = _collect_vars_in_stmts(node["body"]["stmts"])
    for v in body_vars { if !contains(decls, v) { decls = push(decls, v) } }
    let mut init_parts = []
    for v in decls { init_parts = push(init_parts, str.concat(v, " = \{0\}")) }
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 2), str.concat("AValue ", str.concat(str.join(init_parts, ", "), ";")))))
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 2), "__elem = a_array_get(__iter_arr, a_int(__fi));")))
    let mut bi = 0
    for b in bindings {
      out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 2), str.concat(_mangle(b), str.concat(" = a_array_get(__elem, a_int(", str.concat(to_str(bi), "));"))))))
      bi = bi + 1
    }
    let body_stmts = node["body"]["stmts"]
    for s in body_stmts {
      let sr = emit_stmt(s, depth + 2, bm, ctx, li)
      out = str.concat(out, str.concat("\n", sr[0]))
      li = sr[1]
      lifted = concat_arr(lifted, sr[2])
    }
    let fd_cleanup = _emit_cleanup(decls, depth + 2)
    out = str.concat(out, fd_cleanup)
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 1), "\}")))
    out = str.concat(out, str.concat("\n", str.concat(_indent(depth + 1), "a_release(__iter_arr);")))
    out = str.concat(out, str.concat("\n", str.concat(ind, "\}")))
    ret _RL(out, li, lifted)
  }

  if tag == "Match" { ret _emit_match(node, depth, bm, ctx, li) }

  if tag == "Break" { ret _R(str.concat(ind, "break;"), li) }
  if tag == "Continue" { ret _R(str.concat(ind, "continue;"), li) }

  ret _R(str.concat(ind, str.concat("/* unhandled stmt: ", str.concat(tag, " */"))), li)
}

; --- Variable collection (for pre-declaration) ---

fn _collect_pattern_vars(pat) -> [str] {
  let tag = pat["tag"]
  if tag == "PatIdent" { ret [_mangle(pat["name"])] }
  if tag == "PatRest" { ret [_mangle(pat["name"])] }
  if tag == "PatWildcard" { ret [] }
  if tag == "PatLiteral" { ret [] }
  if tag == "PatConstructor" {
    let mut vs = []
    for a in pat["args"] { vs = concat_arr(vs, _collect_pattern_vars(a)) }
    ret vs
  }
  if tag == "PatArray" {
    let mut vs = []
    for e in pat["elems"] {
      if e["tag"] == "PatElem" { vs = concat_arr(vs, _collect_pattern_vars(e["pattern"])) }
      if e["tag"] == "PatRest" { vs = push(vs, _mangle(e["name"])) }
    }
    ret vs
  }
  if tag == "PatMap" {
    let mut vs = []
    for e in pat["entries"] { vs = concat_arr(vs, _collect_pattern_vars(e["pattern"])) }
    ret vs
  }
  ret []
}

fn _collect_vars_in_stmts(stmts) -> [str] {
  let mut vars = []
  for s in stmts {
    let tag = s["tag"]
    if tag == "Let" {
      let name = _mangle(s["name"])
      if !contains(vars, name) { vars = push(vars, name) }
    }
    if tag == "If" {
      let tv = _collect_vars_in_stmts(s["then"]["stmts"])
      for v in tv { if !contains(vars, v) { vars = push(vars, v) } }
      let eb = s["else"]
      if type_of(eb) != "void" {
        if eb["tag"] == "ElseBlock" {
          let ev = _collect_vars_in_stmts(eb["block"]["stmts"])
          for v in ev { if !contains(vars, v) { vars = push(vars, v) } }
        }
        if eb["tag"] == "ElseIf" {
          let eiv = _collect_vars_in_stmts([eb["stmt"]])
          for v in eiv { if !contains(vars, v) { vars = push(vars, v) } }
        }
      }
    }
    if tag == "While" {
      let wv = _collect_vars_in_stmts(s["body"]["stmts"])
      for v in wv { if !contains(vars, v) { vars = push(vars, v) } }
    }
    if tag == "For" {
      let fv = _collect_vars_in_stmts(s["body"]["stmts"])
      for v in fv { if !contains(vars, v) { vars = push(vars, v) } }
    }
    if tag == "LetDestructure" {
      if !contains(vars, "__dest") { vars = push(vars, "__dest") }
      for b in s["bindings"] {
        if b != "" && b != "_" {
          let name = _mangle(b)
          if !contains(vars, name) { vars = push(vars, name) }
        }
      }
      let rn = s["rest"]
      if rn != "" {
        let name = _mangle(rn)
        if !contains(vars, name) { vars = push(vars, name) }
      }
    }
    if tag == "ForDestructure" {
      let fv = _collect_vars_in_stmts(s["body"]["stmts"])
      for v in fv { if !contains(vars, v) { vars = push(vars, v) } }
    }
    if tag == "Match" {
      for arm in s["arms"] {
        let pv = _collect_pattern_vars(arm["pattern"])
        for v in pv { if !contains(vars, v) { vars = push(vars, v) } }
        let body = arm["body"]
        if type_of(body["stmts"]) == "array" {
          let bv = _collect_vars_in_stmts(body["stmts"])
          for v in bv { if !contains(vars, v) { vars = push(vars, v) } }
        }
      }
    }
  }
  ret vars
}

; --- Function emission ---

fn emit_fn(node, bm, ctx, li) {
  let name = node["name"]
  let full_name = _prefixed_name(name, ctx)
  let params = node["params"]
  let body = node["body"]

  let mut param_parts = []
  for p in params {
    param_parts = push(param_parts, str.concat("AValue ", _mangle(p["name"])))
  }
  let param_str = str.join(param_parts, ", ")
  if len(params) == 0 { param_str = "void" }

  let mut out = str.concat("AValue fn_", str.concat(_mangle(full_name), str.concat("(", str.concat(param_str, ") \{"))))

  ; Pre-declare all local variables
  let all_vars = _collect_vars_in_stmts(body["stmts"])
  let mut param_names = []
  for p in params { param_names = push(param_names, _mangle(p["name"])) }
  let mut decl_vars = []
  for v in all_vars {
    if !contains(param_names, v) {
      if !contains(decl_vars, v) { decl_vars = push(decl_vars, v) }
    }
  }
  if len(decl_vars) > 0 {
    let mut init_parts = []
    for v in decl_vars { init_parts = push(init_parts, str.concat(v, " = \{0\}")) }
    out = str.concat(out, str.concat("\n    AValue ", str.concat(str.join(init_parts, ", "), ";")))
  }
  out = str.concat(out, "\n    AValue __ret = a_void();")

  let all_cleanup_vars = decl_vars

  ; Build enclosing_vars for lambda capture analysis
  let mut enc_vars = []
  for p in params { enc_vars = push(enc_vars, p["name"]) }
  for v in all_vars { if !contains(enc_vars, _mangle(v)) { enc_vars = push(enc_vars, v) } }
  let fn_ctx = map.set(ctx, "enclosing_vars", enc_vars)
  fn_ctx = map.set(fn_ctx, "cleanup_vars", all_cleanup_vars)
  fn_ctx = map.set(fn_ctx, "goto_cleanup", true)

  ; Escape analysis result stored in context for Phase 4 arena allocation
  fn_ctx = map.set(fn_ctx, "escaping_vars", [])

  let mut lifted = []
  let stmts = body["stmts"]
  for s in stmts {
    let sr = emit_stmt(s, 1, bm, fn_ctx, li)
    out = str.concat(out, str.concat("\n", sr[0]))
    li = sr[1]
    lifted = concat_arr(lifted, sr[2])
  }

  out = str.concat(out, "\n__fn_cleanup:")
  let cleanup = _emit_cleanup(all_cleanup_vars, 1)
  out = str.concat(out, str.concat(cleanup, "\n    return __ret;"))

  out = str.concat(out, "\n\}\n")
  ret _RL(out, li, lifted)
}

fn _emit_fwd_decl(name, params) -> str {
  let mut param_parts = []
  for p in params {
    param_parts = push(param_parts, str.concat("AValue ", _mangle(p["name"])))
  }
  let param_str = str.join(param_parts, ", ")
  if len(params) == 0 { param_str = "void" }
  ret str.concat("AValue fn_", str.concat(_mangle(name), str.concat("(", str.concat(param_str, ");"))))
}

; --- Module loading ---

fn _use_path_to_file(path_arr) -> str {
  ret str.concat(str.join(path_arr, "/"), ".a")
}

fn _use_path_short_name(path_arr) -> str {
  ret path_arr[len(path_arr) - 1]
}

fn _collect_fn_names(items) -> [str] {
  let mut names = []
  for item in items {
    if item["tag"] == "FnDecl" {
      names = push(names, item["name"])
    }
  }
  ret names
}

fn _load_module(path_arr, bm, loaded, li) -> map {
  let use_key = str.join(path_arr, ".")
  if contains(loaded, use_key) {
    ret #{"fwd": [], "fns": [], "loaded": loaded, "li": li}
  }
  loaded = push(loaded, use_key)

  let file_path = _use_path_to_file(path_arr)
  let source = io.read_file(file_path)
  let mod_ast = parser.parse(source)
  let items = mod_ast["items"]
  let short = _use_path_short_name(path_arr)

  let mut all_fwd = []
  let mut all_fns = []

  for item in items {
    if item["tag"] == "UseDecl" {
      let sub = _load_module(item["path"], bm, loaded, li)
      loaded = sub["loaded"]
      li = sub["li"]
      all_fwd = concat_arr(all_fwd, sub["fwd"])
      all_fns = concat_arr(all_fns, sub["fns"])
    }
  }

  let fn_names = _collect_fn_names(items)
  let ctx = #{"prefix": short, "fns": fn_names}
  let mut aliases = #{}

  for item in items {
    if item["tag"] == "FnDecl" {
      let full_name = _prefixed_name(item["name"], ctx)
      all_fwd = push(all_fwd, _emit_fwd_decl(full_name, item["params"]))
      let fr = emit_fn(item, bm, ctx, li)
      li = fr[1]
      for lf in fr[2] { all_fns = push(all_fns, lf) }
      all_fns = push(all_fns, fr[0])
      aliases = map.set(aliases, item["name"], full_name)
    }
  }

  ret #{"fwd": all_fwd, "fns": all_fns, "loaded": loaded, "li": li, "aliases": aliases}
}

; --- FFI type mapping ---

fn _ffi_c_type(ty_node) -> str {
  let tag = ty_node["tag"]
  if tag == "TyPrim" {
    let name = ty_node["name"]
    if name == "i8" { ret "int8_t" }
    if name == "i16" { ret "int16_t" }
    if name == "i32" { ret "int32_t" }
    if name == "i64" { ret "int64_t" }
    if name == "u8" { ret "uint8_t" }
    if name == "u16" { ret "uint16_t" }
    if name == "u32" { ret "uint32_t" }
    if name == "u64" { ret "uint64_t" }
    if name == "f32" { ret "float" }
    if name == "f64" { ret "double" }
    if name == "bool" { ret "int" }
    if name == "str" { ret "const char*" }
    if name == "ptr" { ret "void*" }
    if name == "void" { ret "void" }
  }
  ret "AValue"
}

fn _ffi_extract(ty_node, var_name) -> str {
  let tag = ty_node["tag"]
  if tag == "TyPrim" {
    let name = ty_node["name"]
    if name == "i8" || name == "i16" || name == "i32" {
      ret str.concat("(", str.concat(_ffi_c_type(ty_node), str.concat(")", str.concat(var_name, ".ival"))))
    }
    if name == "i64" { ret str.concat(var_name, ".ival") }
    if name == "u8" || name == "u16" || name == "u32" || name == "u64" {
      ret str.concat("(", str.concat(_ffi_c_type(ty_node), str.concat(")", str.concat(var_name, ".ival"))))
    }
    if name == "f32" { ret str.concat("(float)", str.concat(var_name, ".fval")) }
    if name == "f64" { ret str.concat(var_name, ".fval") }
    if name == "bool" { ret str.concat(var_name, ".bval") }
    if name == "str" { ret str.concat(var_name, ".sval->data") }
    if name == "ptr" { ret str.concat(var_name, ".pval") }
  }
  ret var_name
}

fn _ffi_wrap(ty_node, expr) -> str {
  let tag = ty_node["tag"]
  if tag == "TyPrim" {
    let name = ty_node["name"]
    if name == "i8" || name == "i16" || name == "i32" || name == "i64" ||
       name == "u8" || name == "u16" || name == "u32" || name == "u64" {
      ret str.concat("a_int((int64_t)", str.concat(expr, ")"))
    }
    if name == "f32" || name == "f64" { ret str.concat("a_float((double)", str.concat(expr, ")")) }
    if name == "bool" { ret str.concat("a_bool(", str.concat(expr, ")")) }
    if name == "str" { ret str.concat("a_string(", str.concat(expr, ")")) }
    if name == "ptr" { ret str.concat("a_ptr(", str.concat(expr, ")")) }
    if name == "void" { ret "a_void()" }
  }
  ret expr
}

fn _emit_extern_fn(node) -> [str] {
  let name = node["name"]
  let params = node["params"]
  let ret_type = node["ret_type"]
  let c_ret = _ffi_c_type(ret_type)
  let is_void = c_ret == "void"

  ; Build raw C prototype: extern <c_ret> <name>(<c_param_types>);
  let mut c_param_parts = []
  for p in params {
    c_param_parts = push(c_param_parts, _ffi_c_type(p["type"]))
  }
  let c_param_str = str.join(c_param_parts, ", ")
  if len(params) == 0 { c_param_str = "void" }
  let raw_proto = str.concat("extern ", str.concat(c_ret, str.concat(" ", str.concat(name, str.concat("(", str.concat(c_param_str, ");"))))))

  ; Build AValue shim: AValue fn_<name>(AValue p0, ...) { ... }
  let mut shim_params = []
  let mut pi = 0
  while pi < len(params) {
    shim_params = push(shim_params, str.concat("AValue __p", to_str(pi)))
    pi = pi + 1
  }
  let shim_param_str = str.join(shim_params, ", ")
  if len(params) == 0 { shim_param_str = "void" }

  let mut shim = str.concat("AValue fn_", str.concat(_mangle(name), str.concat("(", str.concat(shim_param_str, ") \{\n"))))

  ; Extract arguments
  let mut call_args = []
  pi = 0
  while pi < len(params) {
    let p = params[pi]
    let extracted = _ffi_extract(p["type"], str.concat("__p", to_str(pi)))
    call_args = push(call_args, extracted)
    pi = pi + 1
  }

  ; Emit call
  let call_str = str.concat(name, str.concat("(", str.concat(str.join(call_args, ", "), ")")))
  if is_void {
    shim = str.concat(shim, str.concat("    ", str.concat(call_str, ";\n")))
    shim = str.concat(shim, "    return a_void();\n")
  } else {
    shim = str.concat(shim, str.concat("    ", str.concat(c_ret, str.concat(" __result = ", str.concat(call_str, ";\n")))))
    shim = str.concat(shim, str.concat("    return ", str.concat(_ffi_wrap(ret_type, "__result"), ";\n")))
  }
  shim = str.concat(shim, "\}\n")

  ; Forward declaration for the shim
  let fwd = str.concat("AValue fn_", str.concat(_mangle(name), str.concat("(", str.concat(shim_param_str, ");"))))

  ret [raw_proto, fwd, shim]
}

; --- Program emission ---

fn emit_program(prog_ast, bm) -> str {
  let items = prog_ast["items"]

  let mut all_fwd = []
  let mut all_fns = []
  let mut loaded = []
  let mut li = 0
  let mut import_aliases = #{}

  for item in items {
    if item["tag"] == "UseDecl" {
      let result = _load_module(item["path"], bm, loaded, li)
      loaded = result["loaded"]
      li = result["li"]
      all_fwd = concat_arr(all_fwd, result["fwd"])
      all_fns = concat_arr(all_fns, result["fns"])
      let al = result["aliases"]
      if type_of(al) == "map" {
        for [k, v] in al { import_aliases = map.set(import_aliases, k, v) }
      }
    }
  }

  let mut main_fn_names = _collect_fn_names(items)
  for [k, v] in import_aliases { main_fn_names = push(main_fn_names, k) }

  ; Collect extern fn names so call resolution treats them as known
  let mut extern_protos = []
  let mut extern_shims = []
  for item in items {
    if item["tag"] == "ExternFn" {
      main_fn_names = push(main_fn_names, item["name"])
      let parts = _emit_extern_fn(item)
      extern_protos = push(extern_protos, parts[0])
      all_fwd = push(all_fwd, parts[1])
      extern_shims = push(extern_shims, parts[2])
    }
  }

  let main_ctx = #{"prefix": "", "fns": main_fn_names, "import_aliases": import_aliases}

  for item in items {
    if item["tag"] == "FnDecl" {
      all_fwd = push(all_fwd, _emit_fwd_decl(item["name"], item["params"]))
      let fr = emit_fn(item, bm, main_ctx, li)
      li = fr[1]
      for lf in fr[2] { all_fns = push(all_fns, lf) }
      all_fns = push(all_fns, fr[0])
    }
  }

  let mut out = "#include \"runtime.h\"\n#include <stdlib.h>\n\n"

  ; Emit extern C prototypes
  if len(extern_protos) > 0 {
    out = str.concat(out, "/* FFI extern prototypes */\n")
    for p in extern_protos { out = str.concat(out, str.concat(p, "\n")) }
    out = str.concat(out, "\n")
  }

  ; Forward declarations for lifted lambdas
  let mut lambda_fwd = []
  let mut i = 0
  while i < li {
    lambda_fwd = push(lambda_fwd, str.concat("AValue __lambda_", str.concat(to_str(i), "(AValue __env, int __argc, AValue* __argv);")))
    i = i + 1
  }
  if len(lambda_fwd) > 0 {
    out = str.concat(out, "/* Lambda forward declarations */\n")
    for f in lambda_fwd { out = str.concat(out, str.concat(f, "\n")) }
    out = str.concat(out, "\n")
  }

  out = str.concat(out, "/* Forward declarations */\n")
  for f in all_fwd { out = str.concat(out, str.concat(f, "\n")) }
  out = str.concat(out, "\n")

  ; Emit FFI shim wrappers
  for s in extern_shims { out = str.concat(out, str.concat(s, "\n")) }

  for f in all_fns { out = str.concat(out, str.concat(f, "\n")) }

  out = str.concat(out, "int main(int argc, char** argv) \{\n")
  out = str.concat(out, "    g_argc = argc; g_argv = argv;\n")
  out = str.concat(out, "    fn_main();\n")
  out = str.concat(out, "    return 0;\n")
  out = str.concat(out, "\}\n")

  ret out
}

; --- Entry point ---

fn main() -> void effects [io] {
  let file_args = args()
  if len(file_args) == 0 {
    eprintln("usage: a run std/compiler/cgen.a -- <input.a>")
    exit(1)
  }
  let source = io.read_file(file_args[0])
  let prog_ast = parser.parse(source)
  let bm = _builtin_map()
  let c_code = emit_program(prog_ast, bm)
  print(c_code)
}
