; site_gen.a -- Minimal static site generator
; Demonstrates std.path, std.datetime, std.hash, std.csv, std.template, std.encoding

use std.path
use std.datetime
use std.hash
use std.csv
use std.template
use std.encoding

fn main() -> void effects [io] {
  let site_dir = "/tmp/a_site_gen"
  let build_dir = path.join(site_dir, "build")

  ; Setup: create site directory structure
  fs.mkdir(site_dir)
  fs.mkdir(build_dir)

  ; Create a CSV data file listing pages
  let pages_csv = csv.stringify([
    ["slug", "title", "body"],
    ["index", "Home", "Welcome to my site built with the a language."],
    ["about", "About", "This site was generated by an AI programming language."],
    ["contact", "Contact", "Reach us at hello@example.com"]
  ])
  io.write_file(path.join(site_dir, "pages.csv"), pages_csv)

  ; Create an HTML template (use raw strings for {{ }} delimiters)
  let tmpl = str.join([
    "<html>",
    r#"<head><title>{{title}}</title></head>"#,
    "<body>",
    r#"<nav>{{nav}}</nav>"#,
    r#"<h1>{{title}}</h1>"#,
    r#"<p>{{body}}</p>"#,
    "<footer>",
    r#"<p>Generated: {{generated}}</p>"#,
    r#"<p>Checksum: {{checksum}}</p>"#,
    "</footer>",
    "</body>",
    "</html>"
  ], "\n")
  io.write_file(path.join(site_dir, "template.html"), tmpl)

  ; Load and parse pages
  let pages_text = io.read_file(path.join(site_dir, "pages.csv"))
  let pages = csv.parse_records(pages_text)

  ; Build navigation
  let mut nav_parts = []
  for page in pages {
    let link = str.concat(str.concat("<a href=\"", str.concat(page["slug"], ".html")), str.concat("\">", str.concat(page["title"], "</a>")))
    nav_parts = push(nav_parts, link)
  }
  let nav_html = str.join(nav_parts, " | ")

  ; Load template from file
  let tmpl_content = io.read_file(path.join(site_dir, "template.html"))

  ; Generate each page
  let build_time = datetime.iso(datetime.now())
  let mut generated = 0
  for page in pages {
    let body_hash = hash.quick(page["body"])
    let vars = #{
      "title": page["title"],
      "body": page["body"],
      "nav": nav_html,
      "generated": build_time,
      "checksum": body_hash
    }
    let html = template.render(tmpl_content, vars)
    let out_path = path.join(build_dir, path.with_extension(page["slug"], "html"))
    io.write_file(out_path, html)
    generated = generated + 1
    let size = len(html)
    println("  wrote {out_path} ({size} bytes, checksum {body_hash})")
  }

  ; Generate a build manifest
  let manifest = #{
    "pages": generated,
    "timestamp": build_time,
    "generator": "a-lang site_gen v0.40"
  }
  io.write_file(path.join(build_dir, "manifest.json"), json.pretty(manifest))

  ; Summary
  println("")
  println("Built {generated} pages to {build_dir}")
  println("Build time: {build_time}")

  ; Demonstrate encoding: base64-encode the manifest
  let b64 = encoding.base64_encode(json.stringify(manifest))
  println("Manifest (base64): {b64}")

  ; Cleanup
  fs.rm(site_dir)
}
