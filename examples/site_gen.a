; site_gen.a -- Minimal static site generator
; Demonstrates std.path, std.datetime, std.hash, std.csv, std.template, std.encoding

use std.path
use std.datetime
use std.hash
use std.csv
use std.template
use std.encoding

fn _lb() -> str { ret from_code(123) }
fn _rb() -> str { ret from_code(125) }

; Build a template tag like {{key}} without literal braces in source
fn _tag(key) -> str {
  ret str.concat(_lb(), str.concat(_lb(), str.concat(key, str.concat(_rb(), _rb()))))
}

fn make_template() -> str {
  ret str.join([
    "<html>",
    str.concat("<head><title>", str.concat(_tag("title"), "</title></head>")),
    "<body>",
    str.concat("<nav>", str.concat(_tag("nav"), "</nav>")),
    str.concat("<h1>", str.concat(_tag("title"), "</h1>")),
    str.concat("<p>", str.concat(_tag("body"), "</p>")),
    "<footer>",
    str.concat("<p>Generated: ", str.concat(_tag("generated"), "</p>")),
    str.concat("<p>Checksum: ", str.concat(_tag("checksum"), "</p>")),
    "</footer>",
    "</body>",
    "</html>"
  ], "\n")
}

fn make_vars(page, nav_html, build_time) {
  let body_hash = hash.quick(page["body"])
  let mut v = #{}
  v = map.set(v, "title", page["title"])
  v = map.set(v, "body", page["body"])
  v = map.set(v, "nav", nav_html)
  v = map.set(v, "generated", build_time)
  v = map.set(v, "checksum", body_hash)
  ret v
}

fn main() -> void effects [io] {
  let site_dir = "/tmp/a_site_gen"
  let build_dir = path.join(site_dir, "build")

  fs.mkdir(site_dir)
  fs.mkdir(build_dir)

  let pages_csv = csv.stringify([
    ["slug", "title", "body"],
    ["index", "Home", "Welcome to my site built with the a language."],
    ["about", "About", "This site was generated by an AI programming language."],
    ["contact", "Contact", "Reach us at hello@example.com"]
  ])
  io.write_file(path.join(site_dir, "pages.csv"), pages_csv)

  let tmpl = make_template()
  io.write_file(path.join(site_dir, "template.html"), tmpl)

  let pages_text = io.read_file(path.join(site_dir, "pages.csv"))
  let pages = csv.parse_records(pages_text)

  let mut nav_parts = []
  for page in pages {
    let link = str.concat("<a href=\"", str.concat(page["slug"], str.concat(".html\">", str.concat(page["title"], "</a>"))))
    nav_parts = push(nav_parts, link)
  }
  let nav_html = str.join(nav_parts, " | ")

  let tmpl_content = io.read_file(path.join(site_dir, "template.html"))

  let build_time = datetime.iso(datetime.now())
  let mut generated_count = 0
  for page in pages {
    let vars = make_vars(page, nav_html, build_time)
    let html = template.render(tmpl_content, vars)
    let out_path = path.join(build_dir, path.with_extension(page["slug"], "html"))
    io.write_file(out_path, html)
    generated_count = generated_count + 1
    let size = len(html)
    println(str.concat("  wrote ", str.concat(out_path, str.concat(" (", str.concat(to_str(size), str.concat(" bytes, checksum ", str.concat(vars["checksum"], ")")))))))
  }

  let mut manifest = #{}
  manifest = map.set(manifest, "pages", generated_count)
  manifest = map.set(manifest, "timestamp", build_time)
  manifest = map.set(manifest, "generator", "a-lang site_gen v0.49")
  io.write_file(path.join(build_dir, "manifest.json"), json.pretty(manifest))

  println("")
  println(str.concat("Built ", str.concat(to_str(generated_count), str.concat(" pages to ", build_dir))))
  println(str.concat("Build time: ", build_time))

  let b64 = encoding.base64_encode(json.stringify(manifest))
  println(str.concat("Manifest (base64): ", b64))

  fs.rm(site_dir)
}
