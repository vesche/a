ty TokKind = KwFn | KwTy | KwMod | KwLet | KwMut | KwIf | KwElse | KwMatch | KwFor | KwIn | KwWhile | KwBreak | KwContinue | KwRet | KwUse | KwTry | KwPub | KwEffects | KwTrue | KwFalse | TInt(i64) | TFloat(str) | TStr(str) | TIdent(str) | LParen | RParen | LBrace | RBrace | LBracket | RBracket | Comma | Colon | Dot | Arrow | FatArrow | Pipe | PipeArrow | Hash | Eq | EqEq | Bang | NotEq | Lt | LtEq | Gt | GtEq | Plus | Minus | Star | Slash | Percent | Amp | AmpAmp | PipePipe | Semi | Question | Newline | Eof | Unknown(str)

ty Token = {kind: str, text: str, line: i64, col: i64}

fn is_ws(c: str) -> bool {
  ret c == " " || c == "\t" || c == "\r"
}

fn is_id_start(c: str) -> bool {
  ret is_alpha(c) || c == "_"
}

fn is_id_char(c: str) -> bool {
  ret is_alnum(c)
}

fn keyword_or_ident(word: str) -> str {
  if word == "fn" { ret "KwFn" }
  if word == "ty" { ret "KwTy" }
  if word == "mod" { ret "KwMod" }
  if word == "let" { ret "KwLet" }
  if word == "mut" { ret "KwMut" }
  if word == "if" { ret "KwIf" }
  if word == "else" { ret "KwElse" }
  if word == "match" { ret "KwMatch" }
  if word == "for" { ret "KwFor" }
  if word == "in" { ret "KwIn" }
  if word == "while" { ret "KwWhile" }
  if word == "break" { ret "KwBreak" }
  if word == "continue" { ret "KwContinue" }
  if word == "ret" { ret "KwRet" }
  if word == "use" { ret "KwUse" }
  if word == "try" { ret "KwTry" }
  if word == "pub" { ret "KwPub" }
  if word == "effects" { ret "KwEffects" }
  if word == "pre" { ret "KwPre" }
  if word == "post" { ret "KwPost" }
  if word == "where" { ret "KwWhere" }
  if word == "true" { ret "KwTrue" }
  if word == "false" { ret "KwFalse" }
  if word == "i8" { ret "TyI8" }
  if word == "i16" { ret "TyI16" }
  if word == "i32" { ret "TyI32" }
  if word == "i64" { ret "TyI64" }
  if word == "u8" { ret "TyU8" }
  if word == "u16" { ret "TyU16" }
  if word == "u32" { ret "TyU32" }
  if word == "u64" { ret "TyU64" }
  if word == "f32" { ret "TyF32" }
  if word == "f64" { ret "TyF64" }
  if word == "bool" { ret "TyBool" }
  if word == "str" { ret "TyStr" }
  if word == "bytes" { ret "TyBytes" }
  if word == "void" { ret "TyVoid" }
  ret "Ident"
}

fn lex(src: str) -> [str] effects [io] {
  let chars: [str] = str.chars(src)
  let n: i64 = len(chars)
  let mut pos: i64 = 0
  let mut line: i64 = 1
  let mut col: i64 = 1
  let mut tokens: [str] = []

  while pos < n {
    let c: str = chars[pos]

    if c == "\n" {
      tokens = push(tokens, "{line}:{col}:Newline:")
      pos = pos + 1
      line = line + 1
      col = 1
      continue
    }

    if is_ws(c) {
      pos = pos + 1
      col = col + 1
      continue
    }

    if c == "/" {
      if pos + 1 < n {
        if chars[pos + 1] == "/" {
          while pos < n {
            if chars[pos] == "\n" {
              break
            }
            pos = pos + 1
          }
          continue
        }
      }
    }

    if is_id_start(c) {
      let start: i64 = pos
      let start_col: i64 = col
      while pos < n {
        if is_id_char(chars[pos]) {
          pos = pos + 1
          col = col + 1
        } else {
          break
        }
      }
      let word: str = str.slice(src, start, pos)
      let kind: str = keyword_or_ident(word)
      tokens = push(tokens, "{line}:{start_col}:{kind}:{word}")
      continue
    }

    if is_digit(c) {
      let start: i64 = pos
      let start_col: i64 = col
      let mut is_float: bool = false
      while pos < n {
        if is_digit(chars[pos]) {
          pos = pos + 1
          col = col + 1
        } else {
          if chars[pos] == "." {
            if is_float {
              break
            }
            is_float = true
            pos = pos + 1
            col = col + 1
          } else {
            break
          }
        }
      }
      let text: str = str.slice(src, start, pos)
      if is_float {
        tokens = push(tokens, "{line}:{start_col}:Float:{text}")
      } else {
        tokens = push(tokens, "{line}:{start_col}:Int:{text}")
      }
      continue
    }

    if c == "\"" {
      let start: i64 = pos
      let start_col: i64 = col
      pos = pos + 1
      col = col + 1
      while pos < n {
        let sc: str = chars[pos]
        if sc == "\\" {
          pos = pos + 2
          col = col + 2
        } else {
          if sc == "\"" {
            pos = pos + 1
            col = col + 1
            break
          } else {
            pos = pos + 1
            col = col + 1
          }
        }
      }
      let text: str = str.slice(src, start, pos)
      tokens = push(tokens, "{line}:{start_col}:Str:{text}")
      continue
    }

    let start_col: i64 = col

    if c == "(" {
      tokens = push(tokens, "{line}:{col}:LParen:(")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == ")" {
      tokens = push(tokens, "{line}:{col}:RParen:)")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "\{" {
      tokens = push(tokens, str.concat(str.concat("{line}:{col}:LBrace:", ""), "\{"))
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "\}" {
      tokens = push(tokens, str.concat("{line}:{col}:RBrace:", "\}"))
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "[" {
      tokens = push(tokens, "{line}:{col}:LBracket:[")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "]" {
      tokens = push(tokens, "{line}:{col}:RBracket:]")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "," {
      tokens = push(tokens, "{line}:{col}:Comma:,")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == ":" {
      tokens = push(tokens, "{line}:{col}:Colon::")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "?" {
      tokens = push(tokens, "{line}:{col}:Question:?")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "#" {
      tokens = push(tokens, "{line}:{col}:Hash:#")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "+" {
      tokens = push(tokens, "{line}:{col}:Plus:+")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "*" {
      tokens = push(tokens, "{line}:{col}:Star:*")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "%" {
      tokens = push(tokens, "{line}:{col}:Percent:%")
      pos = pos + 1
      col = col + 1
      continue
    }
    if c == "." {
      tokens = push(tokens, "{line}:{col}:Dot:.")
      pos = pos + 1
      col = col + 1
      continue
    }

    if c == "-" {
      if pos + 1 < n {
        if chars[pos + 1] == ">" {
          tokens = push(tokens, "{line}:{col}:Arrow:->")
          pos = pos + 2
          col = col + 2
          continue
        }
      }
      tokens = push(tokens, "{line}:{col}:Minus:-")
      pos = pos + 1
      col = col + 1
      continue
    }

    if c == "=" {
      if pos + 1 < n {
        if chars[pos + 1] == "=" {
          tokens = push(tokens, "{line}:{col}:EqEq:==")
          pos = pos + 2
          col = col + 2
          continue
        }
        if chars[pos + 1] == ">" {
          tokens = push(tokens, "{line}:{col}:FatArrow:=>")
          pos = pos + 2
          col = col + 2
          continue
        }
      }
      tokens = push(tokens, "{line}:{col}:Eq:=")
      pos = pos + 1
      col = col + 1
      continue
    }

    if c == "!" {
      if pos + 1 < n {
        if chars[pos + 1] == "=" {
          tokens = push(tokens, "{line}:{col}:NotEq:!=")
          pos = pos + 2
          col = col + 2
          continue
        }
      }
      tokens = push(tokens, "{line}:{col}:Bang:!")
      pos = pos + 1
      col = col + 1
      continue
    }

    if c == "<" {
      if pos + 1 < n {
        if chars[pos + 1] == "=" {
          tokens = push(tokens, "{line}:{col}:LtEq:<=")
          pos = pos + 2
          col = col + 2
          continue
        }
      }
      tokens = push(tokens, "{line}:{col}:Lt:<")
      pos = pos + 1
      col = col + 1
      continue
    }

    if c == ">" {
      if pos + 1 < n {
        if chars[pos + 1] == "=" {
          tokens = push(tokens, "{line}:{col}:GtEq:>=")
          pos = pos + 2
          col = col + 2
          continue
        }
      }
      tokens = push(tokens, "{line}:{col}:Gt:>")
      pos = pos + 1
      col = col + 1
      continue
    }

    if c == "&" {
      if pos + 1 < n {
        if chars[pos + 1] == "&" {
          tokens = push(tokens, "{line}:{col}:AmpAmp:&&")
          pos = pos + 2
          col = col + 2
          continue
        }
      }
      tokens = push(tokens, "{line}:{col}:Amp:&")
      pos = pos + 1
      col = col + 1
      continue
    }

    if c == "|" {
      if pos + 1 < n {
        if chars[pos + 1] == "|" {
          tokens = push(tokens, "{line}:{col}:PipePipe:||")
          pos = pos + 2
          col = col + 2
          continue
        }
        if chars[pos + 1] == ">" {
          tokens = push(tokens, "{line}:{col}:PipeArrow:|>")
          pos = pos + 2
          col = col + 2
          continue
        }
      }
      tokens = push(tokens, "{line}:{col}:Pipe:|")
      pos = pos + 1
      col = col + 1
      continue
    }

    if c == "/" {
      tokens = push(tokens, "{line}:{col}:Slash:/")
      pos = pos + 1
      col = col + 1
      continue
    }

    tokens = push(tokens, "{line}:{col}:Unknown:{c}")
    pos = pos + 1
    col = col + 1
  }

  tokens = push(tokens, "{line}:{col}:Eof:")
  ret tokens
}

fn main() -> void effects [io] {
  let src: str = io.read_file("examples/self_lexer.a")
  let tokens: [str] = lex(src)
  println("{len(tokens)} tokens produced")
  let mut kw_count: i64 = 0
  let mut ident_count: i64 = 0
  let mut num_count: i64 = 0
  let mut str_count: i64 = 0
  for tok: str in tokens {
    let parts: [str] = str.split(tok, ":")
    if len(parts) >= 3 {
      let kind: str = parts[2]
      if str.starts_with(kind, "Kw") {
        kw_count = kw_count + 1
      }
      if kind == "Ident" {
        ident_count = ident_count + 1
      }
      if kind == "Int" || kind == "Float" {
        num_count = num_count + 1
      }
      if kind == "Str" {
        str_count = str_count + 1
      }
    }
  }
  println("keywords: {kw_count}")
  println("identifiers: {ident_count}")
  println("numbers: {num_count}")
  println("strings: {str_count}")
}
