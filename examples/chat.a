; chat.a -- Simple one-shot LLM chat
; Usage: a run examples/chat.a
; Requires ANTHROPIC_API_KEY env var (or swap provider/model)

use std.llm

fn main() {
  let msgs = [
    #{"role": "system", "content": "You are a concise assistant. Reply in one sentence."},
    #{"role": "user", "content": "What is the most interesting thing about the Rust programming language?"}
  ]
  let r = llm.chat("anthropic", "claude-sonnet-4-20250514", msgs, #{"max_tokens": 256})
  if is_err(r) {
    eprintln("error: {r}")
  } else {
    println(r["content"])
    println("")
    println("model: {r["model"]}  tokens: {r["usage"]["input_tokens"]}in/{r["usage"]["output_tokens"]}out")
  }
}
