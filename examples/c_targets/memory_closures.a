; memory_closures.a -- Closure memory: captures, escaping, nested

fn make_adder(n) {
  ret fn(x) { ret n + x }
}

fn make_counter() {
  let mut count = 0
  let inc = fn() {
    count = count + 1
    ret count
  }
  ret inc
}

fn test_basic_closure() {
  let add5 = make_adder(5)
  println(add5(10))
  println(add5(20))
}

fn test_counter() {
  let c = make_counter()
  println(c())
  println(c())
  println(c())
}

fn test_nested_closure() {
  let outer = fn(x) {
    ret fn(y) {
      ret x + y
    }
  }
  let add10 = outer(10)
  println(add10(5))
  println(add10(20))
}

fn test_hof() {
  let nums = [1, 2, 3, 4, 5]
  let doubled = map(nums, fn(x) { ret x * 2 })
  let evens = filter(doubled, fn(x) { ret x % 2 == 0 })
  let sum = reduce(evens, 0, fn(a, b) { ret a + b })
  println(doubled)
  println(evens)
  println(sum)
}

fn test_many_closures() {
  let a = make_adder(1)
  let b = make_adder(2)
  let c = make_adder(3)
  let d = make_adder(4)
  let e = make_adder(5)
  println(a(100))
  println(b(100))
  println(c(100))
  println(d(100))
  println(e(100))
}

fn main() {
  test_basic_closure()
  test_counter()
  test_nested_closure()
  test_hof()
  test_many_closures()
  println("memory_closures: OK")
}
