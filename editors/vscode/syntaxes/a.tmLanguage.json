{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "A",
  "scopeName": "source.a",
  "patterns": [
    { "include": "#comment" },
    { "include": "#heredoc" },
    { "include": "#raw-string-hashes2" },
    { "include": "#raw-string-hashes1" },
    { "include": "#raw-string" },
    { "include": "#string" },
    { "include": "#function-definition" },
    { "include": "#type-declaration" },
    { "include": "#module-declaration" },
    { "include": "#keywords" },
    { "include": "#boolean" },
    { "include": "#type-keywords" },
    { "include": "#number" },
    { "include": "#operator" },
    { "include": "#punctuation" },
    { "include": "#function-call" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.semicolon.a",
      "match": ";.*$"
    },

    "heredoc": {
      "name": "string.quoted.other.heredoc.a",
      "begin": "```",
      "end": "```"
    },

    "raw-string-hashes2": {
      "name": "string.quoted.other.raw.a",
      "begin": "r##\"",
      "end": "\"##"
    },

    "raw-string-hashes1": {
      "name": "string.quoted.other.raw.a",
      "begin": "r#\"",
      "end": "\"#"
    },

    "raw-string": {
      "name": "string.quoted.other.raw.a",
      "begin": "r\"",
      "end": "\""
    },

    "string": {
      "name": "string.quoted.double.a",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "include": "#string-escape" },
        { "include": "#string-interpolation" }
      ]
    },

    "string-escape": {
      "name": "constant.character.escape.a",
      "match": "\\\\[ntr\\\\\"{}]"
    },

    "string-interpolation": {
      "name": "meta.interpolation.a",
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.section.interpolation.begin.a" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.section.interpolation.end.a" }
      },
      "patterns": [
        { "include": "source.a" }
      ]
    },

    "function-definition": {
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "keyword.declaration.function.a" },
        "2": { "name": "entity.name.function.a" }
      }
    },

    "type-declaration": {
      "match": "\\b(ty)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.a" },
        "2": { "name": "entity.name.type.a" }
      }
    },

    "module-declaration": {
      "match": "\\b(mod)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.module.a" },
        "2": { "name": "entity.name.namespace.a" }
      }
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.a",
          "match": "\\b(fn|let|ty|mod|use)\\b"
        },
        {
          "name": "keyword.control.a",
          "match": "\\b(if|else|match|for|in|while|break|continue|ret|try)\\b"
        },
        {
          "name": "storage.modifier.a",
          "match": "\\b(mut|pub)\\b"
        },
        {
          "name": "keyword.other.a",
          "match": "\\b(effects|pre|post|where)\\b"
        }
      ]
    },

    "boolean": {
      "name": "constant.language.boolean.a",
      "match": "\\b(true|false)\\b"
    },

    "type-keywords": {
      "name": "support.type.primitive.a",
      "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|str|bytes|void)\\b"
    },

    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.a",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.a",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.a",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.a",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.comparison.a",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.logical.a",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.assignment.a",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.a",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.logical.not.a",
          "match": "!"
        },
        {
          "name": "keyword.operator.comparison.a",
          "match": "[<>]"
        },
        {
          "name": "keyword.operator.spread.a",
          "match": "\\.\\.\\."
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.braces.begin.a",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.a",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.a",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.a",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.a",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.a",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.a",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.a",
          "match": ":"
        },
        {
          "name": "punctuation.accessor.dot.a",
          "match": "\\."
        },
        {
          "name": "punctuation.definition.map.a",
          "match": "#"
        },
        {
          "name": "keyword.operator.try.a",
          "match": "\\?"
        },
        {
          "name": "punctuation.separator.pipe.a",
          "match": "\\|"
        }
      ]
    },

    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "entity.name.function.call.a" }
      }
    },

    "identifier": {
      "name": "variable.other.a",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
